{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "strict": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "jsx": "preserve"
  },
  "include": [".astro/types.d.ts", "src/**/*", "env.d.ts", "*.ts", "*.mjs"],
  "exclude": ["node_modules", "dist", "demo", "content"]
}
