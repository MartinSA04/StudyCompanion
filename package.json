{
  "name": "study-companion",
  "version": "3.5.3",
  "description": "A versioned, data-driven Astro integration + component library for interactive course study guides.",
  "type": "module",
  "license": "MIT",
  "author": "Martin Sundal",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MartinSA04/StudyCompanion.git"
  },
  "homepage": "https://github.com/MartinSA04/StudyCompanion",
  "packageManager": "pnpm@10.33.0",
  "exports": {
    ".": "./src/index.ts",
    "./content": "./src/content.ts",
    "./schema": "./src/schema.ts",
    "./styles": "./src/styles/tokens.css",
    "./styles/*": "./src/styles/*",
    "./pages/index.astro": "./src/pages/index.astro",
    "./pages/[slug].astro": "./src/pages/[slug].astro",
    "./pages/*": "./src/pages/*",
    "./components/*": "./src/components/*",
    "./mdx-components": "./src/mdx-components.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "hub:dev": "astro dev --config astro.config.hub.mjs",
    "hub:build": "astro build --config astro.config.hub.mjs",
    "hub:preview": "astro preview --config astro.config.hub.mjs",
    "test": "node --test --disable-warning=ExperimentalWarning 'test/**/*.test.ts'",
    "test:visual": "playwright test -c visual/playwright.config.ts",
    "test:visual:update": "playwright test -c visual/playwright.config.ts --update-snapshots",
    "typecheck": "astro sync && tsc --noEmit",
    "lint": "prettier --check \"{src,hub,visual,test,scripts}/**/*.{ts,astro,mjs}\" \"*.{ts,js,mjs,json,md}\"",
    "lint:fix": "prettier --write \"{src,hub,visual,test,scripts}/**/*.{ts,astro,mjs}\" \"*.{ts,js,mjs,json,md}\"",
    "lint:md": "markdownlint-cli2 \"**/*.md\""
  },
  "peerDependencies": {
    "astro": "^6"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.6",
    "katex": "^0.17.0",
    "pagefind": "^1.5.2",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "sharp": "^0.34.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.10.0",
    "astro": "^6.3.7",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "study-companion": "link:.",
    "typescript": "^6.0.3"
  }
}
