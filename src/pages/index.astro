---
import CourseLayout from "../layouts/CourseLayout.astro";
import Icon from "../components/Icon.astro";
import ImportanceTag from "../components/ImportanceTag.astro";
import { loadCourse } from "../lib/loadCourse.ts";
import { validateXrefs } from "../lib/xref.ts";
import { daysUntil, formatExamCountdown } from "../lib/countdown.ts";
import { upcomingDeadlines } from "../lib/deadlines.ts";
import { formatDate } from "../lib/dates.ts";
import { absoluteUrl, truncateDescription } from "../lib/seo.ts";
import { courseLd } from "../lib/jsonLd.ts";
import { readFileSync } from "node:fs";
import {
  sectionNav,
  sectionNumbers,
  sectionSlug,
  partGroups,
} from "../lib/nav.ts";

const { course, sections, flashcards, tools } = await loadCourse();

// 2.9 — Build-time cross-reference validation. The `/` route is always built,
// so validating here scans the whole course once and FAILS the build on a dead
// <Term>/<FormulaRef> target or a duplicate <Statement>/formula anchor. In DEV
// it only logs (the page must still render; the widgets already warn inline).
{
  const sectionInputs = sections.map((s) => {
    const e = s as { id: string; body?: string; filePath?: string };
    let body = e.body ?? "";
    if (!body && e.filePath) {
      try {
        body = readFileSync(e.filePath, "utf8");
      } catch {
        /* leave empty — nothing to scan */
      }
    }
    return { label: e.id, body };
  });
  const report = validateXrefs({
    glossaryTerms: course.glossary.map((g) => g.term),
    formulaIds: course.formulas.flatMap((f) => (f.id ? [f.id] : [])),
    sections: sectionInputs,
  });
  if (report.errors.length) {
    const msg =
      "study-companion: cross-reference validation failed —\n" +
      report.errors.map((e) => `  • ${e}`).join("\n");
    if (import.meta.env.DEV) console.error(`[study-companion] ${msg}`);
    else throw new Error(msg);
  }
  if (import.meta.env.DEV && report.unusedGlossary.length) {
    console.warn(
      `[study-companion] ${report.unusedGlossary.length} glossary term(s) not referenced by an inline <Term>: ${report.unusedGlossary.join(", ")}`,
    );
  }
}

const nav = sectionNav(sections);
const nums = sectionNumbers(sections);

// Module tiles, derived from section frontmatter.
const tiles = sections.map((s) => ({
  slug: sectionSlug(s.id),
  num: nums.get(s.id) ?? String(s.data.order).padStart(2, "0"),
  title: s.data.title,
  part: s.data.part,
  importance: s.data.importance,
  week: s.data.tag ?? "",
}));

// Group tiles into parts (single null-part group when no section sets one).
const tileGroups = partGroups(tiles);

const examDate = course.exam?.date
  ? formatDate(course.exam.date, course.language)
  : null;
// Build-time snapshot; the page script re-derives the countdown against the
// viewer's clock (data-exam-countdown below carries the date for it).
const daysToExam = course.exam?.date ? daysUntil(course.exam.date) : null;
const examIso = course.exam?.date?.toISOString();
const hasExamCard =
  examDate ||
  course.exam?.format ||
  course.exam?.aids ||
  course.exam?.time ||
  daysToExam != null;

// Overview agenda: dated coursework still ahead, soonest first. A build-time
// snapshot — the page script hides any row that slips past the viewer's clock.
const deadlines = upcomingDeadlines(course.deadlines);
const nextDeadline = deadlines[0];

// ---- SEO + structured data ----
const overviewUrl = absoluteUrl("/", Astro.site);
const seo = {
  description: truncateDescription(
    course.subtitle ? `${course.title} — ${course.subtitle}` : course.title,
  ),
  ogType: "website" as const,
};
const jsonLd = [
  courseLd({
    code: course.code,
    title: course.title,
    description: seo.description,
    url: overviewUrl,
    inLanguage: course.language,
    // Explicit provider only — never guessed from a URL host (see schema).
    provider: course.institution
      ? { name: course.institution, url: course.courseUrl }
      : undefined,
  }),
];
---

<CourseLayout
  course={course}
  nav={nav}
  tools={tools}
  active="top"
  seo={seo}
  jsonLd={jsonLd}
  hasMath={false}
>
  <section class="hero">
    <div class="hero-tag">{course.code} · {course.term}</div>
    <h1>{course.title}</h1>
    <p>
      {course.subtitle ? `${course.subtitle}. ` : ""}
      {sections.length} moduler med læringsmål, kjerneteori, formler og selvtest —
      velg en modul i menyen, eller en flis nedenfor.
    </p>
    {
      course.courseUrl && (
        <p class="hero-meta">
          <a
            class="hero-course-link"
            href={course.courseUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            {course.ui.courseLabel}
            <Icon name="external" size={14} />
          </a>
        </p>
      )
    }
    {
      course.features.progress && (
        <div class="hero-progress-row" data-hero-progress-row hidden>
          <p class="hero-done">
            <span data-progress-done>0</span> av {tiles.length} moduler fullført
          </p>
          <a
            class="hero-continue sc-pill sc-press"
            data-hero-continue
            href="#"
            hidden
          >
            Fortsett der du slapp
            <Icon name="arrow-right" size={14} />
          </a>
        </div>
      )
    }
  </section>

  {
    hasExamCard && (
      <div class="card">
        <h2>
          <span class="dot" />
          {course.ui.examsLabel}
        </h2>
        {examDate && (
          <p>
            <strong>Dato:</strong> {examDate}
            {daysToExam != null && daysToExam >= 0 && (
              <span data-exam-countdown={examIso} data-countdown-hide-past>
                {" — "}
                <span data-countdown-text>
                  {formatExamCountdown(daysToExam)}
                </span>
              </span>
            )}
          </p>
        )}
        {course.exam?.time && (
          <p>
            <strong>Tid:</strong> {course.exam.time}
          </p>
        )}
        {course.exam?.format && (
          <p>
            <strong>Form:</strong> {course.exam.format}
          </p>
        )}
        {course.exam?.aids && (
          <p>
            <strong>Hjelpemidler:</strong> {course.exam.aids}
          </p>
        )}
        {/* Studentweb owns the authoritative exam facts; a quiet mono meta
            line points there from every surface that prints them. */}
        <p class="exam-authority">
          <a
            href={course.exam!.authorityUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            {course.ui.examAuthorityNote}
            <Icon name="external" size={14} />
          </a>
        </p>
      </div>
    )
  }

  {
    deadlines.length > 0 && (
      <div class="card">
        <h2>
          <span class="dot" />
          {course.ui.deadlinesLabel}
        </h2>
        {/* Lede: the soonest deadline + its countdown. The phrase sits in a
            data-countdown-text child so lib/examCountdown.ts re-derives it
            against the viewer's clock; the whole line hides once it passes. */}
        <p
          data-exam-countdown={nextDeadline.date.toISOString()}
          data-countdown-hide-past
        >
          {course.ui.nextDeadlineLabel}: {nextDeadline.title}
          {" — "}
          <span data-countdown-text>
            {formatExamCountdown(daysUntil(nextDeadline.date))}
          </span>
        </p>
        {/* Flat list, no per-section grouping and no done-states. Each row
            carries its date only to auto-hide client-side once past
            (data-countdown-no-text keeps its SSR text verbatim). */}
        <ul class="deadline-list">
          {deadlines.map((d) => (
            <li
              class="deadline-row"
              data-exam-countdown={d.date.toISOString()}
              data-countdown-hide-past
              data-countdown-no-text
            >
              <time
                class="deadline-date"
                datetime={d.date.toISOString().slice(0, 10)}
              >
                {formatDate(d.date, course.language)}
              </time>
              <span class="deadline-body">
                {d.url ? (
                  <a href={d.url} target="_blank" rel="noopener noreferrer">
                    {d.title}
                  </a>
                ) : (
                  d.title
                )}
                {d.note && <span class="deadline-note">{d.note}</span>}
              </span>
            </li>
          ))}
        </ul>
      </div>
    )
  }

  {
    tileGroups.map((group) => (
      <>
        {group.part && <h2 class="part-head">{group.part}</h2>}
        <div class="overview-grid">
          {group.items.map((t) => (
            <a
              class="module-tile sc-press sc-tile sc-lift"
              href={`/${t.slug}`}
              data-tile-slug={t.slug}
            >
              <div class="tile-num">{t.num}</div>
              <div class="tile-title">{t.title}</div>
              <div class="tile-meta">
                <ImportanceTag importance={t.importance} />
                {t.week && <span class="tile-week">{t.week}</span>}
              </div>
              {course.features.progress && (
                <>
                  <span class="tile-check" aria-hidden="true">
                    <Icon name="check" size={11} />
                  </span>
                  {/* Text companion to the aria-hidden check icon, kept in
                      sync with the .done class by the paint script below so
                      the tile's accessible name always states completion. */}
                  <span class="sr-only" data-done-sr />
                </>
              )}
            </a>
          ))}
        </div>
      </>
    ))
  }
</CourseLayout>

<style>
  /* Studentweb authority note under the exam facts — a quiet mono meta line
     mirroring the hero's external "Emneside" link; a footnote, not a callout. */
  .exam-authority {
    margin-top: var(--gap-4);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }
  .exam-authority a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--accent-ink);
    text-decoration: none;
  }
  .exam-authority a:hover {
    text-decoration: underline;
  }

  /* Overview deadline agenda — a flat dated list with no urgency ramp and no
     done-states. Mono date as marginalia, serif title as content. */
  .deadline-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .deadline-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-1) var(--space-3);
  }
  /* The date reads in the normal muted meta tone — never a colour that
     intensifies as the deadline nears. */
  .deadline-date {
    flex: none;
    min-width: 9rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
  }
  .deadline-body {
    color: var(--fg);
  }
  .deadline-note {
    display: block;
    color: var(--muted);
    font-size: var(--text-sm);
  }
</style>

<script>
  import { onPage } from "../lib/pageLifecycle.ts";
  import { paintOverview } from "../lib/progress.ts";
  import { refreshExamCountdowns } from "../lib/examCountdown.ts";

  onPage(() => {
    // Tile done-marks, the hero "N av M fullført" row and the continue link;
    // see lib/progress.ts for the paint/intersection contract.
    paintOverview(document);
    // The exam card's "om N dager" and the deadline agenda's rows are
    // build-time snapshots; recompute/hide them against the viewer's clock
    // (see lib/examCountdown.ts — same [data-exam-countdown] contract).
    refreshExamCountdowns();
  });
  // The incoming-overview pre-paint (so tiles never flash unmarked for a frame
  // during a view-transition swap) lives in CourseLayout's before-swap handler
  // instead: this page's script isn't loaded until the overview has rendered
  // once, so it can't cover the first module→overview swap of a session that
  // started elsewhere. The layout script — shipped on every page — can.
</script>
