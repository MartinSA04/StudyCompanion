---
import { getCollection } from "astro:content";
import CourseLayout from "../layouts/CourseLayout.astro";
import Icon from "../components/Icon.astro";
import ImportanceTag from "../components/ImportanceTag.astro";
import { loadCourse } from "../lib/loadCourse.ts";
import { validateXrefs } from "../lib/xref.ts";
import { absoluteUrl, truncateDescription } from "../lib/seo.ts";
import { courseLd } from "../lib/jsonLd.ts";
import { readFileSync } from "node:fs";
import {
  sectionNav,
  sectionNumbers,
  sectionSlug,
  toolFlags,
  partGroups,
} from "../lib/nav.ts";

const { course, sections } = await loadCourse();

// 2.9 — Build-time cross-reference validation. The `/` route is always built,
// so validating here scans the whole course once and FAILS the build on a dead
// <Term>/<FormulaRef> target or a duplicate <Statement>/formula anchor. In DEV
// it only logs (the page must still render; the widgets already warn inline).
{
  const sectionInputs = sections.map((s) => {
    const e = s as { id: string; body?: string; filePath?: string };
    let body = e.body ?? "";
    if (!body && e.filePath) {
      try {
        body = readFileSync(e.filePath, "utf8");
      } catch {
        /* leave empty — nothing to scan */
      }
    }
    return { label: e.id, body };
  });
  const report = validateXrefs({
    glossaryTerms: course.glossary.map((g) => g.term),
    formulaIds: course.formulas.flatMap((f) => (f.id ? [f.id] : [])),
    sections: sectionInputs,
  });
  if (report.errors.length) {
    const msg =
      "study-companion: cross-reference validation failed —\n" +
      report.errors.map((e) => `  • ${e}`).join("\n");
    if (import.meta.env.DEV) console.error(`[study-companion] ${msg}`);
    else throw new Error(msg);
  }
  if (import.meta.env.DEV && report.unusedGlossary.length) {
    console.warn(
      `[study-companion] ${report.unusedGlossary.length} glossary term(s) not referenced by an inline <Term>: ${report.unusedGlossary.join(", ")}`,
    );
  }
}

const flashcards = course.features.flashcards
  ? ((await getCollection("flashcards"))[0]?.data.cards ?? [])
  : [];

const nav = sectionNav(sections);
const tools = toolFlags(course, flashcards.length);
const nums = sectionNumbers(sections);

// Module tiles, derived from section frontmatter.
const tiles = sections.map((s) => ({
  slug: sectionSlug(s.id),
  order: s.data.order,
  num: nums.get(s.id) ?? String(s.data.order).padStart(2, "0"),
  title: s.data.title,
  part: s.data.part,
  importance: s.data.importance,
  week: s.data.tags[0] ?? "",
}));

// Group tiles into parts (single null-part group when no section sets one).
const tileGroups = partGroups(tiles);

const dateFmt = new Intl.DateTimeFormat(course.language, { dateStyle: "long" });
const examDate = course.exam?.date ? dateFmt.format(course.exam.date) : null;
const daysToExam = course.exam?.date
  ? Math.ceil((course.exam.date.getTime() - Date.now()) / 86_400_000)
  : null;
const hasExamCard =
  examDate || course.exam?.format || course.exam?.aids || daysToExam != null;

// ---- SEO + structured data (4.2–4.4) ----
const overviewUrl = absoluteUrl("/", Astro.site);
const seo = {
  description: truncateDescription(
    course.subtitle ? `${course.title} — ${course.subtitle}` : course.title,
  ),
  ogType: "website" as const,
};
const jsonLd = [
  courseLd({
    code: course.code,
    title: course.title,
    description: seo.description,
    url: overviewUrl,
    inLanguage: course.language,
    // Explicit provider only — never guessed from a URL host (see schema).
    provider: course.institution
      ? { name: course.institution, url: course.courseUrl }
      : undefined,
  }),
];
---

<CourseLayout
  course={course}
  nav={nav}
  tools={tools}
  active="top"
  seo={seo}
  jsonLd={jsonLd}
>
  <section class="hero">
    <div class="hero-tag">{course.code} · {course.term}</div>
    <h1>{course.title}</h1>
    <p>
      {course.subtitle ? `${course.subtitle}. ` : ""}
      {sections.length} moduler med læringsmål, kjerneteori, formler og selvtest —
      velg en modul i menyen, eller en flis nedenfor.
    </p>
    {
      course.courseUrl && (
        <p class="hero-meta">
          <a
            class="hero-course-link"
            href={course.courseUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            {course.ui.courseLabel}
            <Icon name="external" size={14} />
          </a>
        </p>
      )
    }
    {
      course.features.progress && (
        <div class="hero-progress-row" data-hero-progress-row hidden>
          <p class="hero-done">
            <span data-progress-done>0</span> av {tiles.length} moduler fullført
          </p>
          <a class="hero-continue sc-press" data-hero-continue href="#" hidden>
            Fortsett der du slapp
            <Icon name="arrow-right" size={14} />
          </a>
        </div>
      )
    }
  </section>

  {
    hasExamCard && (
      <div class="card">
        <h2>
          <span class="dot" />
          {course.ui.examsLabel}
        </h2>
        {examDate && (
          <p>
            <strong>Dato:</strong> {examDate}
            {daysToExam != null && daysToExam >= 0 && (
              <span>
                {" "}
                — {daysToExam === 0 ? "i dag" : `om ${daysToExam} dager`}
              </span>
            )}
          </p>
        )}
        {course.exam?.format && (
          <p>
            <strong>Form:</strong> {course.exam.format}
          </p>
        )}
        {course.exam?.aids && (
          <p>
            <strong>Hjelpemidler:</strong> {course.exam.aids}
          </p>
        )}
      </div>
    )
  }

  {
    tileGroups.map((group) => (
      <>
        {group.part && <h2 class="part-head">{group.part}</h2>}
        <div class="overview-grid">
          {group.items.map((t) => (
            <a
              class="module-tile sc-press sc-tile"
              href={`/${t.slug}`}
              data-tile-order={t.order}
            >
              <div class="tile-num">{t.num}</div>
              <div class="tile-title">{t.title}</div>
              <div class="tile-meta">
                <ImportanceTag importance={t.importance} />
                {t.week && <span class="tile-week">{t.week}</span>}
              </div>
              {course.features.progress && (
                <span class="tile-check" aria-hidden="true">
                  <Icon name="check" size={11} />
                </span>
              )}
            </a>
          ))}
        </div>
      </>
    ))
  }
</CourseLayout>

<script is:inline data-astro-rerun>
  // data-astro-rerun: re-paint the tile/continue state each time the overview is
  // (re-)loaded via a view transition. Idempotent — it only reads + sets classes.
  (function () {
    var key = document.body.dataset.progressKey;
    if (!key) return;
    var done;
    try {
      done = new Set(JSON.parse(localStorage.getItem(key) || "[]").map(Number));
    } catch (e) {
      done = new Set();
    }
    if (!done.size) return;

    var tiles = Array.from(document.querySelectorAll("[data-tile-order]"));
    tiles.forEach(function (t) {
      if (done.has(Number(t.dataset.tileOrder))) t.classList.add("done");
    });

    var row = document.querySelector("[data-hero-progress-row]");
    if (row) {
      var doneEl = row.querySelector("[data-progress-done]");
      if (doneEl) doneEl.textContent = String(done.size);
      row.hidden = false;
    }

    var continueLink = document.querySelector("[data-hero-continue]");
    var firstUndone = tiles.find(function (t) {
      return !t.classList.contains("done");
    });
    if (continueLink && firstUndone) {
      continueLink.href = firstUndone.href;
      continueLink.hidden = false;
    }
  })();
</script>
