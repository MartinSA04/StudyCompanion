---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import CourseLayout from "../layouts/CourseLayout.astro";
import FormulaSheet from "../components/FormulaSheet.astro";
import Glossary from "../components/Glossary.astro";
import Flashcards from "../components/Flashcards.astro";
import ExamList from "../components/ExamList.astro";
import ExamSummary from "../components/ExamSummary.astro";
import Icon from "../components/Icon.astro";
import PageToc from "../components/PageToc.astro";
import ImportanceTag from "../components/ImportanceTag.astro";
import { loadCourse } from "../lib/loadCourse.ts";
import { IMPORTANCE_LABELS } from "../lib/importance.ts";
import { absoluteUrl, truncateDescription, stripInline } from "../lib/seo.ts";
import {
  breadcrumbList,
  learningResourceLd,
  definedTermSetLd,
} from "../lib/jsonLd.ts";
import { slugify } from "../lib/slug.ts";
import { mdxComponents } from "../mdx-components.ts";
import {
  sectionNav,
  sectionNumbers,
  sectionSlug,
  toolFlags,
  TOOL_SLUGS,
} from "../lib/nav.ts";

type Neighbor = { slug: string; num: string } | null;
type Props =
  | {
      kind: "section";
      entry: CollectionEntry<"sections">;
      prev: Neighbor;
      next: Neighbor;
    }
  | { kind: "formulas" | "glossary" | "flashcards" | "exams" };

export async function getStaticPaths() {
  const { course, sections } = await loadCourse();
  const flashcards = course.features.flashcards
    ? ((await getCollection("flashcards"))[0]?.data.cards ?? [])
    : [];
  const tools = toolFlags(course, flashcards.length);
  const nums = sectionNumbers(sections);

  const neighbor = (s?: CollectionEntry<"sections">): Neighbor =>
    s ? { slug: sectionSlug(s.id), num: nums.get(s.id) ?? "" } : null;

  const paths: { params: { slug: string }; props: Props }[] = sections.map(
    (entry, i) => ({
      params: { slug: sectionSlug(entry.id) },
      props: {
        kind: "section" as const,
        entry,
        prev: neighbor(sections[i - 1]),
        next: neighbor(sections[i + 1]),
      },
    }),
  );

  if (tools.formulas)
    paths.push({
      params: { slug: TOOL_SLUGS.formulas },
      props: { kind: "formulas" },
    });
  if (tools.glossary)
    paths.push({
      params: { slug: TOOL_SLUGS.glossary },
      props: { kind: "glossary" },
    });
  if (tools.flashcards)
    paths.push({
      params: { slug: TOOL_SLUGS.flashcards },
      props: { kind: "flashcards" },
    });
  if (tools.exams)
    paths.push({
      params: { slug: TOOL_SLUGS.exams },
      props: { kind: "exams" },
    });

  return paths;
}

const props = Astro.props as Props;
const active = Astro.params.slug;

// Shared chrome data (cheap — collections are cached during the build).
const { course, sections } = await loadCourse();
const flashcards = course.features.flashcards
  ? ((await getCollection("flashcards"))[0]?.data.cards ?? [])
  : [];
const nav = sectionNav(sections);
const tools = toolFlags(course, flashcards.length);
const nums = sectionNumbers(sections);

let pageTitle = course.title;
let Content: Awaited<ReturnType<typeof render>>["Content"] | null = null;
let headings: { depth: number; slug: string; text: string }[] = [];
// Footer "edit this page" + freshness — section pages only, when repoUrl is set.
let editUrl: string | undefined;
let updated: Date | undefined;
let head: {
  kicker: string;
  index: string;
  title: string;
  week: string;
  order: number;
  importance: (typeof sections)[number]["data"]["importance"];
} | null = null;

if (props.kind === "section") {
  const d = props.entry.data;
  ({ Content, headings } = await render(props.entry));
  pageTitle = d.title;
  updated = d.updated;
  const repoUrl = course.repoUrl?.replace(/\/+$/, "");
  if (repoUrl && props.entry.filePath) {
    editUrl = `${repoUrl}/edit/${course.repoBranch}/${props.entry.filePath}`;
  }
  const weekParts = [
    d.estMinutes != null ? `~${d.estMinutes} min lesing` : null,
    ...d.tags.slice(1),
  ].filter(Boolean);
  head = {
    kicker: d.tags[0] ?? IMPORTANCE_LABELS[d.importance],
    index: nums.get(props.entry.id) ?? String(d.order).padStart(2, "0"),
    title: d.title,
    importance: d.importance,
    week: weekParts.join(" · "),
    order: d.order,
  };
} else if (props.kind === "formulas") {
  pageTitle = course.ui.formulaSheetLabel;
} else if (props.kind === "glossary") {
  pageTitle = course.ui.glossaryLabel;
} else if (props.kind === "flashcards") {
  pageTitle = course.ui.flashcardsLabel;
} else {
  pageTitle = course.ui.examsLabel;
}

// ---- SEO + JSON-LD (4.2–4.4, 4.6) ----
// Module pages are `article`s (with a modified time + LearningResource); tool
// pages are `website`s. Every page gets a breadcrumb; the glossary also gets a
// DefinedTermSet. Absolute URLs resolve against `site` (relative without it).
const abs = (p: string) => absoluteUrl(p, Astro.site);
const overviewCrumb = { name: "Oversikt", url: abs("/") };
const pageUrl = abs(`/${active}`);

let seoDescription = course.subtitle
  ? `${course.title} — ${course.subtitle}`
  : course.title;
let ogType: "website" | "article" = "website";
let modifiedTime: string | undefined;
let noindex = false;
const jsonLd: Record<string, unknown>[] = [];

if (props.kind === "section") {
  const d = props.entry.data;
  seoDescription = d.summary ?? `${d.title} — ${course.title}`;
  ogType = "article";
  modifiedTime = d.updated?.toISOString();
  noindex = d.noindex;
  jsonLd.push(
    learningResourceLd({
      name: d.title,
      description: truncateDescription(seoDescription),
      url: pageUrl,
      inLanguage: course.language,
      dateModified: modifiedTime,
      isPartOf: { name: `${course.code} ${course.title}`, url: abs("/") },
    }),
    breadcrumbList([overviewCrumb, { name: d.title, url: pageUrl }]),
  );
} else {
  // Tool pages: a localized stock description from the page's own label.
  seoDescription = `${pageTitle} — ${course.title}`;
  jsonLd.push(
    breadcrumbList([overviewCrumb, { name: pageTitle, url: pageUrl }]),
  );
  if (props.kind === "glossary" && course.glossary.length) {
    jsonLd.push(
      definedTermSetLd({
        name: pageTitle,
        url: pageUrl,
        inLanguage: course.language,
        terms: course.glossary.map((g) => ({
          term: g.term,
          definition: stripInline(g.definition),
          id: slugify(g.term),
        })),
      }),
    );
  }
}

const seo = {
  description: truncateDescription(seoDescription),
  ogType,
  modifiedTime,
  noindex,
};
---

<CourseLayout
  course={course}
  nav={nav}
  tools={tools}
  active={active}
  pageTitle={pageTitle}
  editUrl={editUrl}
  updated={updated}
  seo={seo}
  jsonLd={jsonLd}
>
  {
    props.kind === "section" && head && Content && (
      <>
        <header class="mod-head">
          <div class="mod-index">{head.index}</div>
          <div class="meta">
            <div class="mod-kicker">{head.kicker}</div>
            <h1>{head.title}</h1>
            <div class="mod-meta-row">
              <ImportanceTag importance={head.importance} />
              {head.week && <span class="week">{head.week}</span>}
            </div>
          </div>
          {course.features.progress && (
            <button class="done-btn" type="button" data-done-order={head.order}>
              <span class="done-check" aria-hidden="true">
                <Icon name="check" size={15} />
              </span>
              <span data-done-label>Marker fullført</span>
            </button>
          )}
        </header>

        <PageToc headings={headings} label={course.ui.tocLabel} />

        <article class="prose" data-pagefind-body data-section={head.order}>
          <Content components={mdxComponents} />
        </article>

        <nav class="page-actions" aria-label="Moduler">
          {props.prev ? (
            <a class="page-link" href={`/${props.prev.slug}`} data-page-prev>
              <Icon name="chevron-left" size={15} />
              Forrige: {props.prev.num}
            </a>
          ) : (
            <span class="page-link disabled" />
          )}
          {props.next ? (
            <a class="page-link" href={`/${props.next.slug}`} data-page-next>
              Neste: {props.next.num}
              <Icon name="chevron-right" size={15} />
            </a>
          ) : (
            <a class="page-link" href="/" data-page-next>
              Til oversikt
            </a>
          )}
        </nav>
      </>
    )
  }

  {
    props.kind === "formulas" && (
      <>
        <header class="tool-head">
          <div class="mod-kicker">Verktøy</div>
          <h1>{course.ui.formulaSheetLabel}</h1>
        </header>
        {course.exam?.formulaSheetUrl && (
          <a
            class="official-sheet"
            href={course.exam.formulaSheetUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            <Icon name="file" size={18} />
            <span class="os-label">{course.ui.officialFormulaSheetLabel}</span>
            <Icon name="external" size={14} />
          </a>
        )}
        <FormulaSheet
          formulas={course.formulas}
          examFormulaSheet={course.exam?.formulaSheet ?? true}
          noFormulaSheetNote={course.ui.noFormulaSheetNote}
        />
      </>
    )
  }

  {
    props.kind === "glossary" && (
      <>
        <header class="tool-head">
          <div class="mod-kicker">Verktøy</div>
          <h1>{course.ui.glossaryLabel}</h1>
        </header>
        <Glossary glossary={course.glossary} />
      </>
    )
  }

  {
    props.kind === "flashcards" && (
      <>
        <header class="tool-head">
          <div class="mod-kicker">Verktøy</div>
          <h1>{course.ui.flashcardsLabel}</h1>
        </header>
        <Flashcards cards={flashcards} code={course.code} />
      </>
    )
  }

  {
    props.kind === "exams" && (
      <>
        <header class="tool-head">
          <div class="mod-kicker">Verktøy</div>
          <h1>{course.ui.examsLabel}</h1>
        </header>
        {course.exam && (
          <ExamSummary exam={course.exam} language={course.language} />
        )}
        {course.examArchive && (
          <p class="exam-archive-note">{course.ui.examArchiveNote}</p>
        )}
        <ExamList
          exams={course.exams}
          language={course.language}
          archive={course.examArchive}
        />
      </>
    )
  }
</CourseLayout>
