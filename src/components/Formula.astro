---
import katex from "katex";
import { renderMathString, ignoreInSearch } from "../lib/katex.ts";
import Icon from "./Icon.astro";

/**
 * A labelled, server-rendered KaTeX formula. Zero client JS — the TeX is
 * rendered to HTML+MathML at build time.
 *
 * `block` (default) lays the formula out the way the original optics guide
 * did: a panel row with the formula on the left and its caption to the right,
 * not a centred display equation. Consecutive `<Formula>` blocks merge into one
 * continuous panel with dashed dividers (see the sibling rules below). Use
 * `block={false}` for inline math inside prose. The caption may itself contain
 * `$inline$` math. Set `memorize` to flag a formula that is NOT on the exam
 * sheet and must be learned by heart — it gets a "må pugges" badge instead of
 * spelling that out in every caption.
 */
interface Props {
  tex: string;
  caption?: string;
  block?: boolean;
  /** Not on the exam sheet → show a star "må pugges" badge. */
  memorize?: boolean;
}
const { tex, caption, block = true, memorize = false } = Astro.props;

// Block formulas: render with a \displaystyle prefix in *inline* mode rather
// than display mode. This keeps fractions full-size and lets \left(…\right)
// and matrix delimiters stretch to their content (correct parenthesis
// height), but emits a plain `.katex` span — not `.katex-display`, which
// carries the base stylesheet's overflow-x rule and would add a stray
// horizontal scrollbar. Inline prose math (block=false) stays text-style so it
// sits on the line with the surrounding sentence.
const html = ignoreInSearch(
  katex.renderToString(block ? `\\displaystyle ${tex}` : tex, {
    displayMode: false,
    throwOnError: false, // render the offending TeX in red instead of failing build
    output: "htmlAndMathml",
  }),
);
---

{
  block ? (
    <figure class="formula">
      <div class="formula-row">
        <span class="fx" set:html={html} />
        {caption && <span class="desc" set:html={renderMathString(caption)} />}
        {memorize && (
          <span
            class="formula-badge"
            title="Står ikke på formelarket – må pugges"
          >
            <Icon name="star" size={12} />
            må pugges
          </span>
        )}
      </div>
    </figure>
  ) : (
    <span class="formula-inline" set:html={html} />
  )
}

<style>
  .formula {
    margin-block: var(--space-5);
    padding: 0 var(--space-5);
    background: var(--card);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
  }

  /* Merge consecutive formula blocks into one panel with dashed dividers,
     mirroring the original guide's grouped .formula-box. `+` skips whitespace
     text nodes, so blank lines between <Formula> blocks in MDX don't break the
     run; intervening prose does (as it should). */
  .formula:has(+ .formula) {
    margin-bottom: 0;
    border-bottom: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
  }
  .formula + .formula {
    margin-top: 0;
    border-top: 1px dashed var(--border);
    border-top-left-radius: 0;
    border-top-right-radius: 0;
  }

  .formula-row {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    padding: var(--space-3) 0;
  }
  .fx {
    flex: none;
    min-width: 150px;
    color: var(--fg);
  }
  .fx :global(.katex) {
    font-size: 1.15em;
  }
  .desc {
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: var(--leading-snug);
  }
  .desc :global(b),
  .desc :global(strong) {
    color: var(--accent);
    font-weight: var(--weight-semibold);
  }
  /* "Must memorise" badge — matches the FormulaSheet memorize badge. */
  .formula-badge {
    flex: none;
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking);
    color: var(--warning);
    border: 1px solid var(--warning);
    border-radius: var(--radius-sm);
    padding: 0.15em 0.55em;
    white-space: nowrap;
  }

  .formula-inline {
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .formula-row {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-2);
    }
    .fx {
      min-width: 0;
    }
    .formula-badge {
      margin-left: 0;
    }
  }
</style>
