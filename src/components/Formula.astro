---
import katex from "katex";
import { renderMathString, ignoreInSearch } from "../lib/katex.ts";
import MemorizeBadge from "./MemorizeBadge.astro";

/**
 * A labelled, server-rendered KaTeX formula. Zero client JS — the TeX is
 * rendered to HTML+MathML at build time.
 *
 * `block` (default) lays the formula out the way the original optics guide
 * did: a panel row with the formula on the left and its caption to the right,
 * not a centred display equation. Consecutive `<Formula>` blocks merge into one
 * continuous panel with dashed dividers (see the sibling rules below). Use
 * `block={false}` for inline math inside prose. The caption may itself contain
 * `$inline$` math. Set `memorize` to flag a formula that is NOT on the exam
 * sheet and must be learned by heart — it gets a "må pugges" badge instead of
 * spelling that out in every caption.
 */
interface Props {
  tex: string;
  caption?: string;
  block?: boolean;
  /** Not on the exam sheet — show a "må pugges" badge. */
  memorize?: boolean;
}
const { tex, caption, block = true, memorize = false } = Astro.props;

// Block formulas: render with a \displaystyle prefix in *inline* mode rather
// than display mode. This keeps fractions full-size and lets \left(…\right)
// and matrix delimiters stretch to their content (correct parenthesis
// height), but emits a plain `.katex` span — not `.katex-display`, which
// carries the base stylesheet's overflow-x rule and would add a stray
// horizontal scrollbar. Inline prose math (block=false) stays text-style so it
// sits on the line with the surrounding sentence.
const html = ignoreInSearch(
  katex.renderToString(block ? `\\displaystyle ${tex}` : tex, {
    displayMode: false,
    throwOnError: false, // render the offending TeX in red instead of failing build
    output: "htmlAndMathml",
  }),
);
---

{
  block ? (
    <figure class="formula">
      <div class="formula-row">
        <span class="fx" set:html={html} tabindex="0" />
        {caption && <span class="desc" set:html={renderMathString(caption)} />}
        {memorize && <MemorizeBadge />}
      </div>
    </figure>
  ) : (
    <span class="formula-inline" set:html={html} />
  )
}

<style>
  .formula {
    /* Flat, not floating: consecutive formulas merge into one panel (below), and
       a per-block shadow would streak the seams. When a formula sits inside a
       card, the nested-recess rule gives it depth via fill instead. */
    margin-block: var(--space-5);
    padding: 0 var(--space-5);
    background: var(--card);
    border-radius: var(--radius);
  }

  /* Merge consecutive formula blocks into one panel with dashed dividers,
     mirroring the original guide's grouped .formula-box. `+` skips whitespace
     text nodes, so blank lines between <Formula> blocks in MDX don't break the
     run; intervening prose does (as it should). */
  .formula:has(+ .formula) {
    margin-bottom: 0;
    border-bottom: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
  }
  .formula + .formula {
    margin-top: 0;
    border-top: 1px dashed var(--border);
    border-top-left-radius: 0;
    border-top-right-radius: 0;
  }

  .formula-row {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    padding: var(--space-3) 0;
  }
  .fx {
    /* Own scroll container so a wide, unbreakable formula scrolls inside this
       cell rather than giving the whole page a horizontal scrollbar that shifts
       the topbar/nav (WCAG 1.4.10). flex:0 1 auto (not none) lets the cell
       shrink to the row so max-width:100% can cap it and overflow-x confine the
       spill; the 150px floor only aligns narrow formulas and stays well under
       the cap. The inline variant's baseline/vertical-align dance does not
       apply here — .fx is a flex item under align-items:center, not an inline
       box. tabindex=0 (on the element) makes the scroll viewport
       keyboard-reachable, matching .katex-display / Shiki <pre> / .table-scroll
       (WCAG 2.1.1): block panels follow .katex-display and stay focusable; only
       inline prose math (.formula-inline) stays unfocusable. */
    flex: 0 1 auto;
    min-width: 150px;
    max-width: 100%;
    overflow-x: auto;
    /* Same y-recipe as .katex-display (base.css): a one-axis scroll container
       computes overflow-y to auto, so a few px of KaTeX strut overshoot would
       grow a stray vertical scrollbar next to the horizontal one. hidden stops
       that; the block padding absorbs ascenders/descenders so nothing clips.
       The inline-end padding is slack of a different kind: KaTeX's intrinsic
       max-content measurement understates its laid-out width by a couple px
       (italic correction on trailing glyphs), so the flex-sized cell would
       "overflow" by phantom pixels and summon a scrollbar with visible room
       to spare. Landing the overshoot in padding suppresses that; genuinely
       wide formulas still scroll. */
    overflow-y: hidden;
    padding-block: var(--space-1);
    padding-inline-end: var(--space-1);
    color: var(--fg);
  }
  .fx :global(.katex) {
    font-size: 1.15em;
  }
  .desc {
    flex: 1;
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: var(--leading-snug);
  }
  .desc :global(b),
  .desc :global(strong) {
    color: var(--accent-ink);
    font-weight: var(--weight-semibold);
  }
  /* nowrap keeps the formula from breaking mid-expression, but an unbroken
     formula wider than the content column would otherwise push the whole page
     into horizontal scroll on phones — contain the overflow to the span
     itself instead. inline-block is required for max-width/overflow-x to
     apply to an inline element; once overflow isn't `visible`, the box's
     reported baseline becomes its bottom margin edge (same rule the UA
     stylesheet uses for <input>/<select>), which sits below the KaTeX
     glyphs' true baseline (descender space is reserved there). Seating that
     edge on the surrounding text's baseline via `vertical-align: baseline`
     lifts the whole formula off the line; `vertical-align: bottom` seats that
     same edge on the line box's own bottom instead, matching the plain
     inline KaTeX span's position. A formula that fits needs no scrollbar and
     renders identically to before. */
  .formula-inline {
    display: inline-block;
    max-width: 100%;
    overflow-x: auto;
    vertical-align: bottom;
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .formula-row {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-2);
    }
    .fx {
      min-width: 0;
    }
  }
</style>
