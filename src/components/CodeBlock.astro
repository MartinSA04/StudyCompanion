---
import { Code } from "astro:components";
import { flexokiDark } from "../lib/shiki-flexoki.ts";

/**
 * A titled code block highlighted with Astro's built-in Shiki. Pass `code` as a
 * string plus a `lang`. A copy button is added by the layout's global
 * enhancement (which targets every <pre> in the content), so this component
 * only owns the optional filename chrome.
 *
 * The theme is passed explicitly: <Code> does NOT read `markdown.shikiConfig`
 * (that only covers fenced ``` blocks), so without this it would fall back to
 * Astro's default github-dark and clash with the fenced blocks.
 *
 * For ordinary code, authors can also just use Markdown fenced code blocks —
 * those are highlighted by Shiki and get the same copy button automatically.
 *
 * Active-line stepping (ROADMAP 3.8): `activeLine` / `activeLines` emphasise
 * 1-based line(s). Give the block an `id` and a course-owned <Simulation> can
 * drive it over time via `api.codeBlock(id)` — walking the highlight in lockstep
 * with whatever it paints on its canvas. With no active line (and no JS) it is
 * just a plain highlighted block.
 */
interface Props {
  code: string;
  lang?: string;
  title?: string;
  /** 1-based line to emphasise. */
  activeLine?: number;
  /** Several 1-based lines to emphasise (alternative to `activeLine`). */
  activeLines?: number[];
  /** Stable id so a <Simulation> can target THIS block: `api.codeBlock("id")`. */
  id?: string;
}
const { code, lang = "text", title, activeLine, activeLines, id } = Astro.props;
const initial = activeLines ?? (activeLine != null ? [activeLine] : []);
---

<figure
  class="codeblock"
  data-code-block={id}
  data-active-lines={initial.length ? initial.join(",") : undefined}
>
  {title && <figcaption class="codeblock-title">{title}</figcaption>}
  <Code code={code} lang={lang as any} theme={flexokiDark} />
  {
    /* Variable strip a driving <Stepper> fills with the frame's `key = value`
       state (empty → hidden). State belongs with the code it describes. */
    id && <div class="codeblock-vars" data-codeblock-vars aria-live="polite" />
  }
</figure>

<style>
  .codeblock {
    margin-block: var(--space-5);
  }
  .codeblock-title {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
    background: var(--card);
    border: 1px solid var(--border);
    border-bottom: 0;
    border-radius: var(--radius) var(--radius) 0 0;
    padding: var(--space-2) var(--space-4);
  }
  .codeblock-title + :global(pre) {
    border-radius: 0 0 var(--radius) var(--radius);
  }

  /* Variable strip (filled at runtime by a driving <Stepper>): a quiet footer
     seated flush under the code, showing the current `key = value` state. */
  .codeblock-vars {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
    background: var(--card);
    border: 1px solid var(--border);
    border-top: 0;
    border-radius: 0 0 var(--radius) var(--radius);
  }
  .codeblock-vars:empty {
    display: none;
  }
  /* The prose flow gives `pre` a bottom margin; drop it inside the figure so the
     var strip (and the figure edge) seat flush. The figure's own margin-block
     handles outer rhythm. */
  .codeblock :global(pre) {
    margin-bottom: 0;
  }
  .codeblock-vars :global(.cv-k) {
    color: var(--faint);
  }
  .codeblock-vars :global(.cv-v) {
    color: var(--accent);
    font-weight: var(--weight-medium);
    font-variant-numeric: tabular-nums;
  }
  /* When the strip is showing, square the code panel's bottom so it seats flush. */
  .codeblock:has(.codeblock-vars:not(:empty)) :global(pre) {
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
  }

  /* Active-line highlight. The Shiki output is unscoped, so reach its lines with
     :global(). `code` is forced block so a line's % width fills the <pre>. Only
     the active line changes layout (full-width tinted band that bleeds into the
     pre's padding); inactive lines keep Shiki's natural inline flow, so blank
     lines never collapse. */
  .codeblock :global(pre code) {
    display: block;
  }
  .codeblock :global(.line) {
    transition: background var(--dur-fast) var(--ease);
  }
  /* The Shiki block is ALWAYS dark (flexoki-dark, bg #1c1b1a), independent of the
     page light/dark theme — so the active-line marker must be tuned for a dark
     surface, NOT the theme-switched --accent-soft/--accent (which track the light
     page ground and wash out on the dark code surface). Use --accent-dark (the
     course's bright dark-mode accent, always set on <html>) + a translucent wash
     of it, so the highlight reads in both page themes. */
  .codeblock :global(.line.cb-line-active) {
    display: inline-block;
    width: 100%;
    margin-inline: calc(-1 * var(--space-4));
    padding-inline: var(--space-4);
    background: color-mix(in srgb, var(--accent-dark) 22%, transparent);
    box-shadow: inset 2px 0 0 var(--accent-dark);
  }
</style>

<script>
  import { onPage } from "../lib/pageLifecycle.ts";
  // Apply any author-set static active lines on load (a sim, if present, takes
  // over afterwards). Selecting on [data-active-lines] skips untagged blocks.
  // Re-runs after each view-transition swap; the class toggle is idempotent.
  onPage(() => {
    document
      .querySelectorAll<HTMLElement>(".codeblock[data-active-lines]")
      .forEach((fig) => {
        const want = new Set(
          (fig.dataset.activeLines ?? "")
            .split(",")
            .map(Number)
            .filter((n) => n > 0),
        );
        const lines = fig.querySelectorAll<HTMLElement>(".line");
        lines.forEach((ln, i) =>
          ln.classList.toggle("cb-line-active", want.has(i + 1)),
        );
      });
  });
</script>
