---
import type { GlossaryEntry } from "../schema.ts";
import { renderMathString } from "../lib/katex.ts";
import { slugify } from "../lib/slug.ts";
import Icon from "./Icon.astro";

/**
 * A scannable glossary of the course's terms, grouped by their optional
 * `section`. Rendered from `course.glossary`. Mirrors the <FormulaSheet> pattern:
 * server-side KaTeX in definitions (zero client cost), a free-text search box,
 * and a stable `#slug` anchor per term so inline `<Term>` links land on the row.
 */
interface Props {
  glossary: GlossaryEntry[];
  /** Localizable chrome strings; each falls back to the Norwegian default. */
  ui?: {
    searchPlaceholder?: string;
    searchLabel?: string;
    empty?: string;
    otherGroup?: string;
  };
}
const { glossary, ui } = Astro.props;
const labels = {
  searchPlaceholder: ui?.searchPlaceholder ?? "Søk i begreper …",
  searchLabel: ui?.searchLabel ?? "Søk i begreper",
  empty: ui?.empty ?? "Ingen begreper matcher søket.",
  otherGroup: ui?.otherGroup ?? "Andre begreper",
};

// Group by section, preserving first-seen order of both groups and entries.
// Entries without a `section` are collected separately: when the glossary is
// a mix of sectioned and unsectioned terms, the unsectioned ones would
// otherwise render as an orphan card with no heading wherever they first
// appear. Give them the neutral "Andre begreper" heading and place them last,
// so labelled sections never get interrupted by an unlabeled one. A glossary
// that is ENTIRELY unsectioned keeps today's single unlabeled list rather than
// manufacturing a heading for the whole thing.
const sectioned: { section: string; items: GlossaryEntry[] }[] = [];
const unsectioned: GlossaryEntry[] = [];
for (const g of glossary) {
  if (g.section) {
    let grp = sectioned.find((x) => x.section === g.section);
    if (!grp) {
      grp = { section: g.section, items: [] };
      sectioned.push(grp);
    }
    grp.items.push(g);
  } else {
    unsectioned.push(g);
  }
}
const groups: { section: string; items: GlossaryEntry[] }[] =
  sectioned.length === 0
    ? [{ section: "", items: unsectioned }]
    : unsectioned.length === 0
      ? sectioned
      : [...sectioned, { section: labels.otherGroup, items: unsectioned }];

// A lowercased haystack for client-side search: term plus the plain-text
// definition (math and inline markup stripped).
const haystack = (e: GlossaryEntry) =>
  (
    e.term +
    " " +
    e.definition.replace(/<[^>]*>/g, "").replace(/\$[^$]*\$/g, " ")
  ).toLowerCase();
---

<div class="gloss-controls">
  <div class="gloss-search sc-field">
    <Icon name="search" />
    <input
      type="search"
      class="gloss-search-input"
      placeholder={labels.searchPlaceholder}
      aria-label={labels.searchLabel}
      autocomplete="off"
    />
  </div>
</div>

<div class="glossary">
  {
    groups.map((g, i) => (
      <section class="gloss-group" data-gloss-group>
        {g.section && (
          <h2 class="gloss-group-title">
            <span class="gloss-group-num">
              {String(i + 1).padStart(2, "0")}
            </span>
            {g.section}
          </h2>
        )}
        <dl class="gloss-list">
          {g.items.map((e) => (
            <div
              class="gloss-row"
              id={slugify(e.term)}
              tabindex="-1"
              data-text={haystack(e)}
            >
              <dt class="gloss-term">
                <span set:html={renderMathString(e.term)} />
                <a
                  class="gloss-anchor"
                  href={`#${slugify(e.term)}`}
                  aria-label={`Lenke til «${e.term}»`}
                >
                  #
                </a>
              </dt>
              <dd class="gloss-def" set:html={renderMathString(e.definition)} />
            </div>
          ))}
        </dl>
      </section>
    ))
  }
  <p class="gloss-empty" hidden>{labels.empty}</p>
</div>
<!-- Polite match-count feedback for screen readers: the filter is visual-only
     otherwise (rows just get [hidden]). Mirrors the role=status pattern used by
     Quiz/Flashcards; visually hidden since the sighted result is the list itself. -->
<p class="sr-only" role="status" aria-live="polite" data-gloss-status></p>

<style>
  .gloss-controls {
    margin-bottom: var(--space-5);
  }
  /* Fill, frame-less field + focus ring come from the shared .sc-field. */
  .gloss-search-input {
    flex: 1;
    min-width: 0;
    border: 0;
    background: transparent;
    color: var(--fg);
    font-family: var(--font-body);
    font-size: var(--text-base);
  }
  .gloss-search-input:focus {
    outline: none;
  }
  .gloss-search-input::placeholder {
    color: var(--muted);
  }
  .gloss-search-input::-webkit-search-cancel-button {
    -webkit-appearance: none;
  }

  .glossary {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  .gloss-group-title {
    display: flex;
    align-items: baseline;
    gap: 10px;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--fg);
    margin-bottom: var(--space-3);
  }
  .gloss-group-num {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent-ink);
  }
  .gloss-list {
    margin: 0;
    padding: 0;
    background: var(--card);
    box-shadow: var(--shadow-sm);
    border-radius: var(--radius);
    /* Clip row backgrounds/dividers to the rounded card. */
    overflow: hidden;
  }
  .gloss-row {
    /* Term left, definition right — a definition grid that stacks on mobile.
       Padding on the row (not the list) → full-width dividers, symmetric insets. */
    display: grid;
    grid-template-columns: minmax(140px, 200px) 1fr;
    gap: var(--space-5);
    padding: var(--space-4);
    border-bottom: 1px dashed var(--border);
    scroll-margin-top: calc(var(--topbar-h) + var(--space-3));
  }
  /* Drop the divider on the last VISIBLE row (not just the DOM last child), so a
     filtered search never leaves a divider dangling under the final match. */
  .gloss-row:not([hidden]):not(:has(~ .gloss-row:not([hidden]))) {
    border-bottom: 0;
  }
  /* The search script toggles [hidden]; restate it since `display:grid` wins. */
  .gloss-row[hidden] {
    display: none;
  }
  /* Flash the row an inline `<Term>` link just jumped to (keyframe in base.css).
     The row already spans the full card width, so the tint fills it edge to edge. */
  .gloss-row:target {
    background: var(--accent-soft);
    animation: sc-target-flash var(--dur-flash) var(--ease);
  }
  @media (prefers-reduced-motion: reduce) {
    .gloss-row:target {
      animation: none;
    }
  }
  .gloss-term {
    position: relative;
    font-family: var(--font-display);
    font-weight: var(--weight-semibold);
    color: var(--fg);
    line-height: var(--leading-snug);
  }
  .gloss-anchor {
    margin-inline-start: var(--space-1);
    color: var(--muted);
    font-family: var(--font-mono);
    text-decoration: none;
    opacity: 0;
    transition:
      opacity var(--dur-fast) var(--ease),
      color var(--dur-fast) var(--ease);
  }
  .gloss-row:hover .gloss-anchor,
  .gloss-anchor:focus-visible {
    opacity: 1;
    color: var(--accent-ink);
  }
  /* Touch devices have no hover, so keep the anchor reachable there. */
  @media (hover: none) {
    .gloss-anchor {
      opacity: 1;
    }
  }
  .gloss-def {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: var(--leading-normal);
  }
  .gloss-def :global(b),
  .gloss-def :global(strong) {
    color: var(--accent-ink);
    font-weight: var(--weight-semibold);
  }
  .gloss-empty {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    padding: var(--space-3) 0;
  }

  @media (max-width: 640px) {
    .gloss-row {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>

<script>
  import { onPage } from "../lib/pageLifecycle.ts";
  import { filterList } from "../lib/filterList.ts";
  // Free-text search over term + definition. Row/group/empty toggling is the
  // shared filterList kernel; this widget adds only the sr-status announcement.
  onPage((signal) => {
    const rows = [...document.querySelectorAll<HTMLElement>(".gloss-row")];
    const groups = [
      ...document.querySelectorAll<HTMLElement>("[data-gloss-group]"),
    ];
    const searchInput = document.querySelector<HTMLInputElement>(
      ".gloss-search-input",
    );
    const empty = document.querySelector<HTMLElement>(".gloss-empty");
    const status = document.querySelector<HTMLElement>("[data-gloss-status]");
    // Reuse the localized empty-state copy for the screen-reader announcement,
    // so the two never drift apart under a course's `ui` override.
    const emptyLabel = empty?.textContent ?? "Ingen begreper matcher søket.";

    const apply = (term: string) => {
      const visibleCount = filterList({
        rows,
        groups,
        rowSelector: ".gloss-row",
        empty,
        predicate: (r) => !term || (r.dataset.text ?? "").includes(term),
      });
      // Announce the outcome only while a filter is active — an empty term is the
      // reset-to-all state, which needs no announcement (and would be noise on
      // load). Empty vs. "N treff" mirrors the visible .gloss-empty / list.
      if (status) {
        status.textContent = !term
          ? ""
          : visibleCount === 0
            ? emptyLabel
            : `${visibleCount} treff`;
      }
    };

    searchInput?.addEventListener(
      "input",
      () => apply(searchInput.value.trim().toLowerCase()),
      { signal },
    );
  });
</script>
