---
import type { Course } from "../schema.ts";
import {
  daysUntil,
  formatExamCountdown,
  EXAM_PAST_LABEL,
} from "../lib/countdown.ts";
import { formatDate, formatDuration } from "../lib/dates.ts";
import Icon from "./Icon.astro";

/**
 * THE exam-info surface — one card, both flater. A centered letterpress
 * announcement: kicker (the card's heading on the overview; omitted on the
 * Eksamen page, whose h1 already says it), the date as the display line with
 * the countdown pill beneath, a short centered rule, then one fact line
 * (Tid · Varighet · Form) behind mono micro-labels, permitted aids as fine
 * print, and the quiet authority link.
 *
 * Pure presentation of `course.exam`: renders only the fields that are
 * present, and nothing at all if `exam` carries none of them. The countdown
 * pill SSRs a build-time snapshot and the script below re-derives it against
 * the viewer's clock, so a site built a week early still says "i dag" on exam
 * morning.
 */
interface Props {
  exam: NonNullable<Course["exam"]>;
  language?: string;
  /**
   * Kicker text rendered as the card's own h2 heading. The overview passes
   * `course.ui.examsLabel`; the Eksamen page omits it (its h1 covers it).
   */
  kicker?: string;
  /**
   * Text for the authority link. Defaults to the framework's Norwegian
   * string; callers pass `course.ui.examAuthorityNote` so per-course
   * overrides reach both surfaces.
   */
  authorityNote?: string;
}
const {
  exam,
  language = "nb",
  kicker,
  authorityNote = "Offisiell eksamensinfo",
} = Astro.props;

const examDate = exam.date ? formatDate(exam.date, language, "full") : null;
const daysToExam = exam.date ? daysUntil(exam.date) : null;

// Norwegian chrome countdown; a past exam reads as a muted "avholdt" note.
const countdown =
  daysToExam == null
    ? null
    : daysToExam < 0
      ? EXAM_PAST_LABEL
      : formatExamCountdown(daysToExam);

const durationStr = formatDuration(exam.durationMinutes);

const facts = [
  // Start time is a VERBATIM string (schema keeps it off Date to avoid the
  // UTC-midnight print bug); it renders as-is on the fact line.
  exam.time && { label: "Tid", value: exam.time },
  durationStr && { label: "Varighet", value: durationStr },
  exam.format && { label: "Form", value: exam.format },
].filter(Boolean) as { label: string; value: string }[];

const hasContent = Boolean(examDate) || facts.length > 0 || Boolean(exam.aids);
---

{
  hasContent && (
    <section class="card exam-card">
      {kicker && <h2 class="exam-kicker sc-kicker">{kicker}</h2>}
      {examDate && (
        <p class="exam-date-line">
          <time
            class="exam-date"
            datetime={exam.date!.toISOString().slice(0, 10)}
          >
            {examDate}
          </time>
        </p>
      )}
      {countdown && (
        <p class="exam-pill-line">
          <span
            class="sc-countdown"
            data-past={daysToExam! < 0}
            data-exam-countdown={exam.date!.toISOString()}
          >
            {countdown}
          </span>
        </p>
      )}
      {examDate && (facts.length > 0 || exam.aids) && (
        <div class="exam-rule" aria-hidden="true" />
      )}
      {facts.length > 0 && (
        <p class="exam-facts">
          {facts.map((f, i) => (
            <>
              {i > 0 && <span class="exam-sep">·</span>}
              <span class="exam-lbl">{f.label}</span>
              {f.value}
            </>
          ))}
        </p>
      )}
      {exam.aids && (
        <p class="exam-aids">
          <span class="sr-only">Hjelpemidler: </span>
          {exam.aids}
        </p>
      )}
      <p class="exam-authority">
        <a href={exam.authorityUrl} target="_blank" rel="noopener noreferrer">
          {authorityNote}
          <Icon name="external" size={14} />
        </a>
      </p>
    </section>
  )
}

<style>
  /* The announcement is a deliberately narrower, centered sheet — the one
     ceremonial flate on an otherwise left-aligned page. */
  .exam-card {
    max-width: 34rem;
    margin-inline: auto;
    text-align: center;
  }
  /* The kicker IS the card's heading (h2 for the outline); undo the generic
     .card h2 flex/dot recipe from shell.css. */
  .exam-kicker {
    display: block;
    margin: 0 0 10px;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--accent-ink);
  }
  .exam-date-line {
    margin: 0;
    color: var(--fg);
  }
  .exam-date {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--weight-medium);
    line-height: var(--leading-tight);
    text-wrap: balance;
  }
  .exam-pill-line {
    margin: 10px 0 0;
  }
  /* Short centered hairline between the "when" and the reference facts. */
  .exam-rule {
    width: 4rem;
    height: 1px;
    background: var(--border-strong);
    margin: var(--space-4) auto;
  }
  .exam-facts {
    margin: 0 0 6px;
    color: var(--fg);
    font-variant-numeric: tabular-nums;
  }
  .exam-lbl {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking);
    color: var(--muted);
    margin-right: 6px;
  }
  .exam-sep {
    color: var(--faint);
    margin: 0 8px;
  }
  /* Permitted aids as fine print — no VISIBLE label (an sr-only "Hjelpemidler"
     prefix carries the semantic the old labelled surfaces had). */
  .exam-aids {
    margin: 0 auto;
    font-size: var(--text-sm);
    color: var(--muted);
    max-width: 30rem;
  }
  .exam-authority {
    margin: var(--space-4) 0 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }
  .exam-authority a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--accent-ink);
    text-decoration: none;
  }
  .exam-authority a:hover {
    text-decoration: underline;
  }
</style>

<script>
  import { onPage } from "../lib/pageLifecycle.ts";
  import { refreshExamCountdowns } from "../lib/examCountdown.ts";
  // The pill's phrase (and its data-past muted state) is a build-time
  // snapshot; recompute per (re)load against the viewer's clock so the pill
  // flips to "i dag"/"avholdt" on the right morning (lib/examCountdown.ts).
  onPage(() => refreshExamCountdowns());
</script>
