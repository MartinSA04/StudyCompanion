---
/**
 * Single-answer multiple-choice question (vanilla island). `answer` is the
 * 0-based index of the correct option. Clicking an option reveals whether it
 * was right and shows the optional explanation. This is a study aid, not a
 * graded test, so the answer being present in the DOM is fine.
 */
interface Props {
  question: string;
  options: string[];
  answer: number;
  explanation?: string;
}
const { question, options, answer, explanation } = Astro.props;
import { renderMathString } from "../lib/katex.ts";
import Icon from "./Icon.astro";
---

<form class="quiz sc-panel" data-answer={answer}>
  <fieldset>
    <legend class="quiz-q" set:html={renderMathString(question)} />
    <ul class="quiz-options">
      {
        options.map((opt, i) => (
          <li>
            <button type="button" class="quiz-option" data-index={i}>
              <span class="quiz-mark" aria-hidden="true">
                <Icon name="check" size={13} class="i-correct" />
                <Icon name="x" size={13} class="i-wrong" />
              </span>
              <span set:html={renderMathString(opt)} />
            </button>
          </li>
        ))
      }
    </ul>
  </fieldset>
  <p
    class="quiz-feedback"
    role="status"
    aria-live="polite"
    tabindex="-1"
    hidden
  >
  </p>
  {
    explanation && (
      <p class="quiz-explain" set:html={renderMathString(explanation)} hidden />
    )
  }
</form>

<style>
  /* Float (fill + shadow + radius) comes from the shared .sc-panel; fill is now
     --bg-elevated (was --card — identical colour, one token for float surfaces). */
  .quiz {
    margin-block: var(--space-5);
    padding: var(--space-4);
  }
  .quiz fieldset {
    border: 0;
    padding: 0;
    margin: 0;
  }
  .quiz-q {
    font-weight: var(--weight-semibold);
    padding: 0;
    margin-bottom: var(--space-3);
  }
  .quiz-options {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  /* Borderless filled rows: each option recesses to --card-nested inside the
     --bg-elevated panel (like every other inset), so the resting affordance is a
     fill — the SAME modality as the graded --tip-bg / --wrong-bg tints, making
     rest→graded one coherent fill change. The radio mark keeps the only border
     (the sanctioned --border-strong form glyph — see the Structural-Border
     Rule), so the rows still read as selectable choices. */
  .quiz-option {
    width: 100%;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-align: left;
    padding: var(--space-3);
    border: 0;
    border-radius: var(--radius-sm);
    background: var(--card-nested);
    transition:
      background-color var(--dur-fast) var(--ease),
      color var(--dur-fast) var(--ease);
  }
  /* Accent wash carries the interactive cue the border used to (blended into the
     resting fill so it stays visible in both themes — --card-hover == the resting
     --card-nested, so a plain fill hover would be invisible). */
  .quiz-option:hover:not([disabled]) {
    background: color-mix(in srgb, var(--accent) 14%, var(--card-nested));
  }
  /* Tactile press, kept local (not the shared .sc-press): a graded option is
     [disabled], and the :not([disabled]) guard must suppress the press there. */
  .quiz-option:active:not([disabled]) {
    transform: translateY(1px);
  }
  .quiz-mark {
    flex: none;
    display: grid;
    place-items: center;
    width: 1.3em;
    height: 1.3em;
    border: 1px solid var(--border-strong);
    border-radius: 50%;
  }
  /* Both result glyphs are present but hidden until the option is graded, so
     correct/wrong reads from the shape (check / cross), not colour alone. */
  .quiz-mark :global(.i-correct),
  .quiz-mark :global(.i-wrong) {
    display: none;
  }
  .quiz-option[data-state="correct"] {
    background: var(--tip-bg);
    color: var(--tip);
  }
  .quiz-option[data-state="correct"] .quiz-mark {
    background: var(--tip);
    border-color: var(--tip);
  }
  .quiz-option[data-state="correct"] .quiz-mark :global(.i-correct) {
    display: block;
    color: var(--on-strong);
  }
  .quiz-option[data-state="wrong"] {
    background: var(--wrong-bg);
    color: var(--wrong);
  }
  .quiz-option[data-state="wrong"] .quiz-mark {
    border-color: var(--wrong);
  }
  .quiz-option[data-state="wrong"] .quiz-mark :global(.i-wrong) {
    display: block;
    color: var(--wrong);
  }
  .quiz-feedback {
    margin-top: var(--space-3);
    font-weight: var(--weight-medium);
    font-size: var(--text-sm);
  }
  .quiz-feedback[data-result="correct"] {
    color: var(--tip);
  }
  .quiz-feedback[data-result="wrong"] {
    color: var(--wrong);
  }
  .quiz-explain {
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: var(--leading-snug);
    padding: var(--space-3) var(--space-4);
    background: var(--accent-soft);
    border-radius: var(--radius);
  }
</style>

<script>
  import { onPage } from "../lib/pageLifecycle.ts";
  onPage((signal) => {
    document.querySelectorAll<HTMLFormElement>(".quiz").forEach((quiz) => {
      const answer = Number(quiz.dataset.answer);
      const options = [
        ...quiz.querySelectorAll<HTMLButtonElement>(".quiz-option"),
      ];
      const feedback = quiz.querySelector<HTMLElement>(".quiz-feedback")!;
      const explain = quiz.querySelector<HTMLElement>(".quiz-explain");
      let done = false;

      // Plain-text of an option's label, for the announced feedback. KaTeX
      // output carries both MathML (what a screen reader gets) and an
      // aria-hidden visual tree plus the raw LaTeX <annotation>; keep only the
      // MathML text so math reads as symbols, not doubled markup.
      const optionText = (btn: HTMLButtonElement): string => {
        const label = btn.querySelector<HTMLElement>(
          ":scope > span:not(.quiz-mark)",
        );
        if (!label) return "";
        const clone = label.cloneNode(true) as HTMLElement;
        clone
          .querySelectorAll(".katex-html, annotation, .sr-only")
          .forEach((n) => n.remove());
        return clone.textContent?.replace(/\s+/g, " ").trim() ?? "";
      };

      // Visually-hidden state suffix, so a graded option's accessible name says
      // what the colour + icon show ("…, riktig svar" / "…, ditt svar").
      const addSrState = (btn: HTMLButtonElement, text: string) => {
        const s = document.createElement("span");
        s.className = "sr-only quiz-sr-state";
        s.textContent = `, ${text}`;
        btn.appendChild(s);
      };

      // ↑/↓ moves focus between options (arrow-key group navigation)
      options.forEach((btn, i) => {
        btn.addEventListener(
          "keydown",
          (e) => {
            if (e.key === "ArrowDown") {
              e.preventDefault();
              options[(i + 1) % options.length]?.focus();
            } else if (e.key === "ArrowUp") {
              e.preventDefault();
              options[(i - 1 + options.length) % options.length]?.focus();
            }
          },
          { signal },
        );
      });

      options.forEach((btn) => {
        btn.addEventListener(
          "click",
          () => {
            if (done) return;
            done = true;
            const chosen = Number(btn.dataset.index);
            const correct = chosen === answer;

            // Disabling every option (including a focused one) would blur focus
            // to <body>. If an option had focus, hand it to the feedback line
            // instead so keyboard users keep a landing spot; pointer users never
            // had widget focus, so they're untouched.
            const hadFocus = options.includes(
              document.activeElement as HTMLButtonElement,
            );

            options.forEach((b, i) => {
              b.disabled = true;
              if (i === answer) {
                b.dataset.state = "correct";
                addSrState(b, "riktig svar");
              } else if (i === chosen) {
                b.dataset.state = "wrong";
                addSrState(b, "ditt svar");
              }
            });

            feedback.hidden = false;
            feedback.dataset.result = correct ? "correct" : "wrong";
            if (correct) {
              feedback.textContent = "Riktig!";
            } else {
              // Two audiences, one clean sentence each: sighted readers get
              // "Se riktig svar." (the green row above shows the answer, so
              // repeating it visibly is redundant); the live region announces
              // the answer by name instead, since the row's reveal is colour +
              // an aria-hidden icon — invisible in an announcement. aria-hidden
              // strips the pointer sentence from the announced text; sr-only
              // text is announced but not shown.
              feedback.textContent = "Ikke helt. ";
              const answerText = optionText(options[answer]);
              const pointer = document.createElement("span");
              pointer.textContent = "Se riktig svar.";
              if (answerText) {
                pointer.setAttribute("aria-hidden", "true");
                const sr = document.createElement("span");
                sr.className = "sr-only";
                sr.textContent = `Riktig svar: ${answerText}.`;
                feedback.append(pointer, sr);
              } else {
                feedback.append(pointer);
              }
            }
            if (explain) explain.hidden = false;
            if (hadFocus) feedback.focus({ preventScroll: true });
          },
          { signal },
        );
      });
    });
  });
</script>
