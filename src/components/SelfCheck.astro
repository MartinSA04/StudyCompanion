---
/**
 * A "check yourself" prompt with the answer hidden behind a native <details>
 * reveal. Works with no JS. Answer is slotted MDX (may contain math, lists…).
 */
interface Props {
  question: string;
  revealLabel?: string;
}
const { question, revealLabel = "Vis svar" } = Astro.props;
// State-matching summary ("Vis svar" ⇄ "Skjul svar"); non-"Vis …" labels stay put.
const hideLabel = revealLabel.startsWith("Vis ")
  ? `Skjul ${revealLabel.slice(4)}`
  : revealLabel;
import { renderMathString } from "../lib/katex.ts";
import Icon from "./Icon.astro";
---

<div class="selfcheck sc-panel">
  <p class="selfcheck-q">
    <span class="selfcheck-tag" aria-hidden="true">
      <Icon name="help-circle" size={20} />
    </span>
    <span set:html={renderMathString(question)} />
  </p>
  <details class="selfcheck-a">
    <summary class="sc-summary" data-pagefind-ignore>
      <span class="selfcheck-chev sc-chev" aria-hidden="true">
        <Icon name="chevron-right" size={13} />
      </span>
      <span class="sum-closed">{revealLabel}</span>
      <span class="sum-open">{hideLabel}</span>
    </summary>
    <div class="selfcheck-body"><slot /></div>
  </details>
</div>

<style>
  /* Float (fill + shadow + radius) comes from the shared .sc-panel; fill is now
     --bg-elevated (was --card — identical colour). */
  .selfcheck {
    margin-block: var(--space-5);
    padding: var(--space-4);
  }
  .selfcheck-q {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-weight: var(--weight-medium);
    margin-bottom: var(--space-3);
  }
  /* Stroked help-circle marker, centred against the first line of the question —
     same line-icon vocabulary as the other content blocks. */
  .selfcheck-tag {
    flex: none;
    display: inline-flex;
    align-items: center;
    height: 1lh;
    color: var(--accent-ink);
  }
  /* Compact inline reveal. The shared .sc-summary carries the type, the faint-ink
     hover and the marker-hide; only the compact width + a little padding for the
     wash are local — this reveal sits in the panel body, not as a full-width
     header, and .selfcheck-body already draws the [open] divider. */
  .selfcheck-a > summary {
    width: fit-content;
    padding: 0.15em 0.45em;
    margin-inline-start: -0.45em;
    border-radius: var(--radius-xs);
  }
  .selfcheck-a[open] > summary {
    border-bottom: 0;
  }
  .selfcheck-a[open] > summary .sum-closed {
    display: none;
  }
  .selfcheck-a:not([open]) > summary .sum-open {
    display: none;
  }
  /* The chevron's display/transition/rotate come from the shared .sc-chev
     primitive; the summary itself stays local (an inline underline reveal). */
  .selfcheck-body {
    margin-top: var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid var(--border);
  }
  .selfcheck-body :global(> :last-child) {
    margin-bottom: 0;
  }
</style>
