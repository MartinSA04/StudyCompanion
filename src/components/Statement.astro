---
import Icon from "./Icon.astro";
import { renderMathString } from "../lib/katex.ts";
import { slugify } from "../lib/slug.ts";

/**
 * A named, boxed result — a law, theorem, definition or principle ("Snells lov",
 * "Huygens' prinsipp"). Gives recurring named results a consistent treatment and
 * a STABLE `id` anchor for deep-linking (and for the future <FormulaRef>/glossary
 * cross-refs, ROADMAP 2.3/2.4). The `id` is derived from `name` (slugified) unless
 * given explicitly. `name` may contain `$inline$` math; the body is slotted MDX.
 */
interface Props {
  kind?: "law" | "theorem" | "definition" | "principle";
  name: string;
  /** Anchor id. Defaults to a slug of `name`. */
  id?: string;
}
const { kind = "definition", name, id } = Astro.props;

const LABELS = {
  law: "Lov",
  theorem: "Teorem",
  definition: "Definisjon",
  principle: "Prinsipp",
} as const;

const anchor = id ?? slugify(name);
---

<aside
  class={`statement statement-${kind}`}
  id={anchor}
  aria-label={LABELS[kind]}
>
  <p class="statement-head">
    <span class="statement-badge">
      <Icon name="bookmark" size={15} />
      {LABELS[kind]}
    </span>
    <span class="statement-name" set:html={renderMathString(name)} />
    <a
      class="statement-anchor"
      href={`#${anchor}`}
      aria-label="Lenke til dette resultatet">#</a
    >
  </p>
  <div class="statement-body"><slot /></div>
</aside>

<style>
  .statement {
    margin-block: var(--space-5);
    padding: var(--space-4);
    background: var(--accent-soft);
    border-radius: var(--radius);
    scroll-margin-top: calc(var(--topbar-h) + var(--space-3));
  }
  /* Flash on deep-link arrival, same as <FormulaRef>/<Term> row targets. It
     settles back to the statement's own accent-soft ground. */
  .statement:target {
    animation: sc-target-flash 1.8s var(--ease);
  }
  @media (prefers-reduced-motion: reduce) {
    .statement:target {
      animation: none;
    }
  }
  .statement-head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
    margin-bottom: var(--space-2);
  }
  .statement-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    flex: none;
    align-self: center;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking);
    font-weight: var(--weight-semibold);
    color: var(--accent);
  }
  .statement-name {
    font-family: var(--font-display);
    font-weight: var(--weight-semibold);
    font-size: var(--text-md);
    color: var(--fg);
  }
  .statement-anchor {
    margin-inline-start: auto;
    align-self: center;
    padding-inline: var(--space-1);
    color: var(--faint);
    font-family: var(--font-mono);
    text-decoration: none;
    opacity: 0.5;
    transition:
      opacity var(--dur-fast) var(--ease),
      color var(--dur-fast) var(--ease);
  }
  .statement:hover .statement-anchor,
  .statement-anchor:focus-visible {
    opacity: 1;
    color: var(--accent);
  }
  .statement-body :global(> :last-child) {
    margin-bottom: 0;
  }
</style>
