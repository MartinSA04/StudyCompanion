---
import Icon from "./Icon.astro";

/**
 * One rung of a <Hints> ladder. With no props it auto-labels "Hint N" from the
 * parent counter; `solution` makes it the green "Løsning" closer (not numbered);
 * `label` sets an explicit summary instead. Body is slotted MDX. No JS — native
 * `<details>`.
 */
interface Props {
  /** Final rung — labelled "Løsning", tinted, and left out of the numbering. */
  solution?: boolean;
  /** Explicit summary label, overriding the auto "Hint N". */
  label?: string;
  open?: boolean;
}
const { solution = false, label, open = false } = Astro.props;
const auto = !solution && !label;
---

<details
  class:list={[
    "hint",
    "sc-panel",
    { "hint-num": auto, "hint-solution": solution },
  ]}
  open={open}
>
  <summary class="sc-summary" data-pagefind-ignore>
    <span class="hint-chev sc-chev" aria-hidden="true"
      ><Icon name="chevron-right" size={13} /></span
    >
    {
      auto ? (
        <span class="hint-auto">Hint</span>
      ) : (
        <span>{solution ? "Løsning" : label}</span>
      )
    }
  </summary>
  <div class="hint-body"><slot /></div>
</details>

<style>
  /* Float (fill + shadow) comes from the shared .sc-panel; this small reveal
     keeps the tighter --radius-sm. No overflow:hidden — it clipped descendant
     focus outlines; the summary rounds itself instead. */
  .hint {
    border-radius: var(--radius-sm);
  }
  .hint-num {
    counter-increment: hint;
  }
  /* Summary type, hover, marker-hide, [open] divider and chevron come from the
     shared .sc-summary / .sc-chev primitives; only the padding is local.
     Concrete token, not `inherit`: a <summary> is slotted into the <details>
     UA shadow tree, so `inherit` resolves to the slot's 0, not the panel's
     radius. */
  .hint > summary {
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
  }
  .hint[open] > summary {
    border-end-start-radius: 0;
    border-end-end-radius: 0;
  }
  /* The word "Hint" is real DOM text (the accessible name); the number is
     decorative and stays in a counter so re-ordering hints never needs an
     authored index. */
  .hint-auto::after {
    content: " " counter(hint);
  }
  .hint-body {
    padding: var(--space-3);
  }
  .hint-body > :global(:last-child) {
    margin-bottom: 0;
  }
  /* The solution rung reads like an <Answer>: green and tinted. */
  .hint-solution > summary {
    color: var(--tip);
  }
  .hint-solution[open] {
    background: var(--answer-bg);
  }
  .hint-solution[open] > summary {
    border-bottom-color: var(--border);
  }
</style>
