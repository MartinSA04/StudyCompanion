---
import katex from "katex";
import type { FormulaEntry } from "../schema.ts";
import { renderMathString } from "../lib/katex.ts";
import Icon from "./Icon.astro";

/**
 * A scannable reference sheet of the course's formulas, grouped by their
 * optional `section`. Rendered from `course.formulas`. Server-side KaTeX, so
 * zero client cost. A search box filters by formula/description text and the
 * chips narrow to what's on the exam sheet vs. must-memorize; each row has a
 * copy-LaTeX button (enhanced client-side).
 */
interface Props {
  formulas: FormulaEntry[];
  /**
   * Whether the exam hands out a formula sheet. When `false`, the on-sheet /
   * must-memorize distinction is meaningless (nothing is on a sheet), so the
   * filter chips and per-row badges are dropped and a notice is shown instead.
   */
  examFormulaSheet?: boolean;
  /** Notice text shown when `examFormulaSheet` is false. */
  noFormulaSheetNote?: string;
}
const {
  formulas,
  examFormulaSheet = true,
  noFormulaSheetNote = "",
} = Astro.props;

// Group by section, preserving first-seen order of both groups and entries.
const groups: { section: string; items: FormulaEntry[] }[] = [];
for (const f of formulas) {
  const key = f.section ?? "";
  let g = groups.find((x) => x.section === key);
  if (!g) {
    g = { section: key, items: [] };
    groups.push(g);
  }
  g.items.push(f);
}

// A \displaystyle prefix in *inline* mode keeps fractions full-size and lets
// \left(…\right)/matrix delimiters stretch to their content, while emitting a
// plain `.katex` span — not `.katex-display`, which carries the base
// stylesheet's overflow-x rule and would add a stray horizontal scrollbar.
const html = (tex: string) =>
  katex.renderToString(`\\displaystyle ${tex}`, {
    displayMode: false,
    throwOnError: false,
  });

// A lowercased haystack for client-side search: raw TeX plus the plain-text
// description (latex commands and markup stripped).
const haystack = (f: FormulaEntry) =>
  (
    f.tex +
    " " +
    (f.label ?? "")
      .replace(/<[^>]*>/g, "")
      .replace(/\$/g, "")
      .replace(/\\[a-zA-Z]+/g, " ")
  ).toLowerCase();

// The on-sheet / must-memorize distinction only makes sense when the exam
// actually provides a sheet. Closed-book courses (examFormulaSheet=false) get a
// plain reference list — no chips, no per-row "off the sheet" badges.
const hasMemorize = examFormulaSheet && formulas.some((f) => f.memorize);
---

{
  !examFormulaSheet && noFormulaSheetNote && (
    <p class="fs-notice" role="note">
      <Icon name="info" size={24} />
      <span>{noFormulaSheetNote}</span>
    </p>
  )
}

<div class="fs-controls">
  <div class="fs-search">
    <Icon name="search" />
    <input
      type="search"
      class="fs-search-input"
      placeholder="Søk i formler og symboler …"
      aria-label="Søk i formler"
      autocomplete="off"
    />
  </div>
  {
    hasMemorize && (
      <div class="fs-filter" role="group" aria-label="Filtrer formler">
        <button
          type="button"
          class="fs-chip"
          data-filter="all"
          aria-pressed="true"
        >
          Alle
        </button>
        <button
          type="button"
          class="fs-chip"
          data-filter="sheet"
          aria-pressed="false"
        >
          På formelarket
        </button>
        <button
          type="button"
          class="fs-chip"
          data-filter="memorize"
          aria-pressed="false"
        >
          <Icon name="star" size={13} />
          Må pugges
        </button>
      </div>
    )
  }
</div>

<div class="formula-sheet">
  {
    groups.map((g, i) => (
      <section class="fs-group" data-fs-group>
        {g.section && (
          <h2 class="fs-group-title">
            <span class="fs-group-num">{String(i + 1).padStart(2, "0")}</span>
            {g.section}
          </h2>
        )}
        <ul class="fs-list">
          {g.items.map((f) => (
            <li
              class="fs-row"
              id={f.id}
              data-onsheet={String(f.onSheet)}
              data-memorize={String(examFormulaSheet && f.memorize)}
              data-text={haystack(f)}
            >
              <span class="fs-render" set:html={html(f.tex)} />
              {f.label && (
                <span class="fs-label" set:html={renderMathString(f.label)} />
              )}
              {examFormulaSheet && f.memorize && (
                <span
                  class="fs-badge"
                  title="Står ikke på formelarket – må pugges"
                >
                  <Icon name="star" size={12} />
                  ikke på formelarket
                </span>
              )}
              <button
                type="button"
                class="fs-copy"
                data-tex={f.tex}
                aria-label="Kopier LaTeX"
                title="Kopier LaTeX"
              >
                <Icon name="copy" class="i-copy" />
                <Icon name="check" class="i-check" />
              </button>
            </li>
          ))}
        </ul>
      </section>
    ))
  }
  <p class="fs-empty" hidden>Ingen formler matcher søket.</p>
</div>

<style>
  /* Notice shown for closed-book courses: no formula sheet at the exam. A
     prominent banner — this is the single most important fact on the page. */
  .fs-notice {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    margin: 0 0 var(--space-6);
    padding: var(--space-4) var(--space-5);
    background: var(--accent-soft);
    border: 1px solid var(--accent);
    border-radius: var(--radius);
    color: var(--fg);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
  }
  .fs-notice :global(svg) {
    flex: none;
    margin-top: 1px;
    color: var(--accent);
  }

  /* Controls: a search field plus the on-sheet / must-memorize chips. */
  .fs-controls {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    margin-bottom: var(--space-5);
  }
  .fs-search {
    display: flex;
    align-items: center;
    gap: 8px;
    flex: 1;
    min-width: 220px;
    background: var(--card);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    padding: 9px 14px;
    color: var(--faint);
    transition: border-color var(--dur-fast) var(--ease);
  }
  .fs-search:focus-within {
    border-color: var(--accent);
    color: var(--accent);
  }
  .fs-search-input {
    flex: 1;
    min-width: 0;
    border: 0;
    background: transparent;
    color: var(--fg);
    font-family: var(--font-body);
    font-size: var(--text-base);
  }
  .fs-search-input:focus {
    outline: none;
  }
  .fs-search-input::placeholder {
    color: var(--faint);
  }
  .fs-search-input::-webkit-search-cancel-button {
    -webkit-appearance: none;
  }

  .fs-filter {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .fs-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    padding: 0.4em 0.95em;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-pill);
    background: var(--card);
    color: var(--muted);
    transition:
      color var(--dur-fast) var(--ease),
      border-color var(--dur-fast) var(--ease),
      background var(--dur-fast) var(--ease);
  }
  .fs-chip:hover {
    color: var(--fg);
    border-color: var(--accent);
  }
  .fs-chip[aria-pressed="true"] {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--on-strong);
    font-weight: var(--weight-medium);
  }

  /* Groups: each section is a panel with dashed-divided rows — inline formula
     left, description right — mirroring the original guide's formula sheet. */
  .formula-sheet {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  .fs-group-title {
    display: flex;
    align-items: baseline;
    gap: 10px;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--fg);
    margin-bottom: var(--space-3);
  }
  .fs-group-num {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
  }
  .fs-list {
    list-style: none;
    margin: 0;
    padding: 0 var(--space-5);
    background: var(--card);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
  }
  .fs-row {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--space-5);
    padding: var(--space-3) 0;
    border-bottom: 1px dashed var(--border);
    scroll-margin-top: calc(var(--topbar-h) + var(--space-3));
  }
  .fs-row:last-child {
    border-bottom: 0;
  }
  /* Flash the row a `<FormulaRef>` deep-link just jumped to (keyframe in base.css).
     Bleed out through the list's inline padding so the highlight spans the full
     row width instead of floating inset. */
  .fs-row:target {
    margin-inline: calc(-1 * var(--space-5));
    padding-inline: var(--space-5);
    background: var(--accent-soft);
    animation: sc-target-flash 1.8s var(--ease);
  }
  @media (prefers-reduced-motion: reduce) {
    .fs-row:target {
      animation: none;
    }
  }
  /* The author content toggles these via the script below; the UA `[hidden]`
     rule loses to `.fs-row { display:flex }`, so restate it. */
  .fs-row[hidden] {
    display: none;
  }
  .fs-render {
    flex: none;
    min-width: 150px;
    color: var(--fg);
  }
  .fs-render :global(.katex) {
    font-size: 1.15em;
  }
  .fs-label {
    flex: 1;
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: var(--leading-snug);
  }
  .fs-label :global(b),
  .fs-label :global(strong) {
    color: var(--accent);
    font-weight: var(--weight-semibold);
  }
  .fs-badge {
    flex: none;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.02em;
    color: var(--warning);
    border: 1px solid var(--warning);
    border-radius: var(--radius-sm);
    padding: 0.15em 0.55em;
    white-space: nowrap;
  }
  .fs-copy {
    flex: none;
    margin-left: auto;
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg-elevated);
    color: var(--muted);
    transition:
      color var(--dur-fast) var(--ease),
      border-color var(--dur-fast) var(--ease);
  }
  .fs-copy:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  /* Icon swap: copy by default, check once copied. The icons render from the
     Icon component (a different scope), so :global() is needed to reach them. */
  .fs-copy :global(.i-check) {
    display: none;
  }
  .fs-copy[data-copied="true"] {
    color: var(--tip);
    border-color: var(--tip);
  }
  .fs-copy[data-copied="true"] :global(.i-copy) {
    display: none;
  }
  .fs-copy[data-copied="true"] :global(.i-check) {
    display: block;
  }
  .fs-empty {
    color: var(--faint);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    padding: var(--space-3) 0;
  }

  @media (max-width: 640px) {
    .fs-row {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-2);
      padding-right: 40px;
    }
    .fs-render {
      min-width: 0;
    }
    .fs-copy {
      position: absolute;
      top: var(--space-3);
      right: 0;
    }
  }
</style>

<script>
  import { onPage } from "../lib/pageLifecycle.ts";
  onPage((signal) => {
    // Copy LaTeX — toggles the data-copied state; the icon swap is pure CSS.
    document.querySelectorAll<HTMLButtonElement>(".fs-copy").forEach((btn) => {
      let timer: ReturnType<typeof setTimeout>;
      btn.addEventListener(
        "click",
        async () => {
          try {
            await navigator.clipboard.writeText(btn.dataset.tex ?? "");
            btn.dataset.copied = "true";
            clearTimeout(timer);
            timer = setTimeout(() => (btn.dataset.copied = "false"), 1200);
          } catch {
            /* clipboard unavailable */
          }
        },
        { signal },
      );
    });

    // Combined filter: free-text search AND the active chip (all / on the exam
    // sheet / must-memorize). Empty groups and the whole sheet collapse cleanly.
    const rows = [...document.querySelectorAll<HTMLElement>(".fs-row")];
    const groups = [
      ...document.querySelectorAll<HTMLElement>("[data-fs-group]"),
    ];
    const chips = [...document.querySelectorAll<HTMLButtonElement>(".fs-chip")];
    const searchInput =
      document.querySelector<HTMLInputElement>(".fs-search-input");
    const empty = document.querySelector<HTMLElement>(".fs-empty");

    let mode = "all";
    let term = "";

    const apply = () => {
      let anyVisible = false;
      rows.forEach((r) => {
        const matchMode =
          mode === "all" ||
          (mode === "sheet" && r.dataset.onsheet === "true") ||
          (mode === "memorize" && r.dataset.memorize === "true");
        const matchTerm = !term || (r.dataset.text ?? "").includes(term);
        const show = matchMode && matchTerm;
        r.hidden = !show;
        if (show) anyVisible = true;
      });
      groups.forEach((g) => {
        g.hidden = ![...g.querySelectorAll<HTMLElement>(".fs-row")].some(
          (r) => !r.hidden,
        );
      });
      if (empty) empty.hidden = anyVisible;
    };

    chips.forEach((chip) => {
      chip.addEventListener(
        "click",
        () => {
          mode = chip.dataset.filter ?? "all";
          chips.forEach((c) =>
            c.setAttribute("aria-pressed", c === chip ? "true" : "false"),
          );
          apply();
        },
        { signal },
      );
    });

    searchInput?.addEventListener(
      "input",
      () => {
        term = searchInput.value.trim().toLowerCase();
        apply();
      },
      { signal },
    );
  });
</script>
