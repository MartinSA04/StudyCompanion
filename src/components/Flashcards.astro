---
import type { Flashcards } from "../schema.ts";
import { renderMathString } from "../lib/katex.ts";
import { fcId } from "../lib/fcId.ts";
import Icon from "./Icon.astro";

/**
 * Flashcard deck (vanilla island) with a flip animation and a binary rating:
 * "Kan" marks a card known (it surfaces later), "Øv" marks it not known (it
 * surfaces sooner). Ratings persist in localStorage under
 * `sc:flashcards:<code>` as a versioned envelope keyed by each card's content
 * id (fcId of the front text), so deck edits can't shift ratings onto the
 * wrong cards; load() migrates legacy positional records (and their 0/1/2
 * mastery scheme) once. Card text may contain $inline$ / $$display$$ math,
 * rendered to KaTeX at build time.
 */
interface Props {
  cards: Flashcards["cards"];
  code: string;
  ui?: { known?: string; review?: string; flip?: string; reset?: string };
}
const { cards, code, ui } = Astro.props;
const labels = {
  known: ui?.known ?? "Kan",
  review: ui?.review ?? "Øv",
  flip: ui?.flip ?? "Snu",
  reset: ui?.reset ?? "Nullstill",
};
const storageKey = `sc:flashcards:${code}`;

const rendered = cards.map((c) => ({
  front: renderMathString(c.front),
  back: renderMathString(c.back),
  section: c.section ?? "",
  id: fcId(c.front),
}));
const sections = [...new Set(rendered.map((c) => c.section).filter(Boolean))];
const hasSections = sections.length > 0;
---

<div
  class="flashcards"
  data-storage-key={storageKey}
  data-total={rendered.length}
>
  <div class="fc-head">
    {
      /* role="status": rating updates this line ("2 / 24 kan"), which is the
        visible — and announced — acknowledgment that a Kan/Øv press landed. */
    }
    <p
      class="fc-progress"
      role="status"
      title="Lagres lokalt i denne nettleseren"
    >
      <strong data-fc-known>0</strong> / <span>{rendered.length}</span> kan
    </p>
    <button type="button" class="fc-reset sc-press" data-fc-reset hidden
      >{labels.reset}</button
    >
  </div>

  <div class="fc-toolbar">
    {
      hasSections && (
        <div
          class="fc-section-chips"
          role="group"
          aria-label="Filtrer etter seksjon"
        >
          <button
            type="button"
            class="fc-chip active sc-press sc-chip"
            data-fc-section=""
            aria-pressed="true"
          >
            Alle
          </button>
          {sections.map((s) => (
            <button
              type="button"
              class="fc-chip sc-press sc-chip"
              data-fc-section={s}
              aria-pressed="false"
            >
              {s}
            </button>
          ))}
        </div>
      )
    }
    <div class="fc-toggles">
      <button
        type="button"
        class="fc-chip sc-press sc-chip"
        data-fc-unknown
        aria-pressed="false">Kun ukjente</button
      >
      <button type="button" class="fc-chip sc-press sc-chip" data-fc-shuffle
        >Bland</button
      >
    </div>
  </div>

  <div class="fc-stage">
    {
      rendered.map((card, i) => (
        /* No aria-label: it would REPLACE the button's accessible name, so a
           screen reader would hear "Snu" instead of the question. The name is
           the visible face's text (the script keeps the hidden face
           aria-hidden), and the fc-hint "Snu" inside the front face supplies
           the verb. */
        <button
          type="button"
          class="fc-card sc-lift"
          data-fc-card
          data-index={i}
          data-fc-id={card.id}
          data-section={card.section}
          hidden={i !== 0}
        >
          <span class="fc-inner">
            <span class="fc-face fc-front sc-panel">
              {card.section && (
                <span class="fc-section sc-kicker">{card.section}</span>
              )}
              <span class="fc-text" set:html={card.front} />
              <span class="fc-hint">{labels.flip}</span>
            </span>
            <span class="fc-face fc-back sc-panel" aria-hidden="true">
              {card.section && (
                <span class="fc-section sc-kicker">{card.section}</span>
              )}
              <span class="fc-text" set:html={card.back} />
            </span>
          </span>
          <span class="fc-level" aria-hidden="true">
            <span class="fc-level-check">
              <Icon name="check" size={13} />
            </span>
            <span class="fc-level-text">{labels.known}</span>
          </span>
        </button>
      ))
    }
    {
      /* Two empty states, set by show(): the earned one (every card in scope
        rated "kan") and the plain filter mismatch — with a next step each,
        so the end of a run never reads as a dead filter error. */
    }
    <div class="fc-empty" data-fc-empty>
      <p class="fc-empty-title" data-fc-empty-title>
        Ingen kort matcher filteret.
      </p>
      <p class="fc-empty-hint" data-fc-empty-hint></p>
    </div>
    {
      /* Announces the visible face's plain text on every flip/card-change.
        The flip only swaps aria-hidden between the two faces — focus stays on
        the same button, so without this a screen reader never hears the
        revealed answer (WCAG 4.1.2). */
    }
    <p class="sr-only" data-fc-live aria-live="polite"></p>
  </div>

  <div class="fc-controls">
    <button
      type="button"
      class="fc-nav sc-press sc-icon-btn"
      data-fc-prev
      aria-label="Forrige"
    >
      <Icon name="chevron-left" size={18} />
    </button>
    <div class="fc-rate">
      <button
        type="button"
        class="fc-btn fc-review sc-press sc-btn"
        data-fc-rate="0"
      >
        {labels.review}
      </button>
      <button
        type="button"
        class="fc-btn fc-known sc-press sc-btn"
        data-fc-rate="1"
      >
        {labels.known}
      </button>
    </div>
    <button
      type="button"
      class="fc-nav sc-press sc-icon-btn"
      data-fc-next
      aria-label="Neste"
    >
      <Icon name="chevron-right" size={18} />
    </button>
  </div>
  <p class="fc-counter">
    <span data-fc-pos>1</span> / <span data-fc-total>{rendered.length}</span>
  </p>
  {
    /* The deck's keyboard vocabulary as one quiet marginalia line — plain faint
      mono, no keycap boxes (a row of framed keys reads as a toolbar and pulls
      focus off the card). The keys sit one ink-step up from the connective
      words so the line still parses. Hidden on touch-only devices. */
  }
  <p class="fc-keys">
    <kbd>←→</kbd> bla · <kbd>mellomrom</kbd> snu · <kbd>1</kbd>{" "}
    {labels.review.toLowerCase()} · <kbd>2</kbd>
    {labels.known.toLowerCase()}
  </p>
</div>

<style>
  .flashcards {
    margin-block: var(--space-5);
  }
  .fc-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-3);
  }
  .fc-progress {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--muted);
  }
  .fc-progress strong {
    color: var(--accent-ink);
  }
  /* Marginalia: bare mono text; hover paints the ink wash. Padding is carved
     from negative margin so the wash has a shape without moving the label. */
  .fc-reset {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
    background: none;
    border: 0;
    padding: 0.2em 0.5em;
    margin: -0.2em -0.5em;
    border-radius: var(--radius-xs);
    transition:
      color var(--dur-fast) var(--ease),
      background-color var(--dur-fast) var(--ease),
      transform var(--dur-fast) var(--ease);
  }
  .fc-reset:hover {
    color: var(--accent-ink);
    background: var(--wash);
  }

  /* Filter toolbar: section chips (left) + toggles (right) — one chip language. */
  .fc-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--border);
  }
  .fc-section-chips,
  .fc-toggles {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  /* Chips are fully the shared .sc-chip (size, hover, selected state). */
  /* Empty/finished state — fills the card slot (dashed placeholder), and the
     rating controls hide, so it reads as a deliberate end-state rather than
     orphaned buttons over a vanished card. */
  .fc-empty {
    display: none;
    min-height: 200px;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    text-align: center;
    color: var(--muted);
    font-size: var(--text-sm);
    /* --border, not --border-strong: a static placeholder, not a control
       (the Structural-Border Rule). */
    border: 1px dashed var(--border);
    border-radius: var(--radius);
    padding: var(--space-4);
  }
  /* The earned all-known state trades the dashed placeholder frame for the
     completion language the rest of the site uses: a quiet accent wash. */
  .fc-empty[data-complete="true"] {
    border: 0;
    background: var(--accent-soft);
  }
  .fc-empty[data-complete="true"] .fc-empty-title {
    color: var(--accent-ink);
    font-weight: var(--weight-medium);
  }
  /* --muted, not --faint: the hint also sits on the completion state's
     accent wash, where --faint measures 3.9:1 (light) — below AA. */
  .fc-empty-hint {
    font-size: var(--text-xs);
    color: var(--muted);
  }
  .fc-empty-hint:empty {
    display: none;
  }
  .flashcards[data-empty="true"] .fc-empty {
    display: flex;
  }
  .flashcards[data-empty="true"] .fc-controls,
  .flashcards[data-empty="true"] .fc-counter {
    display: none;
  }

  .fc-stage {
    perspective: 1200px;
  }
  .fc-card {
    position: relative;
    display: block;
    width: 100%;
    min-height: 200px;
    padding: 0;
    border: 0;
    background: none;
    text-align: left;
  }
  /* `.fc-card { display:block }` would otherwise override the [hidden]
     attribute (the deck shows one card at a time via `hidden`). */
  .fc-card[hidden] {
    display: none;
  }
  .fc-inner {
    position: relative;
    display: block;
    width: 100%;
    min-height: 200px;
    transition: transform var(--dur) var(--ease);
    transform-style: preserve-3d;
  }
  .fc-card[data-flipped="true"] .fc-inner {
    transform: rotateY(180deg);
  }
  .fc-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: var(--space-3);
    text-align: center;
    padding: var(--space-6) var(--space-5);
    transition: box-shadow var(--dur-fast) var(--ease);
  }
  /* Same shadow-lift as the tiles (the 1px rise + transition come from .sc-lift
     on .fc-card): the face's resting shadow grows on hover, signalling "click to
     flip". The shadow lives on the face, not the card, hence the child target. */
  .fc-card:hover .fc-face {
    box-shadow: var(--shadow);
  }
  /* Float (fill + shadow + radius) comes from the shared .sc-panel; the answer
     side overrides the fill below. */
  /* The answer side carries a faint accent wash, so a flip reads as a change of
     state (question → answer) without a border fighting the card's shadow. */
  .fc-back {
    transform: rotateY(180deg);
    background: var(--accent-soft);
  }
  .fc-text {
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
  }
  /* Mono uppercase kicker recipe comes from .sc-kicker; this label keeps the
     WIDER tracking (a card section header, not a badge kicker) + its size/tone. */
  .fc-section {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    /* --accent-ink: this kicker sits on the accent-soft back AND the bg-elevated
       front — raw --accent fails AA in dark on both (3.89 / 4.37). */
    color: var(--accent-ink);
  }
  .fc-hint {
    position: absolute;
    bottom: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
  }

  /* Per-card known badge — sits outside .fc-inner so it never flips. Driven
     by data-level on the card (0 = not known, 1 = known): an accent check +
     "Kan" pill, the same accent "done" cue as the module done state, but
     filled (the deck's active-chip treatment) so it reads on the
     accent-washed answer side too. */
  .fc-level {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    z-index: 1;
    display: none;
    align-items: center;
    gap: 4px;
    line-height: 1;
    padding: 3px var(--space-2) 3px 6px;
    border-radius: var(--radius-pill);
    color: var(--accent-contrast);
    background: var(--accent);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
  }
  .fc-card[data-level="1"] .fc-level {
    display: inline-flex;
  }
  .fc-level-check {
    display: inline-flex;
    align-items: center;
  }

  .fc-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }
  .fc-rate {
    display: flex;
    gap: var(--space-2);
  }
  /* Frame, type and fill-darken hover come from the shared .sc-btn (rating) /
     .sc-icon-btn (nav arrows); only sizing is local. Rating labels keep the
     page ink — they are the deck's primary actions. */
  .fc-btn {
    min-height: var(--control-h);
    padding: var(--space-2) var(--space-4);
    color: var(--fg);
  }
  .fc-nav {
    min-height: var(--control-h);
    padding: var(--space-2) var(--space-4);
  }
  .fc-counter {
    text-align: center;
    margin-top: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }
  .fc-keys {
    text-align: center;
    margin-top: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--faint);
  }
  /* No box — just a hair more ink than the connective words so the keys read as
     keys (both stay AA on --bg: --muted 7.1:1, --faint 5.0:1). */
  .fc-keys kbd {
    color: var(--muted);
  }
  /* No keyboard to hint at on touch-only devices. */
  @media (hover: none) {
    .fc-keys {
      display: none;
    }
  }
</style>

<script>
  import { onPage } from "../lib/pageLifecycle.ts";
  // Keyed by each card's content id (data-fc-id), not its position — see the
  // component doc comment.
  type Levels = Record<string, number>;
  // Re-wire the deck per page-load; the document keydown is bound with the page
  // signal so it drops on the next swap instead of stacking.
  onPage((signal) => {
    const deck = document.querySelector<HTMLElement>(".flashcards");
    if (!deck) return;
    const key = deck.dataset.storageKey!;
    const total = Number(deck.dataset.total);
    const cards = [
      ...deck.querySelectorAll<HTMLButtonElement>("[data-fc-card]"),
    ];
    const knownOut = deck.querySelector<HTMLElement>("[data-fc-known]")!;
    const posOut = deck.querySelector<HTMLElement>("[data-fc-pos]")!;
    const totalOut = deck.querySelector<HTMLElement>("[data-fc-total]")!;
    const resetBtn = deck.querySelector<HTMLButtonElement>("[data-fc-reset]")!;
    const resetLabel = resetBtn.textContent;
    const emptyBox = deck.querySelector<HTMLElement>("[data-fc-empty]")!;
    const emptyTitle = deck.querySelector<HTMLElement>(
      "[data-fc-empty-title]",
    )!;
    const emptyHint = deck.querySelector<HTMLElement>("[data-fc-empty-hint]")!;

    // Both faces are always in the DOM (the flip is CSS backface-visibility,
    // which hides nothing from assistive tech): keep exactly the visible face
    // in the accessibility tree, so the button's name is the question at rest
    // and the answer once flipped — never both.
    const syncFaces = (c: HTMLButtonElement) => {
      const flipped = c.dataset.flipped === "true";
      c.querySelector(".fc-front")?.setAttribute(
        "aria-hidden",
        String(flipped),
      );
      c.querySelector(".fc-back")?.setAttribute(
        "aria-hidden",
        String(!flipped),
      );
    };

    const focusCard = () =>
      cards.find((c) => !c.hidden)?.focus({ preventScroll: true });

    // Plain text of a face's card text, for the live announcement. KaTeX
    // output carries both MathML (what a screen reader gets) and an
    // aria-hidden visual tree plus the raw LaTeX <annotation>; keep only the
    // MathML text so math reads as symbols, not doubled markup (same
    // stripping as Quiz's optionText).
    const liveEl = deck.querySelector<HTMLElement>("[data-fc-live]")!;
    const announce = (c: HTMLButtonElement) => {
      const face = c.querySelector<HTMLElement>(
        c.dataset.flipped === "true"
          ? ".fc-back .fc-text"
          : ".fc-front .fc-text",
      );
      if (!face) return;
      const clone = face.cloneNode(true) as HTMLElement;
      clone
        .querySelectorAll(".katex-html, annotation, .sr-only")
        .forEach((n) => n.remove());
      liveEl.textContent = clone.textContent?.replace(/\s+/g, " ").trim() ?? "";
    };

    const idsInDeck = new Set(cards.map((c) => c.dataset.fcId!));
    // Ratings persist as a versioned envelope { v: 2, data: { <id>: 0|1 } }.
    const ENVELOPE_V = 2;
    const save = (l: Levels) => {
      try {
        localStorage.setItem(key, JSON.stringify({ v: ENVELOPE_V, data: l }));
      } catch {}
    };
    // `dirty` marks a record that should be rewritten once: legacy positional,
    // corrupt, or holding entries for cards no longer in the deck.
    const load = (): { levels: Levels; dirty: boolean } => {
      let raw: string | null = null;
      try {
        raw = localStorage.getItem(key);
      } catch {
        return { levels: {}, dirty: false };
      }
      if (!raw) return { levels: {}, dirty: false };
      let parsed: unknown;
      try {
        parsed = JSON.parse(raw);
      } catch {
        parsed = null;
      }
      // A scalar/array/null (however it got stored) must reset, not leave
      // every later rating throwing on a non-object.
      if (
        parsed === null ||
        typeof parsed !== "object" ||
        Array.isArray(parsed)
      )
        return { levels: {}, dirty: true };
      const obj = parsed as Record<string, unknown>;
      let data: Record<string, unknown>;
      let dirty = false;
      if (
        obj.v === ENVELOPE_V &&
        typeof obj.data === "object" &&
        obj.data !== null &&
        !Array.isArray(obj.data)
      ) {
        data = obj.data as Record<string, unknown>;
      } else {
        // Legacy positional record: keys are card indices. A stored 2 can only
        // come from the older 0/1/2 mastery scheme (the binary model writes
        // 0/1), so it marks the whole record legacy: 2 (mastered) → known,
        // 1 (seen once) → not known — collapsing downward, never fabricating
        // mastery. In-range indices map to the id of the card at that
        // position; out-of-range keys are dropped.
        const hasMastery = Object.values(obj).some(
          (v) => typeof v === "number" && v >= 2,
        );
        data = {};
        for (const [k, v] of Object.entries(obj)) {
          const i = Number(k);
          if (!Number.isInteger(i) || i < 0 || i >= cards.length) continue;
          if (typeof v !== "number") continue;
          data[cards[i].dataset.fcId!] = hasMastery ? (v >= 2 ? 1 : 0) : v;
        }
        dirty = true;
      }
      // Prune ids no rendered card carries (deck edits), so the known counter
      // can never exceed the deck ("27 / 20 kan").
      const levels: Levels = {};
      for (const [id, v] of Object.entries(data)) {
        if (idsInDeck.has(id) && typeof v === "number") levels[id] = v;
        else dirty = true;
      }
      return { levels, dirty };
    };

    const loaded = load();
    let levels = loaded.levels;
    // One-time rewrite to the current envelope, so migration/pruning sticks.
    if (loaded.dirty) save(levels);
    let queue: number[] = [];
    let pos = 0;
    const filter = { section: "", onlyUnknown: false };
    // One-level undo for "Nullstill" (an undo beats a confirm dialog: no modal,
    // no friction on the honest path, and a slip is still recoverable).
    let undoStash: Levels | null = null;
    let undoTimer: ReturnType<typeof setTimeout> | undefined;
    // The undo window outlives any single handler — clear it on the page swap
    // so it can't fire into a replaced deck (same shape as ThemeToggle).
    signal.addEventListener("abort", () => clearTimeout(undoTimer), {
      once: true,
    });

    // The queue holds positional indices (stable within one render); the
    // stored level is looked up through the card's content id.
    const levelOf = (i: number) => levels[cards[i].dataset.fcId!] ?? 0;

    const buildQueue = () => {
      let indices = [...Array(total).keys()];
      if (filter.section) {
        indices = indices.filter(
          (i) => cards[i].dataset.section === filter.section,
        );
      }
      if (filter.onlyUnknown) {
        indices = indices.filter((i) => levelOf(i) < 1);
      }
      // Not-known first, then original order — a stable study order. "Bland"
      // reshuffles the built queue in place (below), on demand.
      indices.sort((a, b) => levelOf(a) - levelOf(b) || a - b);
      queue = indices;
    };

    // Reflect each card's stored known state on the card (drives the badge).
    const paintBadges = () => {
      cards.forEach((c) => {
        c.dataset.level = String(levels[c.dataset.fcId!] ?? 0);
      });
    };

    const renderProgress = () => {
      const known = Object.values(levels).filter((v) => v >= 1).length;
      knownOut.textContent = String(known);
      // Keep the button while an undo is pending, or "Angre" vanishes the
      // moment the reset it undoes empties the levels.
      resetBtn.hidden = !undoStash && Object.keys(levels).length === 0;
      paintBadges();
    };

    // Suppress the live announcement on the initial paint: page load isn't a
    // card change, and announcing the first card would talk over the page.
    let firstPaint = true;
    const show = () => {
      const idx = queue[pos];
      const isEmpty = idx === undefined;
      // Hiding the focused card orphans focus up to <main> (a tabindex=-1
      // container), which would draw a focus ring around the whole page. If the
      // card had focus, keep it on the deck by moving focus to the new card.
      const refocus = cards.includes(
        document.activeElement as HTMLButtonElement,
      );
      deck.dataset.empty = isEmpty ? "true" : "false";
      cards.forEach((c) => {
        c.hidden = isEmpty || Number(c.dataset.index) !== idx;
        c.dataset.flipped = "false";
        syncFaces(c);
      });
      if (refocus && !isEmpty) {
        focusCard();
      }
      if (!firstPaint && !isEmpty) {
        const cur = cards.find((c) => !c.hidden);
        if (cur) announce(cur);
      }
      firstPaint = false;
      posOut.textContent = isEmpty ? "0" : String(pos + 1);
      if (totalOut) totalOut.textContent = String(queue.length);
      if (isEmpty) {
        // Say WHY the deck is empty. Every card in scope rated "kan" is the
        // earned end of a run — acknowledge it quietly; anything else is a
        // filter mismatch, and both get their next step spelled out.
        const scope = cards.filter(
          (c) => !filter.section || c.dataset.section === filter.section,
        );
        const allKnown =
          filter.onlyUnknown &&
          scope.length > 0 &&
          scope.every((c) => (levels[c.dataset.fcId!] ?? 0) >= 1);
        emptyBox.dataset.complete = String(allKnown);
        if (allKnown) {
          emptyTitle.textContent = `Alle ${scope.length} kort er markert som kan.`;
          emptyHint.textContent =
            "Slå av «Kun ukjente» for å bla gjennom alle, eller nullstill og øv på nytt.";
        } else {
          emptyTitle.textContent = "Ingen kort matcher filteret.";
          emptyHint.textContent =
            "Velg en annen seksjon, eller slå av «Kun ukjente».";
        }
      }
    };

    // Navigation is a stable carousel: the queue order only changes when the
    // reader changes a filter, shuffles or resets — never silently mid-session,
    // so next/prev always moves to a different card (unless only one matches).
    const advance = (delta: number) => {
      const qlen = queue.length;
      if (!qlen) return;
      pos = (pos + delta + qlen) % qlen;
      show();
    };

    const rate = (known: boolean) => {
      const idx = queue[pos];
      if (idx === undefined) return;
      // Read-modify-write, like the reading-progress path: re-read the stored
      // envelope (load() re-validates a missing/corrupt one the same way), apply
      // only this card's change, and persist the merge — so a second open tab
      // can't clobber the other's ratings by rewriting the whole key from a
      // load-time snapshot. Adopting the merged state also converges this tab's
      // view on ratings other tabs made, without rebuilding the queue under the
      // card in view (advance() moves off it next anyway).
      levels = load().levels;
      levels[cards[idx].dataset.fcId!] = known ? 1 : 0;
      save(levels);
      renderProgress();
      advance(1);
    };

    // Card click = flip
    cards.forEach((c) =>
      c.addEventListener("click", () => {
        c.dataset.flipped = c.dataset.flipped === "true" ? "false" : "true";
        syncFaces(c);
        announce(c);
      }),
    );

    deck
      .querySelector("[data-fc-prev]")!
      .addEventListener("click", () => advance(-1));
    deck
      .querySelector("[data-fc-next]")!
      .addEventListener("click", () => advance(1));
    deck
      .querySelectorAll<HTMLButtonElement>("[data-fc-rate]")
      .forEach((b) =>
        b.addEventListener("click", () => rate(b.dataset.fcRate === "1")),
      );
    resetBtn.addEventListener("click", () => {
      if (undoStash) {
        // "Angre": restore the stashed ratings.
        clearTimeout(undoTimer);
        levels = undoStash;
        undoStash = null;
        resetBtn.textContent = resetLabel;
        save(levels);
        buildQueue();
        pos = 0;
        renderProgress();
        show();
        return;
      }
      undoStash = levels;
      levels = {};
      save(levels);
      buildQueue();
      pos = 0;
      renderProgress();
      show();
      // The button itself becomes the undo affordance for a beat; the label
      // swap is also what a screen reader hears on the still-focused control.
      resetBtn.textContent = "Angre";
      undoTimer = setTimeout(() => {
        undoStash = null;
        resetBtn.textContent = resetLabel;
        // renderProgress() hides the button once the window closes (levels is
        // empty) — if it still holds keyboard focus, hiding it would orphan
        // focus to <body>. Hand focus to the current card first, mirroring
        // show()'s refocus guard.
        const hadFocus = document.activeElement === resetBtn;
        renderProgress();
        if (hadFocus && resetBtn.hidden) {
          focusCard();
        }
      }, 8000);
    });

    // Section filter chips
    const sectionChips = [
      ...deck.querySelectorAll<HTMLButtonElement>("[data-fc-section]"),
    ];
    sectionChips.forEach((chip) => {
      chip.addEventListener("click", () => {
        filter.section = chip.dataset.fcSection ?? "";
        sectionChips.forEach((c) => {
          c.classList.toggle("active", c === chip);
          c.setAttribute("aria-pressed", c === chip ? "true" : "false");
        });
        buildQueue();
        pos = 0;
        show();
      });
    });

    // Unknown-only toggle
    const unknownBtn =
      deck.querySelector<HTMLButtonElement>("[data-fc-unknown]");
    if (unknownBtn) {
      unknownBtn.addEventListener("click", () => {
        filter.onlyUnknown = !filter.onlyUnknown;
        unknownBtn.classList.toggle("active", filter.onlyUnknown);
        unknownBtn.setAttribute("aria-pressed", String(filter.onlyUnknown));
        buildQueue();
        pos = 0;
        show();
      });
    }

    // Shuffle toggle
    const shuffleBtn =
      deck.querySelector<HTMLButtonElement>("[data-fc-shuffle]");
    if (shuffleBtn) {
      // "Bland" is a one-shot action: each click reshuffles the current cards
      // into a fresh random order (not a sticky sorted/shuffled toggle).
      shuffleBtn.addEventListener("click", () => {
        for (let i = queue.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [queue[i], queue[j]] = [queue[j], queue[i]];
        }
        pos = 0;
        show();
      });
    }

    // A mouse click leaves focus on the clicked control, and a focused button
    // natively re-activates on Space — the deck's flip key. After a pointer
    // click on any deck control, hand focus to the current card so the next
    // Space flips it. Keyboard activation (detail 0) keeps focus where the
    // user tabbed. Bubble phase: the control's own handler has already run,
    // so the visible card is the post-action one.
    deck.addEventListener("click", (e) => {
      if (e.detail === 0) return;
      const btn = (e.target as Element).closest("button");
      if (!btn || btn.dataset.fcCard !== undefined) return;
      focusCard();
    });

    // Keyboard: Space/Enter=flip, ←/→=navigate, 1=Øv, 2=Kan.
    // Every handled key also hands focus to the current card: the card is what
    // the keys control, so it — not whatever container the last click landed
    // focus on (e.g. the tabindex="-1" <main>, whose UA focus ring frames the
    // whole page) — should carry the keyboard highlight.
    document.addEventListener(
      "keydown",
      (e) => {
        if (e.metaKey || e.ctrlKey || e.altKey) return;
        const active = document.activeElement;
        const tag = (active?.tagName ?? "").toLowerCase();
        if (tag === "input" || tag === "textarea" || tag === "select") return;
        if (
          [...document.querySelectorAll("dialog")].some(
            (d) => (d as HTMLDialogElement).open,
          )
        )
          return;
        const cur = cards.find((c) => !c.hidden);
        if (!cur) return;
        if (e.key === " " || e.key === "Enter") {
          // A focused button (the card itself or a control) already activates on
          // Space/Enter natively — don't also flip here, or the two cancel out.
          if (active instanceof HTMLButtonElement) return;
          // Enter on a focused link is navigation, not a deck key.
          if (e.key === "Enter" && active instanceof HTMLAnchorElement) return;
          e.preventDefault();
          cur.dataset.flipped =
            cur.dataset.flipped === "true" ? "false" : "true";
          syncFaces(cur);
          announce(cur);
          focusCard();
        } else if (e.key === "ArrowLeft") {
          e.preventDefault();
          advance(-1);
          focusCard();
        } else if (e.key === "ArrowRight") {
          e.preventDefault();
          advance(1);
          focusCard();
        } else if (e.key === "1") {
          e.preventDefault();
          rate(false);
          focusCard();
        } else if (e.key === "2") {
          e.preventDefault();
          rate(true);
          focusCard();
        }
      },
      { signal },
    );

    buildQueue();
    renderProgress();
    show();
  });
</script>
