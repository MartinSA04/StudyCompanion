---
import type { Flashcards } from "../schema.ts";
import { renderMathString } from "../lib/katex.ts";
import Icon from "./Icon.astro";

/**
 * Flashcard deck (vanilla island) with a flip animation and a tiny
 * spaced-repetition scheme: rating a card "Kan" raises its level (it surfaces
 * later), "Øv" resets it (it surfaces sooner). Levels persist in localStorage
 * under `sc:flashcards:<code>`. Card text may contain $inline$ / $$display$$
 * math, rendered to KaTeX at build time.
 */
interface Props {
  cards: Flashcards["cards"];
  code: string;
  ui?: { known?: string; review?: string; flip?: string };
}
const { cards, code, ui } = Astro.props;
const labels = {
  known: ui?.known ?? "Kan",
  review: ui?.review ?? "Øv",
  flip: ui?.flip ?? "Snu",
};
const storageKey = `sc:flashcards:${code}`;

const rendered = cards.map((c) => ({
  front: renderMathString(c.front),
  back: renderMathString(c.back),
  section: c.section ?? "",
}));
const sections = [...new Set(rendered.map((c) => c.section).filter(Boolean))];
const hasSections = sections.length > 0;
---

<div
  class="flashcards"
  data-storage-key={storageKey}
  data-total={rendered.length}
>
  <div class="fc-head">
    <p class="fc-progress">
      <strong data-fc-known>0</strong> / <span>{rendered.length}</span> kan
    </p>
    <button type="button" class="fc-reset" data-fc-reset hidden
      >Nullstill</button
    >
  </div>

  <div class="fc-toolbar">
    {
      hasSections && (
        <div
          class="fc-section-chips"
          role="group"
          aria-label="Filtrer etter seksjon"
        >
          <button type="button" class="fc-chip active" data-fc-section="">
            Alle
          </button>
          {sections.map((s) => (
            <button type="button" class="fc-chip" data-fc-section={s}>
              {s}
            </button>
          ))}
        </div>
      )
    }
    <div class="fc-toggles">
      <button type="button" class="fc-chip" data-fc-unknown>Kun ukjente</button>
      <button type="button" class="fc-chip" data-fc-shuffle>Bland</button>
    </div>
  </div>

  <div class="fc-stage">
    {
      rendered.map((card, i) => (
        <button
          type="button"
          class="fc-card"
          data-fc-card
          data-index={i}
          data-section={card.section}
          hidden={i !== 0}
          aria-label={labels.flip}
        >
          <span class="fc-inner">
            <span class="fc-face fc-front">
              {card.section && <span class="fc-section">{card.section}</span>}
              <span class="fc-text" set:html={card.front} />
              <span class="fc-hint">{labels.flip}</span>
            </span>
            <span class="fc-face fc-back">
              <span class="fc-text" set:html={card.back} />
            </span>
          </span>
        </button>
      ))
    }
  </div>

  <div class="fc-controls">
    <button
      type="button"
      class="fc-btn fc-nav"
      data-fc-prev
      aria-label="Forrige"
    >
      <Icon name="chevron-left" size={18} />
    </button>
    <div class="fc-rate">
      <button type="button" class="fc-btn fc-review" data-fc-rate="0">
        {labels.review}
      </button>
      <button type="button" class="fc-btn fc-known" data-fc-rate="1">
        {labels.known}
      </button>
    </div>
    <button type="button" class="fc-btn fc-nav" data-fc-next aria-label="Neste">
      <Icon name="chevron-right" size={18} />
    </button>
  </div>
  <p class="fc-counter">
    <span data-fc-pos>1</span> / <span data-fc-total>{rendered.length}</span>
  </p>
  <p class="fc-empty" data-fc-empty hidden>Ingen kort matcher filteret.</p>
</div>

<style>
  .flashcards {
    margin-block: var(--space-5);
  }
  .fc-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-3);
  }
  .fc-progress {
    font-size: var(--text-sm);
    color: var(--muted);
  }
  .fc-progress strong {
    color: var(--tip);
  }
  .fc-reset {
    font-size: var(--text-xs);
    color: var(--muted);
    background: none;
    border: 0;
  }
  .fc-reset:hover {
    color: var(--accent);
  }

  /* Filter toolbar: section chips (left) + toggles (right) — one chip language. */
  .fc-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--border);
  }
  .fc-section-chips,
  .fc-toggles {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }
  .fc-chip {
    padding: 3px var(--space-3);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-pill);
    background: var(--bg-elevated);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--muted);
    transition: var(--dur-fast) var(--ease);
    cursor: pointer;
  }
  .fc-chip:hover {
    border-color: var(--accent);
    color: var(--fg);
  }
  .fc-chip.active {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--accent-contrast);
  }
  .fc-empty {
    text-align: center;
    padding: var(--space-6);
    color: var(--muted);
    font-size: var(--text-sm);
    font-style: italic;
  }

  .fc-stage {
    perspective: 1200px;
  }
  .fc-card {
    display: block;
    width: 100%;
    min-height: 200px;
    padding: 0;
    border: 0;
    background: none;
    text-align: left;
  }
  /* `.fc-card { display:block }` would otherwise override the [hidden]
     attribute (the deck shows one card at a time via `hidden`). */
  .fc-card[hidden] {
    display: none;
  }
  .fc-inner {
    position: relative;
    display: block;
    width: 100%;
    min-height: 200px;
    transition: transform var(--dur) var(--ease);
    transform-style: preserve-3d;
  }
  .fc-card[data-flipped="true"] .fc-inner {
    transform: rotateY(180deg);
  }
  .fc-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: var(--space-3);
    text-align: center;
    padding: var(--space-6) var(--space-5);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--card);
    box-shadow: var(--shadow-sm);
  }
  .fc-back {
    transform: rotateY(180deg);
    background: var(--bg-elevated);
    border-color: var(--accent);
  }
  .fc-text {
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
  }
  .fc-section {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    font-weight: var(--weight-semibold);
  }
  .fc-hint {
    position: absolute;
    bottom: var(--space-3);
    font-size: var(--text-xs);
    color: var(--muted);
  }

  .fc-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }
  .fc-rate {
    display: flex;
    gap: var(--space-2);
  }
  .fc-btn {
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg-elevated);
    font-weight: var(--weight-medium);
  }
  .fc-nav {
    display: inline-grid;
    place-items: center;
    color: var(--muted);
  }
  .fc-btn:hover {
    border-color: var(--border-strong);
  }
  .fc-nav:hover {
    color: var(--fg);
  }
  .fc-review:hover {
    border-color: var(--warning);
    color: var(--warning);
  }
  .fc-known:hover {
    border-color: var(--tip);
    color: var(--tip);
  }
  .fc-counter {
    text-align: center;
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }
</style>

<script>
  type Levels = Record<number, number>;
  const deck = document.querySelector<HTMLElement>(".flashcards");
  if (deck) {
    const key = deck.dataset.storageKey!;
    const total = Number(deck.dataset.total);
    const cards = [
      ...deck.querySelectorAll<HTMLButtonElement>("[data-fc-card]"),
    ];
    const knownOut = deck.querySelector<HTMLElement>("[data-fc-known]")!;
    const posOut = deck.querySelector<HTMLElement>("[data-fc-pos]")!;
    const totalOut = deck.querySelector<HTMLElement>("[data-fc-total]")!;
    const resetBtn = deck.querySelector<HTMLButtonElement>("[data-fc-reset]")!;
    const emptyMsg = deck.querySelector<HTMLElement>("[data-fc-empty]");

    const load = (): Levels => {
      try {
        return JSON.parse(localStorage.getItem(key) || "{}") as Levels;
      } catch {
        return {};
      }
    };
    const save = (l: Levels) => {
      try {
        localStorage.setItem(key, JSON.stringify(l));
      } catch {}
    };

    let levels = load();
    let queue: number[] = [];
    let pos = 0;
    const filter = { section: "", onlyUnknown: false, shuffled: false };

    const buildQueue = () => {
      let indices = [...Array(total).keys()];
      if (filter.section) {
        indices = indices.filter(
          (i) => cards[i].dataset.section === filter.section,
        );
      }
      if (filter.onlyUnknown) {
        indices = indices.filter((i) => (levels[i] ?? 0) < 2);
      }
      if (filter.shuffled) {
        for (let i = indices.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [indices[i], indices[j]] = [indices[j], indices[i]];
        }
      } else {
        indices.sort((a, b) => (levels[a] ?? 0) - (levels[b] ?? 0) || a - b);
      }
      queue = indices;
    };

    const renderProgress = () => {
      const known = Object.values(levels).filter((v) => v >= 2).length;
      knownOut.textContent = String(known);
      resetBtn.hidden = Object.keys(levels).length === 0;
    };

    const show = () => {
      const idx = queue[pos];
      const isEmpty = idx === undefined;
      if (emptyMsg) emptyMsg.hidden = !isEmpty;
      cards.forEach((c) => {
        c.hidden = isEmpty || Number(c.dataset.index) !== idx;
        c.dataset.flipped = "false";
      });
      posOut.textContent = isEmpty ? "0" : String(pos + 1);
      if (totalOut) totalOut.textContent = String(queue.length);
    };

    const advance = (delta: number) => {
      const qlen = queue.length;
      if (!qlen) return;
      pos = (pos + delta + qlen) % qlen;
      if (pos === 0) buildQueue();
      show();
    };

    const rate = (known: boolean) => {
      const idx = queue[pos];
      if (idx === undefined) return;
      levels[idx] = known ? Math.min(2, (levels[idx] ?? 0) + 1) : 0;
      save(levels);
      renderProgress();
      advance(1);
    };

    // Card click = flip
    cards.forEach((c) =>
      c.addEventListener("click", () => {
        c.dataset.flipped = c.dataset.flipped === "true" ? "false" : "true";
      }),
    );

    deck
      .querySelector("[data-fc-prev]")!
      .addEventListener("click", () => advance(-1));
    deck
      .querySelector("[data-fc-next]")!
      .addEventListener("click", () => advance(1));
    deck
      .querySelectorAll<HTMLButtonElement>("[data-fc-rate]")
      .forEach((b) =>
        b.addEventListener("click", () => rate(b.dataset.fcRate === "1")),
      );
    resetBtn.addEventListener("click", () => {
      levels = {};
      save(levels);
      buildQueue();
      pos = 0;
      renderProgress();
      show();
    });

    // Section filter chips
    const sectionChips = [
      ...deck.querySelectorAll<HTMLButtonElement>("[data-fc-section]"),
    ];
    sectionChips.forEach((chip) => {
      chip.addEventListener("click", () => {
        filter.section = chip.dataset.fcSection ?? "";
        sectionChips.forEach((c) => c.classList.toggle("active", c === chip));
        buildQueue();
        pos = 0;
        show();
      });
    });

    // Unknown-only toggle
    const unknownBtn =
      deck.querySelector<HTMLButtonElement>("[data-fc-unknown]");
    if (unknownBtn) {
      unknownBtn.addEventListener("click", () => {
        filter.onlyUnknown = !filter.onlyUnknown;
        unknownBtn.classList.toggle("active", filter.onlyUnknown);
        buildQueue();
        pos = 0;
        show();
      });
    }

    // Shuffle toggle
    const shuffleBtn =
      deck.querySelector<HTMLButtonElement>("[data-fc-shuffle]");
    if (shuffleBtn) {
      shuffleBtn.addEventListener("click", () => {
        filter.shuffled = !filter.shuffled;
        shuffleBtn.classList.toggle("active", filter.shuffled);
        buildQueue();
        pos = 0;
        show();
      });
    }

    // Keyboard: Space/Enter=flip, ←/→=navigate, 1=Øv, 2=Kan
    document.addEventListener("keydown", (e) => {
      if (e.metaKey || e.ctrlKey || e.altKey) return;
      const active = document.activeElement;
      const tag = (active?.tagName ?? "").toLowerCase();
      if (tag === "input" || tag === "textarea" || tag === "select") return;
      if (
        [...document.querySelectorAll("dialog")].some(
          (d) => (d as HTMLDialogElement).open,
        )
      )
        return;
      const cur = cards.find((c) => !c.hidden);
      if (!cur) return;
      if (e.key === " " || e.key === "Enter") {
        if (active?.closest(".fc-controls")) return;
        e.preventDefault();
        cur.dataset.flipped = cur.dataset.flipped === "true" ? "false" : "true";
      } else if (e.key === "ArrowLeft") {
        e.preventDefault();
        advance(-1);
      } else if (e.key === "ArrowRight") {
        e.preventDefault();
        advance(1);
      } else if (e.key === "1") {
        e.preventDefault();
        rate(false);
      } else if (e.key === "2") {
        e.preventDefault();
        rate(true);
      }
    });

    buildQueue();
    renderProgress();
    show();
  }
</script>
