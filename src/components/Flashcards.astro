---
import type { Flashcards } from "../schema.ts";
import { renderMathString } from "../lib/katex.ts";
import { fcId } from "../lib/fcId.ts";
import Icon from "./Icon.astro";

/**
 * Flashcard deck (vanilla island) with a flip animation and a binary rating:
 * "Kan" marks a card known (it surfaces later), "Øv" marks it not known (it
 * surfaces sooner). Ratings persist in localStorage under
 * `sc:flashcards:<code>` as a versioned envelope keyed by each card's content
 * id (fcId of the front text), so deck edits can't shift ratings onto the
 * wrong cards; load() migrates legacy positional records (and their 0/1/2
 * mastery scheme) once. Card text may contain $inline$ / $$display$$ math,
 * rendered to KaTeX at build time.
 */
interface Props {
  cards: Flashcards["cards"];
  code: string;
  ui?: { known?: string; review?: string; flip?: string; reset?: string };
}
const { cards, code, ui } = Astro.props;
const labels = {
  known: ui?.known ?? "Kan",
  review: ui?.review ?? "Øv",
  flip: ui?.flip ?? "Snu",
  reset: ui?.reset ?? "Nullstill",
};
const storageKey = `sc:flashcards:${code}`;

const rendered = cards.map((c) => ({
  front: renderMathString(c.front),
  back: renderMathString(c.back),
  section: c.section ?? "",
  id: fcId(c.front),
}));
const sections = [...new Set(rendered.map((c) => c.section).filter(Boolean))];
const hasSections = sections.length > 0;
---

<div
  class="flashcards"
  data-storage-key={storageKey}
  data-total={rendered.length}
>
  <div class="fc-head">
    {
      /* role="status": rating updates this line ("2 / 24 kan"), which is the
        visible — and announced — acknowledgment that a Kan/Øv press landed. */
    }
    <p
      class="fc-progress"
      role="status"
      title="Lagres lokalt i denne nettleseren"
    >
      <strong data-fc-known>0</strong> / <span>{rendered.length}</span> kan
    </p>
    <button type="button" class="fc-reset sc-press" data-fc-reset hidden
      >{labels.reset}</button
    >
  </div>

  <div class="fc-toolbar">
    {
      hasSections && (
        <>
          {/* Two forms of the same section filter: a chip row on desktop, and a
              native <select> on a phone — many sections would wrap the chips into
              several rows and eat the screen, whereas the select stays one line
              and opens the OS picker. CSS shows exactly one per breakpoint; the
              script keeps both in sync. */}
          <div
            class="fc-section-chips"
            role="group"
            aria-label="Filtrer etter seksjon"
          >
            <button
              type="button"
              class="fc-chip active sc-press sc-chip"
              data-fc-section=""
              aria-pressed="true"
            >
              Alle
            </button>
            {sections.map((s) => (
              <button
                type="button"
                class="fc-chip sc-press sc-chip"
                data-fc-section={s}
                aria-pressed="false"
              >
                {s}
              </button>
            ))}
          </div>
          <span class="fc-section-select-wrap">
            <select
              class="fc-section-select"
              data-fc-section-select
              aria-label="Filtrer etter seksjon"
            >
              <option value="">Alle</option>
              {sections.map((s) => (
                <option value={s}>{s}</option>
              ))}
            </select>
          </span>
        </>
      )
    }
    <div class="fc-toggles">
      <button
        type="button"
        class="fc-chip sc-press sc-chip"
        data-fc-unknown
        aria-pressed="false">Kun ukjente</button
      >
      <button
        type="button"
        class="fc-chip sc-press sc-chip fc-shuffle"
        data-fc-shuffle
        aria-label="Bland kortene"
      >
        {
          /* Icon-only: the shuffle glyph at rest, cross-fading to a check for a
            beat after a click to confirm the (off-screen) reorder landed. Both
            glyphs occupy one grid cell so the chip never resizes mid-swap.
            aria-label above carries the accessible name; the glyphs are
            decorative to AT. */
        }
        <span class="fc-shuffle-face fc-shuffle-idle" aria-hidden="true">
          <Icon name="shuffle" size={15} />
        </span>
        <span class="fc-shuffle-face fc-shuffle-done" aria-hidden="true">
          <Icon name="check" size={15} />
        </span>
      </button>
    </div>
  </div>

  <div class="fc-stage">
    {
      rendered.map((card, i) => (
        /* No aria-label: it would REPLACE the button's accessible name, so a
           screen reader would hear "Snu" instead of the question. The name is
           the visible face's text (the script keeps the hidden face
           aria-hidden), and the fc-hint "Snu" inside the front face supplies
           the verb. */
        <button
          type="button"
          class="fc-card sc-lift"
          data-fc-card
          data-index={i}
          data-fc-id={card.id}
          data-section={card.section}
          data-current={i === 0 ? "true" : undefined}
          hidden={i !== 0}
        >
          <span class="fc-inner">
            <span class="fc-face fc-front sc-panel">
              {card.section && (
                <span class="fc-section sc-kicker">{card.section}</span>
              )}
              <span class="fc-text" set:html={card.front} />
              <span class="fc-hint">{labels.flip}</span>
            </span>
            <span class="fc-face fc-back sc-panel" aria-hidden="true">
              {card.section && (
                <span class="fc-section sc-kicker">{card.section}</span>
              )}
              <span class="fc-text" set:html={card.back} />
            </span>
          </span>
          <span class="fc-level" aria-hidden="true">
            <span class="fc-level-check">
              <Icon name="check" size={13} />
            </span>
            <span class="fc-level-text">{labels.known}</span>
          </span>
        </button>
      ))
    }
    {
      /* Two empty states, set by show(): the earned one (every card in scope
        rated "kan") and the plain filter mismatch — with a next step each,
        so the end of a run never reads as a dead filter error. */
    }
    <div class="fc-empty" data-fc-empty>
      <p class="fc-empty-title" data-fc-empty-title>
        Ingen kort matcher filteret.
      </p>
      <p class="fc-empty-hint" data-fc-empty-hint></p>
    </div>
    {
      /* Announces the visible face's plain text on every flip/card-change.
        The flip only swaps aria-hidden between the two faces — focus stays on
        the same button, so without this a screen reader never hears the
        revealed answer (WCAG 4.1.2). */
    }
    <p class="sr-only" data-fc-live aria-live="polite"></p>
  </div>

  <div class="fc-controls">
    <button
      type="button"
      class="fc-nav sc-press sc-icon-btn"
      data-fc-prev
      aria-label="Forrige"
    >
      <Icon name="chevron-left" size={18} />
    </button>
    <div class="fc-rate">
      <button
        type="button"
        class="fc-btn fc-review sc-press sc-btn"
        data-fc-rate="0"
      >
        {labels.review}
      </button>
      <button
        type="button"
        class="fc-btn fc-known sc-press sc-btn"
        data-fc-rate="1"
      >
        {labels.known}
      </button>
    </div>
    <button
      type="button"
      class="fc-nav sc-press sc-icon-btn"
      data-fc-next
      aria-label="Neste"
    >
      <Icon name="chevron-right" size={18} />
    </button>
  </div>
  <p class="fc-counter">
    <span data-fc-pos>1</span> / <span data-fc-total>{rendered.length}</span>
  </p>
  {
    /* The deck's keyboard vocabulary as one quiet marginalia line — plain faint
      mono, no keycap boxes (a row of framed keys reads as a toolbar and pulls
      focus off the card). The keys sit one ink-step up from the connective
      words so the line still parses. Hidden on touch-only devices. */
  }
  <p class="fc-keys">
    <kbd>←→</kbd> bla · <kbd>mellomrom</kbd> snu · <kbd>1</kbd>{" "}
    {labels.review.toLowerCase()} · <kbd>2</kbd>
    {labels.known.toLowerCase()}
  </p>
</div>

<style>
  .flashcards {
    margin-block: var(--space-5);
  }
  .fc-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-3);
  }
  .fc-progress {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--muted);
  }
  .fc-progress strong {
    color: var(--accent-ink);
  }
  /* Marginalia: bare mono text; hover paints the ink wash. Padding is carved
     from negative margin so the wash has a shape without moving the label. */
  .fc-reset {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
    background: none;
    border: 0;
    padding: 0.2em 0.5em;
    margin: -0.2em -0.5em;
    border-radius: var(--radius-xs);
    transition:
      color var(--dur-fast) var(--ease),
      background-color var(--dur-fast) var(--ease),
      transform var(--dur-fast) var(--ease);
  }
  .fc-reset:hover {
    color: var(--accent-ink);
    background: var(--wash);
  }

  /* Filter toolbar: section chips (left) + toggles (right) — one chip language. */
  .fc-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--border);
  }
  .fc-section-chips,
  .fc-toggles {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  /* The phone section picker (shown only ≤640px, below): the native <select>
     stripped of its OS chrome and dressed as a .sc-chip — same borderless pill,
     mono type, bg-elevated fill and hover wash — so it reads as one of the deck's
     own filter controls, not a system widget. The list itself stays native (the
     OS wheel — good touch UX). A wrapper draws the chevron, since a <select>
     can't carry its own ::after. */
  .fc-section-select-wrap {
    display: none;
    position: relative;
    align-items: center;
    min-width: 0;
    max-width: 55vw;
  }
  .fc-section-select {
    appearance: none;
    -webkit-appearance: none;
    width: 100%;
    /* Room on the right for the chevron the wrapper draws. */
    padding: 0.35em 1.9em 0.35em 0.8em;
    border: 0;
    border-radius: var(--radius-pill);
    background: var(--bg-elevated);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
    text-overflow: ellipsis;
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease),
      background-color var(--dur-fast) var(--ease);
  }
  .fc-section-select:hover {
    color: var(--accent-ink);
    background: var(--card-hover);
  }
  /* Chevron: a rotated corner in the muted ink, echoing the hover to accent. */
  .fc-section-select-wrap::after {
    content: "";
    position: absolute;
    right: 0.8em;
    width: 0.42em;
    height: 0.42em;
    color: var(--muted);
    border-right: 1.5px solid currentColor;
    border-bottom: 1.5px solid currentColor;
    transform: translateY(-25%) rotate(45deg);
    pointer-events: none;
    transition: color var(--dur-fast) var(--ease);
  }
  .fc-section-select-wrap:hover::after {
    color: var(--accent-ink);
  }
  /* Chips are fully the shared .sc-chip (size, hover, selected state). */
  /* Shuffle chip: an icon + label that cross-fades to a check + "Blandet" for a
     beat after a click, so a one-shot action gives visible feedback. Both faces
     occupy the same grid cell — the chip keeps its widest width and never
     reflows the toolbar mid-swap. */
  .fc-shuffle {
    display: inline-grid;
    place-items: center;
  }
  .fc-shuffle-face {
    grid-area: 1 / 1;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    transition: opacity var(--dur-fast) var(--ease);
  }
  .fc-shuffle-done {
    opacity: 0;
    color: var(--accent-ink);
  }
  .fc-shuffle[data-shuffled="true"] .fc-shuffle-idle {
    opacity: 0;
  }
  .fc-shuffle[data-shuffled="true"] .fc-shuffle-done {
    opacity: 1;
  }
  /* Empty/finished state — fills the card slot (dashed placeholder), and the
     rating controls hide, so it reads as a deliberate end-state rather than
     orphaned buttons over a vanished card. */
  .fc-empty {
    display: none;
    min-height: 200px;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    text-align: center;
    color: var(--muted);
    font-size: var(--text-sm);
    /* --border, not --border-strong: a static placeholder, not a control
       (the Structural-Border Rule). */
    border: 1px dashed var(--border);
    border-radius: var(--radius);
    padding: var(--space-4);
  }
  /* The earned all-known state trades the dashed placeholder frame for the
     completion language the rest of the site uses: a quiet accent wash. */
  .fc-empty[data-complete="true"] {
    border: 0;
    background: var(--accent-soft);
  }
  .fc-empty[data-complete="true"] .fc-empty-title {
    color: var(--accent-ink);
    font-weight: var(--weight-medium);
  }
  /* --muted, not --faint: the hint also sits on the completion state's
     accent wash, where --faint measures 3.9:1 (light) — below AA. */
  .fc-empty-hint {
    font-size: var(--text-xs);
    color: var(--muted);
  }
  .fc-empty-hint:empty {
    display: none;
  }
  .flashcards[data-empty="true"] .fc-empty {
    display: flex;
  }
  .flashcards[data-empty="true"] .fc-controls,
  .flashcards[data-empty="true"] .fc-counter {
    display: none;
  }

  .fc-stage {
    position: relative;
    perspective: 1200px;
    /* The cards are absolutely stacked (below) and carry no flow height, so the
       stage sets it — taller than the card so the card centres with room for the
       peeked cards' rim above and below. */
    min-height: 300px;
    margin-bottom: var(--space-3);
    /* Clip the card that flies off on a rating/nav so it can't grow the document
       (a horizontal scrollbar / page-stretch mid-swipe). `clip` — not `hidden` —
       keeps it out of the scroll box without becoming a scroll container, and the
       margin still lets the resting card's hover shadow and the peek rim show. */
    overflow: clip;
    overflow-clip-margin: 24px;
  }
  /* The deck is a small STACK: the current card on top, with the next card (and,
     deeper, the previous) already rendered behind it and nudged down, so a slow
     drag slides the top card off to preview the one beneath — a real z-stack,
     not a text swap. All cards share one box (absolute, inset:0), layered by
     z-index; the script (applyRole) owns each card's transform, z, opacity and
     interactivity per role, and animates role changes through the transition
     declared here. */
  .fc-card {
    position: absolute;
    /* inset:0 + a fixed height + margin:auto centres the card in the (taller)
       stage, so it reads as a card floating on the page rather than a full-height
       slab. The role transforms nudge from that centred rest position. */
    inset: 0;
    height: 240px;
    margin: auto;
    padding: 0;
    border: 0;
    background: none;
    text-align: left;
    transform-origin: center;
    /* Vertical page scroll still starts on the card; horizontal drags reach the
       swipe handler instead of being claimed by the browser as a pan. */
    touch-action: pan-y;
    transition:
      transform var(--dur) var(--ease),
      opacity var(--dur) var(--ease);
    will-change: transform;
  }
  .fc-card[hidden] {
    display: none;
  }
  .fc-inner {
    position: absolute;
    inset: 0;
    transition: transform var(--dur) var(--ease);
    transform-style: preserve-3d;
  }
  .fc-card[data-flipped="true"] .fc-inner {
    transform: rotateY(180deg);
  }
  .fc-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: var(--space-3);
    text-align: center;
    padding: var(--space-6) var(--space-5);
    transition: box-shadow var(--dur-fast) var(--ease);
  }
  /* Only the top (current) card lifts on hover — the peeked cards behind it are
     inert. The shadow lives on the face, not the card, hence the child target. */
  .fc-card[data-current]:hover .fc-face {
    box-shadow: var(--shadow);
  }
  /* Float (fill + shadow + radius) comes from the shared .sc-panel; the answer
     side overrides the fill below. */
  /* The answer side carries a faint accent wash, so a flip reads as a change of
     state (question → answer) without a border fighting the card's shadow. */
  .fc-back {
    transform: rotateY(180deg);
    background: var(--accent-soft);
  }
  .fc-text {
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
  }
  /* Mono uppercase kicker recipe comes from .sc-kicker; this label keeps the
     WIDER tracking (a card section header, not a badge kicker) + its size/tone. */
  .fc-section {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    /* --accent-ink: this kicker sits on the accent-soft back AND the bg-elevated
       front — raw --accent fails AA in dark on both (3.89 / 4.37). */
    color: var(--accent-ink);
  }
  .fc-hint {
    position: absolute;
    bottom: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
  }

  /* Per-card known badge — sits outside .fc-inner so it never flips. Driven
     by data-level on the card (0 = not known, 1 = known): an accent check +
     "Kan" pill, the same accent "done" cue as the module done state, but
     filled (the deck's active-chip treatment) so it reads on the
     accent-washed answer side too. */
  .fc-level {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    z-index: 1;
    display: none;
    align-items: center;
    gap: 4px;
    line-height: 1;
    padding: 3px var(--space-2) 3px 6px;
    border-radius: var(--radius-pill);
    color: var(--accent-contrast);
    background: var(--accent);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
  }
  .fc-card[data-level="1"][data-current] .fc-level {
    display: inline-flex;
  }
  .fc-level-check {
    display: inline-flex;
    align-items: center;
  }

  .fc-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }
  .fc-rate {
    display: flex;
    gap: var(--space-2);
  }
  /* Frame, type and fill-darken hover come from the shared .sc-btn (rating) /
     .sc-icon-btn (nav arrows); only sizing is local. Rating labels keep the
     page ink — they are the deck's primary actions. */
  .fc-btn {
    min-height: var(--control-h);
    padding: var(--space-2) var(--space-4);
    color: var(--fg);
  }
  .fc-nav {
    min-height: var(--control-h);
    padding: var(--space-2) var(--space-4);
  }
  .fc-counter {
    text-align: center;
    margin-top: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }
  .fc-keys {
    text-align: center;
    margin-top: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--faint);
  }
  /* No box — just a hair more ink than the connective words so the keys read as
     keys (both stay AA on --bg: --muted 7.1:1, --faint 5.0:1). */
  .fc-keys kbd {
    color: var(--muted);
  }
  /* No keyboard to hint at on touch-only devices. */
  @media (hover: none) {
    .fc-keys {
      display: none;
    }
  }

  /* Thumb-zone controls on a phone. The deck becomes a column that fills the
     screen (so the card centres and the footer falls below the fold), and the
     rating/nav row STICKS to the viewport bottom while the card is in view — the
     primary actions sit under the thumb. Because it's sticky, not fixed, it rides
     up out of the way when you scroll on to the footer, so the footer needs no
     dead scroll-room beneath it (an earlier `position: fixed` did, and reserving
     that room globally leaked padding onto every page). It no longer strands
     mid-screen — the old failure mode — because the deck now always fills the
     viewport. Full-bleed --bg fill + a top hairline + safe-area inset. Desktop
     keeps the inline row untouched. */
  @media (max-width: 640px) {
    .flashcards {
      display: flex;
      flex-direction: column;
      /* Fill the viewport so the sticky bar has scroll range to pin against and
         the footer starts just below the fold. dvh tracks the live viewport, so
         the deck matches it (bar reliably pinned) without the overshoot that
         leaves dead space under the footer at the end of the scroll. */
      min-height: 100dvh;
    }
    /* Swap the wrapping section chips for the one-line chip-styled picker. */
    .fc-section-chips {
      display: none;
    }
    .fc-section-select-wrap {
      display: inline-flex;
    }
    /* The stage absorbs the column's slack; the card sits at the TOP of it (the
       slack falls below), which lands the card near the middle of the SCREEN —
       the header + title + toolbar above it already occupy roughly the top half,
       so centring the card within the stage would push it too low. */
    .fc-stage {
      flex: 1 1 auto;
      min-height: 14rem;
    }
    .fc-card {
      height: clamp(12rem, 34dvh, 16rem);
      margin-top: var(--space-4);
      margin-bottom: auto;
    }
    .fc-controls {
      position: sticky;
      bottom: 0;
      z-index: 5;
      background: var(--bg);
      border-top: 1px solid var(--border);
      padding: var(--space-3) var(--space-4);
      padding-bottom: calc(var(--space-3) + env(safe-area-inset-bottom));
    }
    /* Full-width rating targets: the Øv/Kan pair fills the space between the
       arrows, each button splitting it evenly, at the 44px WCAG touch size. */
    .fc-rate {
      flex: 1;
    }
    .fc-rate .fc-btn {
      flex: 1;
    }
    .fc-btn,
    .fc-nav {
      min-height: 44px;
    }
  }
</style>

<script>
  import { onPage } from "../lib/pageLifecycle.ts";
  import { attachSwipe, SWIPE_THRESHOLD } from "../lib/swipe.ts";
  // Keyed by each card's content id (data-fc-id), not its position — see the
  // component doc comment.
  type Levels = Record<string, number>;
  // Re-wire the deck per page-load; the document keydown is bound with the page
  // signal so it drops on the next swap instead of stacking.
  onPage((signal) => {
    const deck = document.querySelector<HTMLElement>(".flashcards");
    if (!deck) return;
    const key = deck.dataset.storageKey!;
    const total = Number(deck.dataset.total);
    const cards = [
      ...deck.querySelectorAll<HTMLButtonElement>("[data-fc-card]"),
    ];
    const knownOut = deck.querySelector<HTMLElement>("[data-fc-known]")!;
    const posOut = deck.querySelector<HTMLElement>("[data-fc-pos]")!;
    const totalOut = deck.querySelector<HTMLElement>("[data-fc-total]")!;
    const resetBtn = deck.querySelector<HTMLButtonElement>("[data-fc-reset]")!;
    const resetLabel = resetBtn.textContent;
    const emptyBox = deck.querySelector<HTMLElement>("[data-fc-empty]")!;
    const emptyTitle = deck.querySelector<HTMLElement>(
      "[data-fc-empty-title]",
    )!;
    const emptyHint = deck.querySelector<HTMLElement>("[data-fc-empty-hint]")!;

    // Both faces are always in the DOM (the flip is CSS backface-visibility,
    // which hides nothing from assistive tech): keep exactly the visible face
    // in the accessibility tree, so the button's name is the question at rest
    // and the answer once flipped — never both.
    const syncFaces = (c: HTMLButtonElement) => {
      const flipped = c.dataset.flipped === "true";
      c.querySelector(".fc-front")?.setAttribute(
        "aria-hidden",
        String(flipped),
      );
      c.querySelector(".fc-back")?.setAttribute(
        "aria-hidden",
        String(!flipped),
      );
    };

    const focusCard = () => currentCard()?.focus({ preventScroll: true });

    const stage = deck.querySelector<HTMLElement>(".fc-stage")!;
    const prefersReduced = () =>
      window.matchMedia?.("(prefers-reduced-motion: reduce)").matches ?? false;

    // Plain text of a face's card text, for the live announcement. KaTeX
    // output carries both MathML (what a screen reader gets) and an
    // aria-hidden visual tree plus the raw LaTeX <annotation>; keep only the
    // MathML text so math reads as symbols, not doubled markup (same
    // stripping as Quiz's optionText).
    const liveEl = deck.querySelector<HTMLElement>("[data-fc-live]")!;
    const announce = (c: HTMLButtonElement) => {
      const face = c.querySelector<HTMLElement>(
        c.dataset.flipped === "true"
          ? ".fc-back .fc-text"
          : ".fc-front .fc-text",
      );
      if (!face) return;
      const clone = face.cloneNode(true) as HTMLElement;
      clone
        .querySelectorAll(".katex-html, annotation, .sr-only")
        .forEach((n) => n.remove());
      liveEl.textContent = clone.textContent?.replace(/\s+/g, " ").trim() ?? "";
    };

    const idsInDeck = new Set(cards.map((c) => c.dataset.fcId!));
    // Ratings persist as a versioned envelope { v: 2, data: { <id>: 0|1 } }.
    const ENVELOPE_V = 2;
    const save = (l: Levels) => {
      try {
        localStorage.setItem(key, JSON.stringify({ v: ENVELOPE_V, data: l }));
      } catch {}
    };
    // `dirty` marks a record that should be rewritten once: legacy positional,
    // corrupt, or holding entries for cards no longer in the deck.
    const load = (): { levels: Levels; dirty: boolean } => {
      let raw: string | null = null;
      try {
        raw = localStorage.getItem(key);
      } catch {
        return { levels: {}, dirty: false };
      }
      if (!raw) return { levels: {}, dirty: false };
      let parsed: unknown;
      try {
        parsed = JSON.parse(raw);
      } catch {
        parsed = null;
      }
      // A scalar/array/null (however it got stored) must reset, not leave
      // every later rating throwing on a non-object.
      if (
        parsed === null ||
        typeof parsed !== "object" ||
        Array.isArray(parsed)
      )
        return { levels: {}, dirty: true };
      const obj = parsed as Record<string, unknown>;
      let data: Record<string, unknown>;
      let dirty = false;
      if (
        obj.v === ENVELOPE_V &&
        typeof obj.data === "object" &&
        obj.data !== null &&
        !Array.isArray(obj.data)
      ) {
        data = obj.data as Record<string, unknown>;
      } else {
        // Legacy positional record: keys are card indices. A stored 2 can only
        // come from the older 0/1/2 mastery scheme (the binary model writes
        // 0/1), so it marks the whole record legacy: 2 (mastered) → known,
        // 1 (seen once) → not known — collapsing downward, never fabricating
        // mastery. In-range indices map to the id of the card at that
        // position; out-of-range keys are dropped.
        const hasMastery = Object.values(obj).some(
          (v) => typeof v === "number" && v >= 2,
        );
        data = {};
        for (const [k, v] of Object.entries(obj)) {
          const i = Number(k);
          if (!Number.isInteger(i) || i < 0 || i >= cards.length) continue;
          if (typeof v !== "number") continue;
          data[cards[i].dataset.fcId!] = hasMastery ? (v >= 2 ? 1 : 0) : v;
        }
        dirty = true;
      }
      // Prune ids no rendered card carries (deck edits), so the known counter
      // can never exceed the deck ("27 / 20 kan").
      const levels: Levels = {};
      for (const [id, v] of Object.entries(data)) {
        if (idsInDeck.has(id) && typeof v === "number") levels[id] = v;
        else dirty = true;
      }
      return { levels, dirty };
    };

    const loaded = load();
    let levels = loaded.levels;
    // One-time rewrite to the current envelope, so migration/pruning sticks.
    if (loaded.dirty) save(levels);
    let queue: number[] = [];
    let pos = 0;
    const filter = { section: "", onlyUnknown: false };
    // One-level undo for "Nullstill" (an undo beats a confirm dialog: no modal,
    // no friction on the honest path, and a slip is still recoverable).
    let undoStash: Levels | null = null;
    let undoTimer: ReturnType<typeof setTimeout> | undefined;
    // The undo window outlives any single handler — clear it on the page swap
    // so it can't fire into a replaced deck (same shape as ThemeToggle).
    signal.addEventListener("abort", () => clearTimeout(undoTimer), {
      once: true,
    });

    // The queue holds positional indices (stable within one render); the
    // stored level is looked up through the card's content id.
    const levelOf = (i: number) => levels[cards[i].dataset.fcId!] ?? 0;

    const buildQueue = () => {
      let indices = [...Array(total).keys()];
      if (filter.section) {
        indices = indices.filter(
          (i) => cards[i].dataset.section === filter.section,
        );
      }
      if (filter.onlyUnknown) {
        indices = indices.filter((i) => levelOf(i) < 1);
      }
      // Not-known first, then original order — a stable study order. "Bland"
      // reshuffles the built queue in place (below), on demand.
      indices.sort((a, b) => levelOf(a) - levelOf(b) || a - b);
      queue = indices;
    };

    // Reflect each card's stored known state on the card (drives the badge).
    const paintBadges = () => {
      cards.forEach((c) => {
        c.dataset.level = String(levels[c.dataset.fcId!] ?? 0);
      });
    };

    const renderProgress = () => {
      const known = Object.values(levels).filter((v) => v >= 1).length;
      knownOut.textContent = String(known);
      // Keep the button while an undo is pending, or "Angre" vanishes the
      // moment the reset it undoes empties the levels.
      resetBtn.hidden = !undoStash && Object.keys(levels).length === 0;
      paintBadges();
    };

    // ---- The stack: current on top, next (and, deeper, previous) behind it ----
    // Every card shares one absolute box; its role decides transform, z, opacity
    // and interactivity. Roles change through the transition on .fc-card, so a
    // nav/rating slides the top card off while the next rises from behind.
    const REST = {
      current: "translate3d(0, 0, 0) scale(1)",
      next: "translate3d(0, 14px, 0) scale(0.95)",
      prev: "translate3d(0, 26px, 0) scale(0.9)",
    } as const;
    const roleZ = { current: "3", next: "2", prev: "1" } as const;
    const roleOpacity = { current: "1", next: "1", prev: "0.55" } as const;
    type Role = "current" | "next" | "prev";

    // Cards mid-fly-off (goTo → settle). They keep their own fling transform and
    // must not be re-targeted while airborne: layout() skips them, and nextCard()
    // won't hand a still-flying card to a drag. Scoped per deck (onPage re-runs on
    // each page swap), so it can't retain cards from a torn-down deck.
    const inFlight = new Set<HTMLElement>();

    const currentCard = () =>
      cards.find((c) => c.dataset.current === "true") ?? null;
    const nextCard = () => {
      const len = queue.length;
      if (len < 2) return null;
      const idx = queue[(pos + 1) % len];
      return (
        cards.find(
          (c) =>
            Number(c.dataset.index) === idx && !c.hidden && !inFlight.has(c),
        ) ?? null
      );
    };

    // Position one card for its role (or hide it). `snap` applies the position
    // with no transition — for first paint, and to fold a flown-off card back
    // into the pile without it sliding in.
    const applyRole = (
      c: HTMLButtonElement,
      role: Role | null,
      snap: boolean,
    ) => {
      if (!role) {
        c.hidden = true;
        c.dataset.flipped = "false";
        delete c.dataset.current;
        c.setAttribute("aria-hidden", "true");
        c.tabIndex = -1;
        c.style.transition = "";
        c.style.transform = "";
        c.style.opacity = "";
        c.style.zIndex = "";
        c.style.pointerEvents = "";
        syncFaces(c);
        return;
      }
      const isCurrent = role === "current";
      c.hidden = false;
      c.style.transition = snap ? "none" : "";
      c.style.zIndex = roleZ[role];
      c.style.opacity = roleOpacity[role];
      c.style.transform = REST[role];
      c.style.pointerEvents = isCurrent ? "" : "none";
      c.tabIndex = isCurrent ? 0 : -1;
      c.setAttribute("aria-hidden", isCurrent ? "false" : "true");
      c.dataset.flipped = "false";
      if (isCurrent) c.dataset.current = "true";
      else delete c.dataset.current;
      syncFaces(c);
      if (snap) {
        void c.offsetHeight; // commit the snapped position before re-enabling
        c.style.transition = "";
      }
    };

    // The role a card at deck index `i` should take at the current `pos`.
    const roleFor = (i: number): Role | null => {
      const len = queue.length;
      if (i === queue[pos]) return "current";
      if (len > 1 && i === queue[(pos + 1) % len]) return "next";
      if (len > 2 && i === queue[(pos - 1 + len) % len]) return "prev";
      return null;
    };

    // Assign every card its stack role. In-flight cards (and the optional
    // `except`) are left untouched so a fly-off isn't re-targeted mid-air; `snap`
    // is `true` for all, or a set of cards to position without animating.
    const layout = (
      opts: {
        except?: HTMLElement | null;
        snap?: Set<HTMLElement> | true;
      } = {},
    ) => {
      cards.forEach((c) => {
        if (c === opts.except || inFlight.has(c)) return;
        const snap = opts.snap === true || (opts.snap?.has(c) ?? false);
        applyRole(c, roleFor(Number(c.dataset.index)), snap);
      });
    };

    // Suppress the live announcement on the initial paint: page load isn't a
    // card change, and announcing the first card would talk over the page.
    let firstPaint = true;
    // Counters, announcement and empty-state copy — everything that isn't the
    // card geometry (layout() owns that).
    const postShow = () => {
      // Capture before the reset below: the empty-state announcement (further
      // down) also needs to suppress the initial paint, and firstPaint is already
      // false by the time that branch runs.
      const wasFirstPaint = firstPaint;
      const isEmpty = queue[pos] === undefined;
      deck.dataset.empty = isEmpty ? "true" : "false";
      if (!wasFirstPaint && !isEmpty) {
        const cur = currentCard();
        if (cur) announce(cur);
      }
      firstPaint = false;
      posOut.textContent = isEmpty ? "0" : String(pos + 1);
      if (totalOut) totalOut.textContent = String(queue.length);
      if (isEmpty) {
        // Say WHY the deck is empty. Every card in scope rated "kan" is the
        // earned end of a run — acknowledge it quietly; anything else is a
        // filter mismatch, and both get their next step spelled out.
        const scope = cards.filter(
          (c) => !filter.section || c.dataset.section === filter.section,
        );
        const allKnown =
          filter.onlyUnknown &&
          scope.length > 0 &&
          scope.every((c) => (levels[c.dataset.fcId!] ?? 0) >= 1);
        emptyBox.dataset.complete = String(allKnown);
        const title = allKnown
          ? `Alle ${scope.length} kort er markert som kan.`
          : "Ingen kort matcher filteret.";
        const hint = allKnown
          ? "Slå av «Kun ukjente» for å bla gjennom alle, eller nullstill og øv på nytt."
          : "Velg en annen seksjon, eller slå av «Kun ukjente».";
        emptyTitle.textContent = title;
        emptyHint.textContent = hint;
        // Reaching the empty state only swaps a data-attr and this copy — focus
        // doesn't move — so without mirroring it into the live region AT hears
        // nothing (WCAG 4.1.3). Skip the SSR first paint, which never lands empty
        // (filter state isn't persisted, so the deck always opens on all cards).
        if (!wasFirstPaint) liveEl.textContent = `${title} ${hint}`;
      }
    };

    // Full (re)render for the non-animated callers (filters, shuffle, reset,
    // first paint). Keeps focus on the deck if a card held it — hiding a focused
    // card would orphan focus to <main> and ring the whole page.
    const show = (opts: { instant?: boolean } = {}) => {
      const hadFocus = cards.includes(
        document.activeElement as HTMLButtonElement,
      );
      layout({ snap: opts.instant ? true : undefined });
      postShow();
      if (hadFocus && queue[pos] !== undefined) focusCard();
    };

    // Spring the dragged cards back to rest without touching flip state (a
    // sub-threshold drag must not silently un-flip the card in view).
    const springBack = () => {
      const cur = currentCard();
      if (cur) {
        cur.style.transition = "";
        cur.style.transform = REST.current;
      }
      const nxt = nextCard();
      if (nxt) {
        nxt.style.transition = "";
        nxt.style.transform = REST.next;
        nxt.style.opacity = roleOpacity.next;
      }
    };

    // Move to queue index `nextPos`, sliding the current card off toward `dir`
    // while the next card rises from behind. Degrades to an instant swap under
    // reduced motion, a single-card queue, or a no-op move.
    const goTo = (nextPos: number, dir: "left" | "right") => {
      const len = queue.length;
      if (!len) {
        pos = 0;
        show();
        return;
      }
      const wrapped = ((nextPos % len) + len) % len;
      const outgoing = currentCard();
      const hadFocus = cards.includes(
        document.activeElement as HTMLButtonElement,
      );
      if (prefersReduced() || len <= 1 || wrapped === pos || !outgoing) {
        pos = wrapped;
        show();
        return;
      }
      // Fly the outgoing card off the top of the stack. It keeps whatever
      // transform a drag left on it, so a committed swipe continues from the
      // finger rather than snapping to centre first. Mark it in-flight so a
      // second advance or a drag mid-flight can't re-target it.
      inFlight.add(outgoing);
      const sign = dir === "right" ? 1 : -1;
      outgoing.style.transition =
        "transform calc(var(--dur) * 1.3) var(--ease), opacity calc(var(--dur) * 1.3) var(--ease)";
      outgoing.style.transform = `translate3d(${sign * 118}%, 0, 0) rotate(${sign * 8}deg)`;
      outgoing.style.opacity = "0";
      outgoing.style.zIndex = "4";
      outgoing.style.pointerEvents = "none";
      outgoing.tabIndex = -1;
      outgoing.setAttribute("aria-hidden", "true");
      delete outgoing.dataset.current;
      // Promote the rest: the next card becomes current and rises to the front.
      pos = wrapped;
      layout({ except: outgoing });
      postShow();
      if (hadFocus) focusCard();
      // Once it has flown clear, fold the outgoing card into its new role behind
      // the pile with no animation, so it doesn't slide back in.
      let settled = false;
      const settle = () => {
        if (settled) return;
        settled = true;
        inFlight.delete(outgoing);
        outgoing.style.opacity = "";
        outgoing.style.zIndex = "";
        applyRole(outgoing, roleFor(Number(outgoing.dataset.index)), true);
      };
      // The inline transition animates transform AND opacity over the same
      // duration, and the opacity transitionend can fire first — a plain
      // { once:true } listener would be consumed by it and never settle on the
      // transform. Self-remove only once the transform end arrives; the 500ms
      // net still covers a hidden tab throttling transitionend away.
      const onEnd = (e: TransitionEvent) => {
        if (e.propertyName !== "transform") return;
        outgoing.removeEventListener("transitionend", onEnd);
        settle();
      };
      outgoing.addEventListener("transitionend", onEnd);
      setTimeout(settle, 500);
    };

    // Navigation is a stable carousel: the queue order only changes when the
    // reader changes a filter, shuffles or resets — never silently mid-session,
    // so next/prev always moves to a different card (unless only one matches).
    // Forward slides the card left; back slides it right.
    const advance = (delta: number) =>
      goTo(pos + delta, delta < 0 ? "right" : "left");

    // A committed swipe sets the fling direction so the card exits the way it was
    // thrown; a button/keyboard rating mirrors the verdict below.
    let pendingExit: "left" | "right" | null = null;

    const rate = (known: boolean) => {
      const idx = queue[pos];
      if (idx === undefined) return;
      // Read-modify-write, like the reading-progress path: re-read the stored
      // envelope (load() re-validates a missing/corrupt one the same way), apply
      // only this card's change, and persist the merge — so a second open tab
      // can't clobber the other's ratings by rewriting the whole key from a
      // load-time snapshot. Adopting the merged state also converges this tab's
      // view on ratings other tabs made, without rebuilding the queue under the
      // card in view (goTo() moves off it next anyway).
      levels = load().levels;
      levels[cards[idx].dataset.fcId!] = known ? 1 : 0;
      save(levels);
      renderProgress();
      const dir = pendingExit ?? (known ? "right" : "left");
      pendingExit = null;
      goTo(pos + 1, dir);
    };

    // Card click = flip
    cards.forEach((c) =>
      c.addEventListener("click", () => {
        c.dataset.flipped = c.dataset.flipped === "true" ? "false" : "true";
        syncFaces(c);
        announce(c);
      }),
    );

    deck
      .querySelector("[data-fc-prev]")!
      .addEventListener("click", () => advance(-1));
    deck
      .querySelector("[data-fc-next]")!
      .addEventListener("click", () => advance(1));
    deck
      .querySelectorAll<HTMLButtonElement>("[data-fc-rate]")
      .forEach((b) =>
        b.addEventListener("click", () => rate(b.dataset.fcRate === "1")),
      );

    // Swipe parity: right ≙ Kan, left ≙ Øv. A committed swipe just clicks the
    // matching button, so rating flows through the one rate() path and the
    // buttons stay the canonical (and only guaranteed) way to act — swipe is
    // never the sole route. During a drag the visible card follows the finger
    // and springs back on a sub-threshold release.
    const reviewBtn =
      deck.querySelector<HTMLButtonElement>('[data-fc-rate="0"]')!;
    const knownBtn =
      deck.querySelector<HTMLButtonElement>('[data-fc-rate="1"]')!;
    // A committed swipe's pointerup synthesises a trailing click on the card;
    // swallow that one so a rating doesn't also flip the card. onEnd sets this
    // per gesture (and the capture handler only acts on pointer clicks, detail
    // > 0), so it can neither leak onto a later tap nor eat a keyboard flip.
    let swallowFlip = false;
    // Largest |dx| the active drag reached, reset per gesture in onEnd. Below
    // the commit threshold a MOUSE release still synthesises a trailing click;
    // we swallow it only when the pointer travelled past a tap's slop, so a
    // moved-but-uncommitted drag springs back without that click un-flipping the
    // card, while a near-still tap keeps flip-on-release. (Touch mostly
    // suppresses the compat click past its own slop; should one slip through
    // just past TAP_SLOP, swallowing it is the same drag-not-tap outcome.)
    let dragMax = 0;
    // Travel under this (px) is a tap, not a drag.
    const TAP_SLOP = 10;
    // How far the top card may follow the finger before release — enough travel
    // to slide it clear and preview the next card rising behind it.
    const DRAG_CAP = SWIPE_THRESHOLD * 2;
    const cleanupSwipe = attachSwipe(stage, {
      onMove(dx) {
        dragMax = Math.max(dragMax, Math.abs(dx));
        // prefers-reduced-motion: no follow transform at all — the verdict
        // still commits on release.
        if (prefersReduced()) return;
        const card = currentCard();
        if (!card) return;
        // The top card follows the finger (capped, with a slight lean); the next
        // card rises from its peek toward the front in proportion, so a slow
        // drag literally previews it. transition:none keeps the follow 1:1.
        const clamped = Math.max(-DRAG_CAP, Math.min(DRAG_CAP, dx));
        const t = clamped / DRAG_CAP;
        card.style.transition = "none";
        card.style.transform = `translate3d(${clamped}px, 0, 0) rotate(${t * 4}deg)`;
        const nxt = nextCard();
        if (nxt) {
          const p = Math.min(1, Math.abs(dx) / DRAG_CAP);
          nxt.style.transition = "none";
          nxt.style.transform = `translate3d(0, ${14 * (1 - p)}px, 0) scale(${0.95 + 0.05 * p})`;
        }
      },
      onEnd(verdict) {
        // Rating hidden (all-known / filter-empty end state) ⇒ swipe does
        // nothing.
        const commit = verdict !== null && deck.dataset.empty !== "true";
        const moved = dragMax;
        dragMax = 0;
        if (commit) {
          // Leave the drag transform on the card: rate() → goTo() slides it off
          // from the finger, so there's no snap-back-then-fly flicker. pendingExit
          // just fixes the fling direction.
          pendingExit = verdict as "left" | "right";
          swallowFlip = true;
          (verdict === "right" ? knownBtn : reviewBtn).click();
          return;
        }
        // Sub-threshold / vetoed as a scroll: spring the cards back to rest, and
        // swallow the mouse's trailing click when the pointer actually moved
        // (past TAP_SLOP) — a spring-back must not ride that click into an
        // un-flip. A near-still tap leaves swallowFlip false so it still flips.
        swallowFlip = moved > TAP_SLOP;
        springBack();
      },
    });
    signal.addEventListener("abort", cleanupSwipe, { once: true });
    // Capture phase on the stage runs before the card's own (bubble) flip
    // handler, so a committed swipe's trailing click is stopped before it flips.
    // detail === 0 spares keyboard/programmatic activations.
    stage.addEventListener(
      "click",
      (e) => {
        if (!swallowFlip || e.detail === 0) return;
        swallowFlip = false;
        e.stopPropagation();
        e.preventDefault();
      },
      { capture: true, signal },
    );

    resetBtn.addEventListener("click", () => {
      if (undoStash) {
        // "Angre": restore the stashed ratings.
        clearTimeout(undoTimer);
        levels = undoStash;
        undoStash = null;
        resetBtn.textContent = resetLabel;
        save(levels);
        buildQueue();
        pos = 0;
        renderProgress();
        show();
        return;
      }
      undoStash = levels;
      levels = {};
      save(levels);
      buildQueue();
      pos = 0;
      renderProgress();
      show();
      // The button itself becomes the undo affordance for a beat; the label
      // swap is also what a screen reader hears on the still-focused control.
      resetBtn.textContent = "Angre";
      undoTimer = setTimeout(() => {
        undoStash = null;
        resetBtn.textContent = resetLabel;
        // renderProgress() hides the button once the window closes (levels is
        // empty) — if it still holds keyboard focus, hiding it would orphan
        // focus to <body>. Hand focus to the current card first, mirroring
        // show()'s refocus guard.
        const hadFocus = document.activeElement === resetBtn;
        renderProgress();
        if (hadFocus && resetBtn.hidden) {
          focusCard();
        }
      }, 8000);
    });

    // Section filter — a chip row (desktop) and a native <select> (phone) drive
    // the same filter; apply keeps both reflecting the chosen section so a
    // viewport change never shows a stale selection.
    const sectionChips = [
      ...deck.querySelectorAll<HTMLButtonElement>("[data-fc-section]"),
    ];
    const sectionSelect = deck.querySelector<HTMLSelectElement>(
      "[data-fc-section-select]",
    );
    const applySectionFilter = (value: string) => {
      filter.section = value;
      sectionChips.forEach((c) => {
        const on = (c.dataset.fcSection ?? "") === value;
        c.classList.toggle("active", on);
        c.setAttribute("aria-pressed", on ? "true" : "false");
      });
      if (sectionSelect && sectionSelect.value !== value) {
        sectionSelect.value = value;
      }
      buildQueue();
      pos = 0;
      show();
    };
    sectionChips.forEach((chip) => {
      chip.addEventListener("click", () =>
        applySectionFilter(chip.dataset.fcSection ?? ""),
      );
    });
    sectionSelect?.addEventListener("change", () =>
      applySectionFilter(sectionSelect.value),
    );

    // Unknown-only toggle
    const unknownBtn =
      deck.querySelector<HTMLButtonElement>("[data-fc-unknown]");
    if (unknownBtn) {
      unknownBtn.addEventListener("click", () => {
        filter.onlyUnknown = !filter.onlyUnknown;
        unknownBtn.classList.toggle("active", filter.onlyUnknown);
        unknownBtn.setAttribute("aria-pressed", String(filter.onlyUnknown));
        buildQueue();
        pos = 0;
        show();
      });
    }

    // Shuffle toggle
    const shuffleBtn =
      deck.querySelector<HTMLButtonElement>("[data-fc-shuffle]");
    // The confirmation glyph outlives the click handler — clear it on the page
    // swap so it can't fire into a replaced deck (same shape as undoTimer).
    let shuffleTimer: ReturnType<typeof setTimeout> | undefined;
    signal.addEventListener("abort", () => clearTimeout(shuffleTimer), {
      once: true,
    });
    if (shuffleBtn) {
      // "Bland" is a one-shot action: each click reshuffles the current cards
      // into a fresh random order (not a sticky sorted/shuffled toggle).
      shuffleBtn.addEventListener("click", () => {
        for (let i = queue.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [queue[i], queue[j]] = [queue[j], queue[i]];
        }
        pos = 0;
        show();
        // Cross-fade the shuffle glyph to a check for a beat, so a one-shot
        // action that changes off-screen order still confirms it landed.
        shuffleBtn.dataset.shuffled = "true";
        clearTimeout(shuffleTimer);
        shuffleTimer = setTimeout(() => {
          delete shuffleBtn.dataset.shuffled;
        }, 1100);
      });
    }

    // A mouse click leaves focus on the clicked control, and a focused button
    // natively re-activates on Space — the deck's flip key. After a pointer
    // click on any deck control, hand focus to the current card so the next
    // Space flips it. Keyboard activation (detail 0) keeps focus where the
    // user tabbed. Bubble phase: the control's own handler has already run,
    // so the visible card is the post-action one.
    deck.addEventListener("click", (e) => {
      if (e.detail === 0) return;
      const btn = (e.target as Element).closest("button");
      if (!btn || btn.dataset.fcCard !== undefined) return;
      focusCard();
    });

    // Keyboard: Space/Enter=flip, ←/→=navigate, 1=Øv, 2=Kan.
    // Every handled key also hands focus to the current card: the card is what
    // the keys control, so it — not whatever container the last click landed
    // focus on (e.g. the tabindex="-1" <main>, whose UA focus ring frames the
    // whole page) — should carry the keyboard highlight.
    document.addEventListener(
      "keydown",
      (e) => {
        if (e.metaKey || e.ctrlKey || e.altKey) return;
        const active = document.activeElement;
        const tag = (active?.tagName ?? "").toLowerCase();
        if (tag === "input" || tag === "textarea" || tag === "select") return;
        if (
          [...document.querySelectorAll("dialog")].some(
            (d) => (d as HTMLDialogElement).open,
          )
        )
          return;
        const cur = currentCard();
        if (!cur) return;
        if (e.key === " " || e.key === "Enter") {
          // A focused button (the card itself or a control) already activates on
          // Space/Enter natively — don't also flip here, or the two cancel out.
          if (active instanceof HTMLButtonElement) return;
          // Enter on a focused link is navigation, not a deck key.
          if (e.key === "Enter" && active instanceof HTMLAnchorElement) return;
          e.preventDefault();
          cur.dataset.flipped =
            cur.dataset.flipped === "true" ? "false" : "true";
          syncFaces(cur);
          announce(cur);
          focusCard();
        } else if (e.key === "ArrowLeft") {
          e.preventDefault();
          advance(-1);
          focusCard();
        } else if (e.key === "ArrowRight") {
          e.preventDefault();
          advance(1);
          focusCard();
        } else if (e.key === "1") {
          e.preventDefault();
          rate(false);
          focusCard();
        } else if (e.key === "2") {
          e.preventDefault();
          rate(true);
          focusCard();
        }
      },
      { signal },
    );

    buildQueue();
    renderProgress();
    show({ instant: true });
  });
</script>
