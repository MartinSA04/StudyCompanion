---
import type { Course } from "../schema.ts";
import {
  daysUntil,
  formatExamCountdown,
  EXAM_PAST_LABEL,
} from "../lib/countdown.ts";
import { formatDate } from "../lib/dates.ts";

/**
 * A summary of the UPCOMING exam — date + countdown, start time, duration,
 * format and permitted aids — shown atop the Eksamen tool page so a student
 * lands on the facts of the exam they're sitting before the past-paper list.
 *
 * Pure presentation of `course.exam`: renders only the fields that are present,
 * and nothing at all if `exam` carries none of them. When it does render, a
 * quiet footer line links `exam.authorityUrl` (Studentweb by default) as the
 * portal that owns the authoritative exam facts. The countdown pill SSRs a
 * build-time snapshot and the script below re-derives it against the viewer's
 * clock, so a site built a week early still says "i dag" on exam morning.
 */
interface Props {
  exam: NonNullable<Course["exam"]>;
  language?: string;
  /**
   * Text for the Studentweb authority note. Defaults to the framework's
   * Norwegian string; the Eksamen page passes `course.ui.examAuthorityNote` so a
   * per-course override reaches this surface too.
   */
  authorityNote?: string;
}
const {
  exam,
  language = "nb",
  authorityNote = "Offisiell eksamensinformasjon finnes i Studentweb",
} = Astro.props;

const examDate = exam.date ? formatDate(exam.date, language, "full") : null;
const daysToExam = exam.date ? daysUntil(exam.date) : null;

// Norwegian chrome countdown, matching the overview exam card's wording.
const countdown =
  daysToExam == null
    ? null
    : daysToExam < 0
      ? EXAM_PAST_LABEL
      : formatExamCountdown(daysToExam);

const durationStr = (() => {
  const m = exam.durationMinutes;
  if (m == null) return null;
  const h = Math.floor(m / 60);
  const min = m % 60;
  if (h && min) return `${h} t ${min} min`;
  if (h) return `${h} ${h === 1 ? "time" : "timer"}`;
  return `${min} min`;
})();

const facts = [
  // Start time is a VERBATIM string (schema keeps it off Date to avoid the
  // UTC-midnight print bug); it renders as-is next to the date.
  exam.time && { label: "Tid", value: exam.time },
  durationStr && { label: "Varighet", value: durationStr },
  exam.format && { label: "Form", value: exam.format },
  exam.aids && { label: "Hjelpemidler", value: exam.aids },
].filter(Boolean) as { label: string; value: string }[];

const hasContent = Boolean(examDate) || facts.length > 0;
---

{
  hasContent && (
    <div class="exam-summary">
      {examDate && (
        <div class="exam-when">
          <span class="exam-when-label sc-kicker">Eksamensdato</span>
          <span class="exam-when-date">{examDate}</span>
          {countdown && (
            <span
              class="sc-countdown"
              data-past={daysToExam! < 0}
              data-exam-countdown={exam.date!.toISOString()}
            >
              {countdown}
            </span>
          )}
        </div>
      )}
      {facts.length > 0 && (
        <dl class="exam-facts">
          {facts.map((f) => (
            <div class="exam-fact">
              <dt>{f.label}</dt>
              <dd>{f.value}</dd>
            </div>
          ))}
        </dl>
      )}
      <p class="exam-authority">
        <a href={exam.authorityUrl} target="_blank" rel="noopener noreferrer">
          {authorityNote}
        </a>
      </p>
    </div>
  )
}

<style>
  .exam-summary {
    margin-bottom: var(--space-6);
    background: var(--accent-soft);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .exam-when {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2) var(--space-3);
    padding: var(--space-4);
  }
  /* Mono uppercase kicker recipe comes from .sc-kicker; size + tone local.
     (.exam-fact dt is a normal-weight mono label, not this semibold kicker.) */
  .exam-when-label {
    flex-basis: 100%;
    font-size: var(--text-xs);
    color: var(--accent-ink);
  }
  .exam-when-date {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    color: var(--fg);
  }
  .exam-facts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1px;
    margin: 0;
    background: var(--border);
    border-top: 1px solid var(--border);
  }
  /* When there's no date block, the facts grid is the whole panel — no top rule. */
  .exam-when + .exam-facts {
    border-top: 1px solid var(--border);
  }
  /* Cells share the card's tint so the facts strip reads as one surface; the
     1px gap over --border keeps the hairline grid between them. */
  .exam-fact {
    margin: 0;
    padding: var(--space-3) var(--space-4);
    background: var(--accent-soft);
  }
  .exam-fact dt {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking);
    color: var(--muted);
    margin-bottom: var(--space-1);
  }
  .exam-fact dd {
    margin: 0;
    color: var(--fg);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
  }
  /* Studentweb authority note: a quiet footer line naming the portal that owns
     the authoritative exam facts. Fine print, not a callout. */
  .exam-authority {
    margin: 0;
    padding: var(--space-3) var(--space-4);
    border-top: 1px solid var(--border);
    font-size: var(--text-xs);
    line-height: var(--leading-snug);
    color: var(--muted);
  }
  /* Accent-ink so the Studentweb line reads as a link on the tinted panel
     (matching .exam-when-label), while keeping the fine-print size. */
  .exam-authority a {
    color: var(--accent-ink);
    text-decoration: none;
  }
  .exam-authority a:hover {
    text-decoration: underline;
  }
</style>

<script>
  import { onPage } from "../lib/pageLifecycle.ts";
  import { refreshExamCountdowns } from "../lib/examCountdown.ts";
  // The pill's phrase (and its data-past muted state) is a build-time
  // snapshot; recompute per (re)load against the viewer's clock so the pill
  // flips to "i dag"/"avholdt" on the right morning (lib/examCountdown.ts).
  onPage(() => refreshExamCountdowns());
</script>
