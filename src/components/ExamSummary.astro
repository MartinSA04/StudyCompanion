---
import type { Course } from "../schema.ts";

/**
 * A summary of the UPCOMING exam — date + build-time countdown, duration,
 * format and permitted aids — shown atop the Eksamen tool page so a student
 * lands on the facts of the exam they're sitting before the past-paper list.
 *
 * Pure presentation of the existing `course.exam` data (no schema change);
 * renders only the fields that are present, and nothing at all if `exam`
 * carries none of them.
 */
interface Props {
  exam: NonNullable<Course["exam"]>;
  language?: string;
}
const { exam, language = "nb" } = Astro.props;

const dateFmt = new Intl.DateTimeFormat(language, { dateStyle: "full" });
const examDate = exam.date ? dateFmt.format(exam.date) : null;
const daysToExam = exam.date
  ? Math.ceil((exam.date.getTime() - Date.now()) / 86_400_000)
  : null;

// Norwegian chrome countdown, matching the overview exam card's wording.
const countdown =
  daysToExam == null
    ? null
    : daysToExam < 0
      ? "avholdt"
      : daysToExam === 0
        ? "i dag"
        : daysToExam === 1
          ? "i morgen"
          : `om ${daysToExam} dager`;

const durationStr = (() => {
  const m = exam.durationMinutes;
  if (m == null) return null;
  const h = Math.floor(m / 60);
  const min = m % 60;
  if (h && min) return `${h} t ${min} min`;
  if (h) return `${h} ${h === 1 ? "time" : "timer"}`;
  return `${min} min`;
})();

const facts = [
  durationStr && { label: "Varighet", value: durationStr },
  exam.format && { label: "Form", value: exam.format },
  exam.aids && { label: "Hjelpemidler", value: exam.aids },
].filter(Boolean) as { label: string; value: string }[];

const hasContent = Boolean(examDate) || facts.length > 0;
---

{
  hasContent && (
    <div class="exam-summary">
      {examDate && (
        <div class="exam-when">
          <span class="exam-when-label">Eksamensdato</span>
          <span class="exam-when-date">{examDate}</span>
          {countdown && (
            <span class="exam-when-count" data-past={daysToExam! < 0}>
              {countdown}
            </span>
          )}
        </div>
      )}
      {facts.length > 0 && (
        <dl class="exam-facts">
          {facts.map((f) => (
            <div class="exam-fact">
              <dt>{f.label}</dt>
              <dd>{f.value}</dd>
            </div>
          ))}
        </dl>
      )}
    </div>
  )
}

<style>
  .exam-summary {
    margin-bottom: var(--space-6);
    background: var(--accent-soft);
    border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--border));
    border-left: 3px solid var(--accent);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .exam-when {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2) var(--space-3);
    padding: var(--space-4);
  }
  .exam-when-label {
    flex-basis: 100%;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--accent);
  }
  .exam-when-date {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    color: var(--fg);
  }
  .exam-when-count {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--on-strong);
    background: var(--accent);
    border-radius: var(--radius-pill);
    padding: 0.1em 0.7em;
  }
  /* A past exam's countdown reads as a muted note, not an urgent accent pill. */
  .exam-when-count[data-past="true"] {
    color: var(--muted);
    background: transparent;
    border: 1px solid var(--border-strong);
  }
  .exam-facts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1px;
    margin: 0;
    background: var(--border);
    border-top: 1px solid var(--border);
  }
  /* When there's no date block, the facts grid is the whole panel — no top rule. */
  .exam-when + .exam-facts {
    border-top: 1px solid var(--border);
  }
  .exam-fact {
    margin: 0;
    padding: var(--space-3) var(--space-4);
    background: var(--card);
  }
  .exam-fact dt {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--muted);
    margin-bottom: var(--space-1);
  }
  .exam-fact dd {
    margin: 0;
    color: var(--fg);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
  }
</style>
