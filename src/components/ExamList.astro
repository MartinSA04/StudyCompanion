---
import type { ExamPaper } from "../schema.ts";
import Icon from "./Icon.astro";

/**
 * A list of past exam papers with optional dates and solution links. Rendered
 * from `course.exams`, newest first.
 */
interface Props {
  exams: ExamPaper[];
  language?: string;
  /** Optional link to the full archive, rendered as the final list row. */
  archive?: { url: string; label: string };
}
const { exams, language = "nb", archive } = Astro.props;

const fmt = new Intl.DateTimeFormat(language, { dateStyle: "medium" });
const sorted = [...exams].sort((a, b) => {
  const ta = a.date ? a.date.getTime() : 0;
  const tb = b.date ? b.date.getTime() : 0;
  return tb - ta;
});
---

<ul class="exam-list">
  {
    sorted.map((e) => (
      <li class="exam-row">
        <div class="exam-main">
          <span class="exam-label">{e.label}</span>
          {e.date && <span class="exam-date">{fmt.format(e.date)}</span>}
        </div>
        <div class="exam-links">
          {e.url && (
            <a href={e.url} target="_blank" rel="noopener noreferrer">
              Oppgave
              <Icon name="external" size={14} />
            </a>
          )}
          {e.solutionUrl && (
            <a
              href={e.solutionUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="exam-solution"
            >
              Løsning
              <Icon name="external" size={14} />
            </a>
          )}
        </div>
      </li>
    ))
  }
  {
    archive && (
      <li class="exam-row exam-archive">
        <a
          class="exam-archive-link"
          href={archive.url}
          target="_blank"
          rel="noopener noreferrer"
        >
          <Icon name="archive" size={15} />
          <span>{archive.label}</span>
          <Icon name="external" size={14} />
        </a>
      </li>
    )
  }
</ul>

<style>
  .exam-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  /* No row-level hover: a row isn't clickable (it holds up to two links, or
     none), so highlighting the whole row on hover falsely implied it was. The
     actual targets — the Oppgave/Løsning/archive links — carry their own hover. */
  .exam-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--border);
  }
  .exam-row:last-child {
    border-bottom: 0;
  }
  .exam-main {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .exam-label {
    font-weight: var(--weight-medium);
  }
  .exam-date {
    font-size: var(--text-sm);
    color: var(--muted);
  }
  .exam-links {
    display: flex;
    gap: var(--space-3);
    flex: none;
    font-size: var(--text-sm);
  }
  .exam-links a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    text-decoration: none;
    white-space: nowrap;
  }
  .exam-links a:hover {
    text-decoration: underline;
  }
  .exam-solution {
    color: var(--muted);
    transition: color var(--dur-fast) var(--ease);
  }
  .exam-solution:hover {
    color: var(--accent);
  }

  /* Final row: a link out to the complete archive. Tinted to read as a
     "see also" footer of the list rather than another exam paper. */
  .exam-archive {
    background: var(--card);
  }
  .exam-archive-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--accent);
  }
  .exam-archive-link:hover {
    text-decoration: underline;
  }
  .exam-archive-link :global(svg) {
    color: var(--accent);
  }
</style>
