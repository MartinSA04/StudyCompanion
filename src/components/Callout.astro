---
/**
 * An admonition box. `type` selects the semantic tone (note/tip/warning).
 * Body is slotted MDX, so it can contain math, lists, links, etc. A thin wrapper
 * over the shared `<Admonition>` primitive — the tone reads from a mono kicker,
 * not a coloured spine.
 */
import Admonition from "./Admonition.astro";
import { assertOneOf } from "../lib/assertProp.ts";

interface Props {
  type?: "note" | "tip" | "warning";
  title?: string;
}
const { type = "note", title } = Astro.props;

const defaults: Record<NonNullable<Props["type"]>, string> = {
  note: "Merk",
  tip: "Tips",
  warning: "Advarsel",
};
const icons = { note: "info", tip: "star", warning: "alert-triangle" } as const;
// MDX isn't type-checked: a typo'd type would otherwise render a blank kicker.
assertOneOf(type, Object.keys(defaults), "Callout", "type");
---

<Admonition tone={type} icon={icons[type]} title={title ?? defaults[type]}>
  <slot />
</Admonition>
