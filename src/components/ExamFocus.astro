---
/**
 * What to prioritise for the exam ("eksamensfokus"). A warm-tinted block that
 * flags exam-critical material distinctly from notes/tips. Body is slotted MDX.
 * Subject-agnostic — the heading is a prop.
 */
import Admonition from "./Admonition.astro";

interface Props {
  title?: string;
}
const { title = "Eksamensfokus" } = Astro.props;
---

<Admonition tone="exam" icon="flag" title={title}>
  <slot />
</Admonition>
