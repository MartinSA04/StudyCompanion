---
/**
 * End-of-module recap ("Hovedpunkter") — a checklist-styled summary block, in a
 * distinct violet tint from notes/tips/goals/exam so a module's closer reads
 * consistently. Body is slotted MDX, normally a bullet list; its items get a
 * check marker. Subject-agnostic — the heading is a prop.
 */
import Admonition from "./Admonition.astro";

interface Props {
  title?: string;
}
const { title = "Hovedpunkter" } = Astro.props;
---

<Admonition tone="takeaways" icon="list-checks" title={title}>
  <div class="takeaways-list"><slot /></div>
</Admonition>

<style>
  /* A check glyph, alpha-masked so it tints with the block colour. */
  .takeaways-list {
    --check: url("data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'><path d='M20 6 9 17l-5-5'/></svg>");
  }
  /* Direct children only: the checklist treatment belongs to the top-level
     <ul> — a nested sub-list keeps its prose bullets instead of a second
     check, and an accidental <ol> isn't half-styled. */
  .takeaways-list > :global(ul) {
    margin-bottom: 0;
    padding-left: 0;
    list-style: none;
  }
  .takeaways-list > :global(ul) > :global(li) {
    position: relative;
    margin-block: 0.35em;
    padding-left: 1.7em;
  }
  .takeaways-list > :global(ul) > :global(li)::before {
    content: "";
    position: absolute;
    inset-inline-start: 0;
    top: 0.28em;
    width: 1.05em;
    height: 1.05em;
    background: var(--violet);
    -webkit-mask: var(--check) center / contain no-repeat;
    mask: var(--check) center / contain no-repeat;
  }
</style>
