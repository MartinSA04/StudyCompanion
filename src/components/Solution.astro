---
import Icon from "./Icon.astro";

/**
 * A collapsible worked solution, used inside <Example> (closed by default). Put
 * the final <Answer> inside it so the answer stays hidden until the reader
 * reveals the solution. Body is slotted MDX.
 */
interface Props {
  /** Summary text. Default "Vis løsning". */
  label?: string;
  /** Reveal by default. */
  open?: boolean;
}
const { label = "Vis løsning", open = false } = Astro.props;
---

<details class="solution sc-panel" open={open}>
  <summary class="sc-summary">
    <span class="solution-chev sc-chev" aria-hidden="true">
      <Icon name="chevron-right" size={13} />
    </span>
    {label}
  </summary>
  <div class="solution-body"><slot /></div>
</details>

<style>
  /* Float (fill + shadow) comes from the shared .sc-panel; this small nested
     reveal keeps the tighter --radius-sm. base.css recesses it when nested. */
  .solution {
    margin-top: var(--space-4);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }
  /* Summary type, hover, marker-hide, [open] divider and chevron come from the
     shared .sc-summary / .sc-chev primitives; only the padding is local. */
  .solution > summary {
    padding: var(--space-2) var(--space-3);
  }
  .solution-body {
    padding: var(--space-3);
  }
  .solution-body > :global(:last-child) {
    margin-bottom: 0;
  }
</style>
