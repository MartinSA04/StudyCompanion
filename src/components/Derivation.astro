---
/**
 * A collapsible derivation / worked steps block. Native <details>, so it works
 * with no JS. Author the steps as slotted MDX (often a sequence of <Formula>).
 */
interface Props {
  title?: string;
  open?: boolean;
}
const { title = "Utledning", open = false } = Astro.props;
import Icon from "./Icon.astro";
---

<details class="derivation sc-panel" open={open}>
  <summary class="sc-summary">
    <span class="derivation-chevron sc-chev" aria-hidden="true">
      <Icon name="chevron-right" size={13} />
    </span>
    <span>{title}</span>
  </summary>
  <div class="derivation-body"><slot /></div>
</details>

<style>
  /* Float (fill + shadow + radius) comes from the shared .sc-panel. No
     overflow:hidden — it clipped descendant focus outlines; the summary
     rounds itself instead. */
  .derivation {
    margin-block: var(--space-5);
  }
  /* Summary type, hover, marker-hide, [open] divider and chevron come from the
     shared .sc-summary / .sc-chev primitives; only the padding is local.
     Concrete token, not `inherit`: a <summary> is slotted into the <details>
     UA shadow tree, so `inherit` resolves to the slot's 0, not the panel's
     radius (the panel's own comes from .sc-panel). */
  .derivation > summary {
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius);
  }
  .derivation[open] > summary {
    border-end-start-radius: 0;
    border-end-end-radius: 0;
  }
  .derivation-body {
    padding: var(--space-2) var(--space-4) var(--space-4);
  }
  .derivation-body :global(> :last-child) {
    margin-bottom: 0;
  }
</style>
