---
/**
 * A collapsible derivation / worked steps block. Native <details>, so it works
 * with no JS. Author the steps as slotted MDX (often a sequence of <Formula>).
 */
interface Props {
  title?: string;
  open?: boolean;
}
const { title = "Utledning", open = false } = Astro.props;
import Icon from "./Icon.astro";
---

<details class="derivation sc-panel" open={open}>
  <summary class="sc-summary">
    <span class="derivation-chevron sc-chev" aria-hidden="true">
      <Icon name="chevron-right" size={13} />
    </span>
    <span>{title}</span>
  </summary>
  <div class="derivation-body"><slot /></div>
</details>

<style>
  /* Float (fill + shadow + radius) comes from the shared .sc-panel. */
  .derivation {
    margin-block: var(--space-5);
    overflow: hidden;
  }
  /* Summary type, hover, marker-hide, [open] divider and chevron come from the
     shared .sc-summary / .sc-chev primitives; only the padding is local. */
  .derivation > summary {
    padding: var(--space-3) var(--space-4);
  }
  .derivation-body {
    padding: var(--space-2) var(--space-4) var(--space-4);
  }
  .derivation-body :global(> :last-child) {
    margin-bottom: 0;
  }
</style>
