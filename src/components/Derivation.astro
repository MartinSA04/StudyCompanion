---
/**
 * A collapsible derivation / worked steps block. Native <details>, so it works
 * with no JS. Author the steps as slotted MDX (often a sequence of <Formula>).
 */
interface Props {
  title?: string;
  open?: boolean;
}
const { title = "Utledning", open = false } = Astro.props;
import Icon from "./Icon.astro";
---

<details class="derivation" open={open}>
  <summary>
    <span class="derivation-chevron" aria-hidden="true">
      <Icon name="chevron-right" size={13} />
    </span>
    <span>{title}</span>
  </summary>
  <div class="derivation-body"><slot /></div>
</details>

<style>
  .derivation {
    margin-block: var(--space-5);
    border-radius: var(--radius);
    background: var(--bg-elevated);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }
  summary {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: background-color var(--dur-fast) var(--ease);
  }
  summary::-webkit-details-marker {
    display: none;
  }
  /* Ink overlay hover — the panel sits on --card-nested (== --card-hover). */
  summary:hover {
    background: color-mix(in srgb, var(--fg) 6%, transparent);
  }
  .derivation[open] > summary {
    border-bottom: 1px solid var(--border);
  }
  .derivation-chevron {
    display: inline-flex;
    transition: transform var(--dur-fast) var(--ease);
  }
  .derivation[open] .derivation-chevron {
    transform: rotate(90deg);
  }
  .derivation-body {
    padding: var(--space-2) var(--space-4) var(--space-4);
  }
  .derivation-body :global(> :last-child) {
    margin-bottom: 0;
  }
</style>
