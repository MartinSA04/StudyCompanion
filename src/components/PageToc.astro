---
/**
 * In-page "on this page" TOC, shown when the section has at least `threshold`
 * h2/h3 headings. Two placements chosen by `variant`:
 *  - "rail": the primary — a STICKY right-hand rail (docs-style), so the
 *    scroll-spy "you are here" marker stays visible while you read.
 *  - "inline": a jump list at the top of the content, the narrow-screen fallback
 *    (the rail needs horizontal room it doesn't have below ~1280px).
 * [slug].astro renders both; CSS shows exactly one per breakpoint. The active
 * heading (scroll-spy) lights an accent segment on the rail line.
 *
 * Also injects a hover "#" deep-link anchor into every h2/h3 in .prose.
 */
interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  headings: Heading[];
  label?: string;
  threshold?: number;
  variant?: "rail" | "inline";
}
const {
  headings,
  label = "Innhold",
  threshold = 3,
  variant = "inline",
} = Astro.props;
const visible = headings.filter((h) => h.depth === 2 || h.depth === 3);
const show = visible.length >= threshold;
---

{
  show && (
    <nav class={`page-toc is-${variant}`} aria-label={label}>
      <p class="toc-label">{label}</p>
      <ol class="toc-list">
        {visible.map((h) => (
          <li class={`toc-item toc-h${h.depth}`}>
            <a class="toc-link" href={`#${h.slug}`}>
              {h.text}
            </a>
          </li>
        ))}
      </ol>
    </nav>
  )
}

<style>
  /* Inline (narrow-screen) placement sits at the top of the content; it yields to
     the sticky rail once there's room for it. */
  .is-inline {
    margin: 0 0 var(--space-6);
  }
  @media (min-width: 1440px) {
    .is-inline {
      display: none;
    }
  }

  .toc-label {
    margin: 0 0 var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--faint);
  }
  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    /* A quiet rail line down the left; the active item lights its own segment. */
    border-left: 1px solid var(--border);
  }
  .toc-item {
    margin: 0;
  }
  .toc-link {
    display: block;
    border-left: 2px solid transparent;
    margin-left: -1px; /* sit the accent segment over the rail line */
    padding: var(--space-1) 0 var(--space-1) var(--space-3);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    color: var(--muted);
    text-decoration: none;
    transition:
      color var(--dur-fast) var(--ease),
      border-color var(--dur-fast) var(--ease);
  }
  .toc-h3 .toc-link {
    padding-left: calc(var(--space-3) + var(--space-4));
    color: var(--faint);
  }
  .toc-link:hover {
    color: var(--fg);
  }
  .toc-link.active {
    border-left-color: var(--accent);
    color: var(--accent);
    font-weight: var(--weight-medium);
  }
</style>

<script>
  import { onPage } from "../lib/pageLifecycle.ts";
  onPage((signal) => {
    // Scroll-spy: highlight the last heading scrolled past the topbar. Both the
    // rail and the inline copy carry the same links, so drive them together.
    const tocs = [...document.querySelectorAll<HTMLElement>(".page-toc")];
    if (tocs.length) {
      const ids = [
        ...tocs[0].querySelectorAll<HTMLAnchorElement>(".toc-link"),
      ].map((l) => l.getAttribute("href")!.slice(1));
      const targets = ids.map((id) => document.getElementById(id));

      const update = () => {
        let active = -1;
        targets.forEach((el, i) => {
          if (el && el.getBoundingClientRect().top <= 90) active = i;
        });
        tocs.forEach((toc) => {
          const links = [
            ...toc.querySelectorAll<HTMLAnchorElement>(".toc-link"),
          ];
          links.forEach((l, i) => l.classList.toggle("active", i === active));
        });
      };

      window.addEventListener("scroll", update, { passive: true, signal });
      update();
    }

    // Inject hover "#" anchor links into every h2/h3 inside .prose. The guard
    // keeps a re-run from appending a second anchor.
    document
      .querySelectorAll<HTMLElement>(".prose :is(h2, h3)")
      .forEach((h) => {
        if (!h.id || h.querySelector(".heading-anchor")) return;
        const a = document.createElement("a");
        a.href = "#" + h.id;
        a.className = "heading-anchor";
        a.setAttribute(
          "aria-label",
          "Direkte lenke til " + h.textContent?.trim(),
        );
        a.textContent = "#";
        h.appendChild(a);
      });
  });
</script>
