---
/**
 * Scaffold for course-provided interactive simulations.
 *
 * The framework owns the chrome (title, the stage, a controls slot, caption),
 * lazy-mounts on scroll, and dynamic-imports a simulation module that lives in
 * the COURSE repo's `public/sims/`. This keeps course-specific code out of the
 * framework.
 *
 * Two render hosts (`host` prop):
 *  - "canvas" (default): a DPR-aware <canvas> + 2D context. Coordinates are CSS
 *    pixels (the context is pre-scaled for devicePixelRatio).
 *  - "dom": an empty themed element the module renders SVG/HTML into — for
 *    visualizations that want crisp labels / selectable text (graphs, trees).
 *    For *stepped* algorithm traces prefer the higher-level <Stepper> (5.2).
 *
 * Course module contract (e.g. course `public/sims/thin-lens.js`):
 *
 *     export default function init(api) {
 *       const { ctx, controls, getSize, onResize } = api;   // canvas host
 *       function draw() { const { w, h } = getSize(); ...paint with ctx... }
 *       onResize(draw);   // framework calls this after a resize / theme change
 *       draw();
 *     }
 *
 * `api` = {
 *   controls, getSize: () => ({ w, h }), onResize: (cb) => void,
 *   codeBlock: (id?) => { setActiveLine, setActiveLines, clear } | null,
 *   // host="canvas": canvas, ctx     host="dom": stage (an element)
 * }.
 *
 * `codeBlock(id)` (ROADMAP 3.8) returns a controller for a course <CodeBlock>
 * (matched by its `id`, or the first one when omitted), so a sim can step the
 * highlighted line(s) in lockstep with what it paints. Returns null if none.
 */
import PanelHeader from "./PanelHeader.astro";

interface Props {
  /** Path to the course-provided ES module, e.g. "/sims/thin-lens.js". */
  src: string;
  title?: string;
  caption?: string;
  /** CSS height of the stage in px. */
  height?: number;
  /** Render host: a 2D canvas (default) or a DOM/SVG element. */
  host?: "canvas" | "dom";
}
const { src, title, caption, height = 300, host = "canvas" } = Astro.props;
---

<figure
  class="simulation"
  data-sim
  data-sim-src={src}
  data-sim-height={height}
  data-sim-host={host}
>
  {title && <PanelHeader dot title={title} titleSize="lg" align="center" />}
  <div class="sim-stage">
    {
      host === "dom" ? (
        <div
          class="sim-host"
          role="img"
          aria-label={title ?? "Interaktiv visning"}
          style={`min-height:${height}px`}
        />
      ) : (
        <canvas
          class="sim-canvas"
          role="img"
          aria-label={title ?? "Interaktiv simulering"}
          style={`min-height:${height}px`}
        />
      )
    }
    <noscript>
      <p class="sim-fallback">Interaktiv simulering krever JavaScript.</p>
    </noscript>
  </div>
  <div class="sim-controls"></div>
  {caption && <p class="sim-caption">{caption}</p>}
</figure>

<style>
  .simulation {
    margin-block: var(--space-5);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    background: var(--card);
    overflow: hidden;
  }
  .sim-stage {
    position: relative;
    padding: var(--space-4) var(--space-4) 0;
  }
  .sim-canvas,
  .sim-host {
    display: block;
    width: 100%;
    background: var(--canvas-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
  }
  .sim-fallback {
    padding: var(--space-4);
    color: var(--muted);
    font-size: var(--text-sm);
  }
  .sim-controls:empty {
    display: none;
  }
  .sim-controls {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4) var(--space-6);
    align-items: flex-end;
    padding: var(--space-4);
  }
  /* Shared styling for controls the course module injects. */
  .sim-controls :global(label) {
    flex: 1;
    min-width: 180px;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
  }
  .sim-controls :global(output) {
    font-variant-numeric: tabular-nums;
    color: var(--accent);
    font-weight: var(--weight-medium);
  }
  .sim-controls :global(input[type="range"]) {
    accent-color: var(--accent);
    width: 160px;
  }
  .sim-controls :global(.sim-readout) {
    flex-basis: 100%;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: var(--leading-snug);
    padding: var(--space-3) var(--space-4);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .sim-controls :global(.sim-readout b) {
    color: var(--accent);
    font-weight: var(--weight-semibold);
  }
  .sim-controls :global(.sim-btn) {
    font-size: var(--text-sm);
    padding: 0.3em 0.7em;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg);
    color: var(--muted);
  }
  .sim-controls :global(.sim-btn:hover:not(:disabled)) {
    border-color: var(--accent);
    color: var(--accent);
  }
  .sim-controls :global(.sim-btn[aria-pressed="true"]) {
    background: var(--accent-weak);
    border-color: var(--accent);
    color: var(--accent);
  }
  .sim-controls :global(.sim-btn:disabled) {
    opacity: 0.4;
  }
  .sim-caption {
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-sm);
    color: var(--muted);
  }
</style>

<script>
  import {
    makeCodeBlockController,
    importCourseModule,
    lazyMountAll,
    onThemeChange,
    type CodeBlockController,
  } from "../lib/simRuntime";
  import { onPage } from "../lib/pageLifecycle.ts";

  interface BaseApi {
    controls: HTMLElement;
    getSize: () => { w: number; h: number };
    onResize: (cb: () => void) => void;
    codeBlock: (id?: string) => CodeBlockController | null;
  }
  interface CanvasApi extends BaseApi {
    canvas: HTMLCanvasElement;
    ctx: CanvasRenderingContext2D;
  }
  interface DomApi extends BaseApi {
    stage: HTMLElement;
  }
  type SimApi = CanvasApi | DomApi;
  type SimModule = {
    default?: (a: SimApi) => void;
    init?: (a: SimApi) => void;
  };

  // Throttle a window-resize listener to one callback per animation frame. Bound
  // with the page signal so it is removed on the next view-transition swap.
  const onWindowResize = (cb: () => void, signal: AbortSignal) => {
    let raf = 0;
    window.addEventListener(
      "resize",
      () => {
        if (raf) return;
        raf = requestAnimationFrame(() => {
          raf = 0;
          cb();
        });
      },
      { signal },
    );
  };

  const load = (fig: HTMLElement, api: SimApi) => {
    const src = fig.dataset.simSrc!;
    importCourseModule<SimModule>(src)
      .then((mod) => (mod.default ?? mod.init)?.(api))
      .catch((err) => {
        console.error(`study-companion: failed to load simulation ${src}`, err);
      });
  };

  const mount = (fig: HTMLElement, signal: AbortSignal) => {
    const cssH = Number(fig.dataset.simHeight) || 300;
    const controls = fig.querySelector<HTMLElement>(".sim-controls");
    if (!fig.dataset.simSrc || !controls) return;

    let resizeCb: (() => void) | null = null;
    const onResize = (cb: () => void) => {
      resizeCb = cb;
    };

    if (fig.dataset.simHost === "dom") {
      const stage = fig.querySelector<HTMLElement>(".sim-host");
      if (!stage) return;
      stage.style.height = cssH + "px";
      onWindowResize(() => resizeCb?.(), signal);
      onThemeChange(() => resizeCb?.(), signal);
      load(fig, {
        stage,
        controls,
        getSize: () => ({ w: stage.clientWidth || fig.clientWidth, h: cssH }),
        onResize,
        codeBlock: makeCodeBlockController,
      });
      return;
    }

    // canvas host (default)
    const canvas = fig.querySelector<HTMLCanvasElement>(".sim-canvas");
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    // DPR-aware sizing; coordinates handed to the course module are CSS px.
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const size = () => {
      const w = canvas.clientWidth || fig.clientWidth;
      canvas.width = Math.round(w * dpr);
      canvas.height = Math.round(cssH * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };
    canvas.style.height = cssH + "px";
    size();
    onWindowResize(() => {
      size();
      resizeCb?.();
    }, signal);
    onThemeChange(() => resizeCb?.(), signal);

    load(fig, {
      canvas,
      ctx,
      controls,
      getSize: () => ({ w: canvas.clientWidth || fig.clientWidth, h: cssH }),
      onResize,
      codeBlock: makeCodeBlockController,
    });
  };

  // Mount on each page-load; tear the observer + resize/theme listeners down on
  // the next swap. (A course sim's own RAF/timers are its responsibility — the
  // framework can only dispose the hooks it owns.)
  onPage((signal) => {
    lazyMountAll(
      document.querySelectorAll<HTMLElement>("[data-sim]"),
      (fig) => mount(fig, signal),
      signal,
    );
  });
</script>
