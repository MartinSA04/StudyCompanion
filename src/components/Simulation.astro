---
/**
 * Scaffold for course-provided interactive simulations.
 *
 * The framework owns the chrome (title, the stage, a controls slot, caption),
 * lazy-mounts on scroll, and dynamic-imports a simulation module that lives in
 * the COURSE repo's `public/sims/`. This keeps course-specific code out of the
 * framework.
 *
 * Two render hosts (`host` prop):
 *  - "canvas" (default): a DPR-aware <canvas> + 2D context. Coordinates are CSS
 *    pixels (the context is pre-scaled for devicePixelRatio).
 *  - "dom": an empty themed element the module renders SVG/HTML into — for
 *    visualizations that want crisp labels / selectable text (graphs, trees).
 *    For *stepped* algorithm traces prefer the higher-level <Stepper>.
 *
 * Course module contract (e.g. course `public/sims/thin-lens.js`):
 *
 *     export default function init(api) {
 *       const { ctx, controls, getSize, onResize } = api;   // canvas host
 *       function draw() { const { w, h } = getSize(); ...paint with ctx... }
 *       onResize(draw);   // framework calls this after a resize / theme change
 *       draw();
 *     }
 *
 * `api` = {
 *   controls, getSize: () => ({ w, h }), onResize: (cb) => void,
 *   codeBlock: (id?) => { setActiveLine, setActiveLines, clear } | null,
 *   signal,   // page-lifecycle AbortSignal
 *   // host="canvas": canvas, ctx     host="dom": stage (an element)
 * }.
 *
 * `codeBlock(id)` returns a controller for a course <CodeBlock>
 * (matched by its `id`, or the first one when omitted), so a sim can step the
 * highlighted line(s) in lockstep with what it paints. Returns null if none.
 *
 * `signal` aborts when the page is swapped out (view transitions): an
 * animating sim must stop its rAF loop / timers on it (or bind listeners with
 * `{ signal }`), or the loop keeps painting a detached canvas after every
 * navigation.
 */
import fs from "node:fs";
import path from "node:path";
import PanelHeader from "./PanelHeader.astro";
import { assertOneOf } from "../lib/assertProp.ts";

interface Props {
  /** Path to the course-provided ES module, e.g. "/sims/thin-lens.js". */
  src: string;
  title?: string;
  caption?: string;
  /** CSS height of the stage in px. */
  height?: number;
  /** Render host: a 2D canvas (default) or a DOM/SVG element. */
  host?: "canvas" | "dom";
}
const { src, title, caption, height = 300, host = "canvas" } = Astro.props;
// A typo'd host would silently fall into the canvas branch and hand the module
// the wrong api — fail the build with the component/prop named instead.
assertOneOf(host, ["canvas", "dom"], "Simulation", "host");

// Build-time guard: a root-relative src must resolve to a real file under the
// consuming project's public/ — a typo otherwise ships a green build with a
// permanently dead widget (the runtime import just 404s). process.cwd() is the
// project root in both `astro dev` and `astro build`, and public/ is Astro's
// default publicDir; a project on a custom publicDir has no public/ here and
// skips the check. Absolute URLs (CDN-hosted modules) are left to the network.
if (src.startsWith("/") && !src.startsWith("//")) {
  const file = path.join(process.cwd(), "public", src);
  if (
    fs.existsSync(path.join(process.cwd(), "public")) &&
    !fs.existsSync(file)
  ) {
    throw new Error(
      `study-companion: <Simulation src="${src}"> does not resolve to a file — ` +
        `expected ${file}. Check the path against the course repo's public/.`,
    );
  }
}
---

<figure
  class="simulation sc-panel"
  data-sim
  data-sim-src={src}
  data-sim-height={height}
  data-sim-host={host}
>
  {title && <PanelHeader dot title={title} titleSize="lg" align="center" />}
  <div class="sim-stage">
    {
      host === "dom" ? (
        <div
          class="sim-host"
          role="img"
          aria-label={title ?? "Interaktiv visning"}
          style={`min-height:${height}px`}
        />
      ) : (
        <canvas
          class="sim-canvas"
          role="img"
          aria-label={title ?? "Interaktiv simulering"}
          style={`min-height:${height}px`}
        />
      )
    }
    <noscript>
      <p class="sim-fallback">Interaktiv simulering krever JavaScript.</p>
    </noscript>
  </div>
  <div class="sim-controls"></div>
  {caption && <p class="sim-caption">{caption}</p>}
</figure>

<style>
  /* Float (fill + shadow + radius) comes from the shared .sc-panel. */
  .simulation {
    margin-block: var(--space-5);
    overflow: hidden;
  }
  .sim-stage {
    position: relative;
    padding: var(--space-4) var(--space-4) 0;
  }
  .sim-canvas,
  .sim-host {
    display: block;
    width: 100%;
    background: var(--canvas-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
  }
  /* :global twin: the module-load failure line is injected at runtime, so it
     never carries this component's scope attribute. */
  .sim-fallback,
  .sim-stage :global(.sim-fallback) {
    padding: var(--space-4);
    color: var(--muted);
    font-size: var(--text-sm);
  }
  .sim-controls:empty {
    display: none;
  }
  .sim-controls {
    /* Paper controls hosted on this panel step to the nested fill. */
    --control-fill: var(--card-nested);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4) var(--space-6);
    align-items: flex-end;
    padding: var(--space-4);
  }
  /* Shared styling for controls the course module injects. */
  .sim-controls :global(label) {
    flex: 1;
    min-width: 180px;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
  }
  .sim-controls :global(output) {
    font-variant-numeric: tabular-nums;
    color: var(--accent-ink);
    font-weight: var(--weight-medium);
  }
  /* Course-injected range sliders are upgraded to the shared .sc-range primitive
     at mount (see the script); only their width stays local here. */
  .sim-controls :global(input[type="range"]) {
    width: 160px;
  }
  .sim-controls :global(.sim-readout) {
    flex-basis: 100%;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: var(--leading-snug);
    padding: var(--space-3) var(--space-4);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .sim-controls :global(.sim-readout b) {
    color: var(--accent-ink);
    font-weight: var(--weight-semibold);
  }
  .sim-controls :global(.sim-btn) {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    padding: 0.3em 0.7em;
    border: 0;
    border-radius: var(--radius-sm);
    background: var(--control-fill, var(--bg-elevated));
    color: var(--muted);
    transition:
      background-color var(--dur-fast) var(--ease),
      color var(--dur-fast) var(--ease);
  }
  /* --card-hover equals the resting nested fill, so hover is an ink wash over
     it (same construction as the quiz options' accent wash). */
  .sim-controls :global(.sim-btn:hover:not(:disabled)) {
    background: color-mix(in srgb, var(--fg) 6%, var(--card-nested));
    color: var(--accent-ink);
  }
  /* Tactile press, kept local (not the shared .sc-press): .sim-btn is injected by
     the course module — no markup here to carry a class — and the :not(:disabled)
     guard must suppress the press on a disabled control. */
  .sim-controls :global(.sim-btn:active:not(:disabled)) {
    transform: translateY(1px);
  }
  .sim-controls :global(.sim-btn[aria-pressed="true"]) {
    background: var(--accent-weak);
    color: var(--accent-ink);
  }
  .sim-controls :global(.sim-btn:disabled) {
    opacity: 0.4;
  }
  .sim-caption {
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-sm);
    color: var(--muted);
  }
</style>

<script>
  import {
    makeCodeBlockController,
    importCourseModule,
    lazyMountAll,
    onThemeChange,
    setRangePct,
    type CodeBlockController,
  } from "../lib/simRuntime";
  import { onPage } from "../lib/pageLifecycle.ts";

  interface BaseApi {
    controls: HTMLElement;
    getSize: () => { w: number; h: number };
    onResize: (cb: () => void) => void;
    codeBlock: (id?: string) => CodeBlockController | null;
    /** Page-lifecycle signal — aborts on the next view-transition swap. The
     * module ties its own rAF loop/timers to it (see the contract above). */
    signal: AbortSignal;
  }
  interface CanvasApi extends BaseApi {
    canvas: HTMLCanvasElement;
    ctx: CanvasRenderingContext2D;
  }
  interface DomApi extends BaseApi {
    stage: HTMLElement;
  }
  type SimApi = CanvasApi | DomApi;
  type SimModule = {
    default?: (a: SimApi) => void;
    init?: (a: SimApi) => void;
  };

  // Throttle a window-resize listener to one callback per animation frame. Bound
  // with the page signal so it is removed on the next view-transition swap.
  const onWindowResize = (cb: () => void, signal: AbortSignal) => {
    let raf = 0;
    window.addEventListener(
      "resize",
      () => {
        if (raf) return;
        raf = requestAnimationFrame(() => {
          raf = 0;
          cb();
        });
      },
      { signal },
    );
  };

  const load = (fig: HTMLElement, api: SimApi, signal: AbortSignal) => {
    const src = fig.dataset.simSrc!;
    importCourseModule<SimModule>(src)
      .then((mod) => {
        // The lazy import can resolve after the page that mounted this sim was
        // swapped out — don't boot the module into a detached stage (it would
        // start a rAF loop nothing ever stops).
        if (signal.aborted) return;
        try {
          (mod.default ?? mod.init)?.(api);
          // Upgrade the range sliders the course module just injected to the
          // shared .sc-range look, and keep each one's accent fill in sync
          // (WebKit needs --pct). Bound with the page signal, drops on swap.
          api.controls
            .querySelectorAll<HTMLInputElement>('input[type="range"]')
            .forEach((el) => {
              el.classList.add("sc-range");
              setRangePct(el);
              el.addEventListener("input", () => setRangePct(el), { signal });
            });
        } catch (err) {
          // The module LOADED but crashed in init(): a course-code bug, not a
          // missing file. Log and leave whatever it already painted — routing
          // this into the .catch below would wipe the stage and show a false
          // "could not be loaded" message.
          console.error(
            `study-companion: simulation ${src} threw during init`,
            err,
          );
        }
      })
      .catch((err) => {
        console.error(`study-companion: failed to load simulation ${src}`, err);
        // A 404/throwing module must fail visibly, not sit as a permanently
        // blank framed stage under a title.
        const stage = fig.querySelector<HTMLElement>(".sim-stage");
        if (stage) {
          const p = document.createElement("p");
          p.className = "sim-fallback";
          p.textContent = "Simuleringen kunne ikke lastes.";
          stage.replaceChildren(p);
        }
      });
  };

  const mount = (fig: HTMLElement, signal: AbortSignal) => {
    const cssH = Number(fig.dataset.simHeight) || 300;
    const controls = fig.querySelector<HTMLElement>(".sim-controls");
    if (!fig.dataset.simSrc || !controls) return;

    let resizeCb: (() => void) | null = null;
    const onResize = (cb: () => void) => {
      resizeCb = cb;
    };

    if (fig.dataset.simHost === "dom") {
      const stage = fig.querySelector<HTMLElement>(".sim-host");
      if (!stage) return;
      stage.style.height = cssH + "px";
      onWindowResize(() => resizeCb?.(), signal);
      onThemeChange(() => resizeCb?.(), signal);
      load(
        fig,
        {
          stage,
          controls,
          getSize: () => ({ w: stage.clientWidth || fig.clientWidth, h: cssH }),
          onResize,
          codeBlock: makeCodeBlockController,
          signal,
        },
        signal,
      );
      return;
    }

    // canvas host (default)
    const canvas = fig.querySelector<HTMLCanvasElement>(".sim-canvas");
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    // DPR-aware sizing; coordinates handed to the course module are CSS px.
    // DPR is read per call — it changes with browser zoom and monitor moves,
    // and a mount-time capture would leave the canvas blurry after either.
    const size = () => {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const w = canvas.clientWidth || fig.clientWidth;
      canvas.width = Math.round(w * dpr);
      canvas.height = Math.round(cssH * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };
    canvas.style.height = cssH + "px";
    size();
    onWindowResize(() => {
      size();
      resizeCb?.();
    }, signal);
    onThemeChange(() => resizeCb?.(), signal);

    load(
      fig,
      {
        canvas,
        ctx,
        controls,
        getSize: () => ({ w: canvas.clientWidth || fig.clientWidth, h: cssH }),
        onResize,
        codeBlock: makeCodeBlockController,
        signal,
      },
      signal,
    );
  };

  // Mount on each page-load; tear the observer + resize/theme listeners down on
  // the next swap. (A course sim's own RAF/timers are still its responsibility —
  // the api's `signal` tells it when to stop.)
  onPage((signal) => {
    lazyMountAll(
      document.querySelectorAll<HTMLElement>("[data-sim]"),
      (fig) => mount(fig, signal),
      signal,
    );
  });
</script>
