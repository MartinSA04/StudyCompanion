---
import { renderMathString } from "../lib/katex.ts";

/**
 * One column of a <Compare>. A titled card whose body is free MDX (lists, math,
 * prose). The title is a styled `<p>` (not a heading) so it never disturbs the
 * page's heading outline; `aria-label` names the region for screen readers.
 * `title` may contain `$inline$` math.
 */
interface Props {
  title: string;
}
const { title } = Astro.props;
const plain = title.replace(/\$[^$]*\$/g, "").replace(/<[^>]*>/g, "").trim();
---

<section class="compare-col" aria-label={plain || undefined}>
  <p class="compare-col-title" set:html={renderMathString(title)}></p>
  <div class="compare-col-body"><slot /></div>
</section>

<style>
  .compare-col {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-elevated);
    overflow: hidden;
  }
  .compare-col-title {
    margin: 0;
    padding: var(--space-2) var(--space-3);
    background: var(--card);
    border-bottom: 1px solid var(--border);
    font-family: var(--font-display);
    font-weight: var(--weight-semibold);
    color: var(--fg);
  }
  .compare-col-body {
    flex: 1;
    padding: var(--space-3) var(--space-4);
  }
  .compare-col-body :global(> :last-child) {
    margin-bottom: 0;
  }
  /* Tighten the common case: a single bullet list filling the card. */
  .compare-col-body :global(ul) {
    margin-block: 0;
    padding-left: 1.2em;
  }
</style>
