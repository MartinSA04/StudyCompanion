---
/**
 * <Stepper> — a generic algorithm trace-player.
 *
 * The framework owns the player chrome (transport, seek, speed, the current-step
 * caption, code-line sync + a variable strip on the linked <CodeBlock>, keyboard,
 * a11y, theming) and the render *stage*. A course module in `public/` supplies only
 * the domain pieces: the trace (`run`) and how to draw one frame (`render`).
 *
 * Course module contract (course `public/steppers/<algo>.js`, default export):
 *
 *   export default {
 *     run(input) { return [frame, frame, …]; },          // required: the trace
 *     render(stage, frame, api) { …paint SVG/HTML… },     // required: one frame
 *     defaultData(size) { return [...]; },   // optional → enables shuffle
 *     sizeRange: { min, max, default },       // optional → enables a size control
 *     label(frame) { return "…"; },           // optional → overrides caption text
 *   }
 *
 * Framework-recognised frame fields (everything else is opaque course payload
 * passed straight to render): `line` (number | number[]) → the linked <CodeBlock>
 * active line(s); `desc`/`label` → the step caption; `vars`/`variables` → the
 * `key = value` strip on the linked <CodeBlock>.
 */
import fs from "node:fs";
import path from "node:path";
import PanelHeader from "./PanelHeader.astro";
import Icon from "./Icon.astro";

interface Props {
  /** Path to the course-provided ES module, e.g. "/steppers/bubblesort.js". */
  src: string;
  /** `id` of the <CodeBlock> to drive (its active line follows `frame.line`). */
  codeId?: string;
  title?: string;
  caption?: string;
  /** CSS height of the stage in px. */
  height?: number;
}
const { src, codeId, title, caption, height = 300 } = Astro.props;

// Build-time guard: a root-relative src must resolve to a real file under the
// consuming project's public/ — a typo otherwise ships a green build with a
// permanently dead widget (the runtime import just 404s). process.cwd() is the
// project root in both `astro dev` and `astro build`, and public/ is Astro's
// default publicDir; a project on a custom publicDir has no public/ here and
// skips the check. Absolute URLs (CDN-hosted modules) are left to the network.
if (src.startsWith("/") && !src.startsWith("//")) {
  const file = path.join(process.cwd(), "public", src);
  if (
    fs.existsSync(path.join(process.cwd(), "public")) &&
    !fs.existsSync(file)
  ) {
    throw new Error(
      `study-companion: <Stepper src="${src}"> does not resolve to a file — ` +
        `expected ${file}. Check the path against the course repo's public/.`,
    );
  }
}
---

<figure
  class="stepper sc-panel"
  data-stepper
  data-stepper-src={src}
  data-stepper-code={codeId}
  data-stepper-height={height}
  tabindex="-1"
>
  {title && <PanelHeader dot title={title} titleSize="lg" align="center" />}

  <div
    class="stepper-stage"
    role="img"
    aria-label={title ?? "Algoritmevisualisering"}
    style={`min-height:${height}px`}
  >
  </div>
  <noscript>
    <p class="stepper-fallback">Interaktiv visualisering krever JavaScript.</p>
  </noscript>

  <div class="stepper-body">
    <div class="stepper-controls">
      <div class="stepper-transport">
        <button
          class="stepper-btn sc-icon-btn sc-press"
          data-act="back"
          type="button"
          aria-label="Forrige steg"
          title="Forrige steg (←)"><Icon name="chevron-left" /></button
        >
        <button
          class="stepper-btn stepper-play sc-press"
          data-act="play"
          type="button"
          aria-pressed="false"
          aria-label="Spill av"
          title="Spill av / pause (mellomrom)"
        >
          <span class="ic-play"><Icon name="play" size={18} /></span>
          <span class="ic-pause"><Icon name="pause" size={18} /></span>
        </button>
        <button
          class="stepper-btn sc-icon-btn sc-press"
          data-act="forward"
          type="button"
          aria-label="Neste steg"
          title="Neste steg (→)"><Icon name="chevron-right" /></button
        >
      </div>

      <input
        class="stepper-scrub sc-range"
        data-scrub
        type="range"
        min="0"
        max="0"
        value="0"
        aria-label="Gå til steg"
      />
      <span class="stepper-count" data-count>0 / 0</span>

      <div class="stepper-extra">
        <button
          class="sc-pill stepper-speed sc-press"
          data-act="speed"
          type="button"
          aria-label="Avspillingsfart"
          title="Avspillingsfart">1×</button
        >
        <button
          class="stepper-btn sc-icon-btn sc-press"
          data-act="shuffle"
          type="button"
          aria-label="Stokk om"
          title="Stokk om (S)"><Icon name="shuffle" size={15} /></button
        >
        <label class="stepper-size" data-size-ctrl title="Antall elementer">
          <span class="stepper-size-n" data-size-n>n</span>
          <input
            data-size
            class="sc-range"
            type="range"
            aria-label="Størrelse"
          />
        </label>
      </div>
    </div>

    <p class="stepper-desc" aria-live="polite"></p>
    {caption && <p class="stepper-caption">{caption}</p>}
  </div>
</figure>

<style>
  /* Float (fill + shadow + radius) comes from the shared .sc-panel. */
  .stepper {
    margin-block: var(--space-5);
    overflow: hidden;
  }
  .stepper:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Stage: the visualization is the hero — no inner box, it sits on the panel. */
  .stepper-stage {
    margin: var(--space-5) var(--space-5) var(--space-4);
  }
  .stepper-body {
    padding-bottom: var(--space-5);
  }
  /* :global twin: the module-load failure line is injected at runtime, so it
     never carries this component's scope attribute. It sits inside the stage
     (which already carries the margins), hence no padding of its own. */
  .stepper-fallback,
  .stepper-stage :global(.stepper-fallback) {
    color: var(--muted);
    font-size: var(--text-sm);
  }
  .stepper-fallback {
    padding: 0 var(--space-5) var(--space-5);
  }
  .stepper:not([data-ready]) .stepper-body {
    display: none;
  }

  /* Current-step narration: a quiet status line under the controls (the player
     stays a single group). Variables live in the linked <CodeBlock>. */
  .stepper-desc {
    margin: 0;
    padding: var(--space-3) var(--space-5) 0;
    min-height: 1.4em;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    color: var(--muted);
  }

  /* One control bar: primary transport, a seek scrubber, count, quiet extras. */
  .stepper-controls {
    /* Paper controls hosted on this panel step to the nested fill (the play
       toggle uses it), matching the Simulation controls. */
    --control-fill: var(--card-nested);
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    padding: 0 var(--space-5);
  }
  .stepper-transport {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  /* Transport (back/forward) + shuffle are navigational icon controls: they wear
     the shared .sc-icon-btn marginalia recipe (bare glyph → ink-wash + accent-ink
     hover), exactly like the topbar and copy buttons. This class only carries the
     row's 38px control-height contract so every button lines up. */
  .stepper-btn {
    width: var(--control-h);
    height: var(--control-h);
    cursor: pointer;
  }
  /* Play/pause is a TOGGLE → by the Paper/Marginalia Rule it keeps a borderless
     PAPER fill (not a saturated block, which was the loudest accent mass on the
     page); the accent-ink triangle marks it primary against the bare-glyph arrows,
     and an accent-weak wash marks the active "playing" state — the same active
     precedent as the Simulation buttons / quiz options. */
  .stepper-play {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: var(--radius-sm);
    background: var(--control-fill, var(--bg-elevated));
    color: var(--accent-ink);
    transition:
      background-color var(--dur-fast) var(--ease),
      color var(--dur-fast) var(--ease),
      transform var(--dur-fast) var(--ease);
  }
  /* --card-hover equals the resting nested fill here, so hover is an ink wash over
     it (same construction as the quiz options / sim buttons). */
  .stepper-play:hover {
    background: color-mix(in srgb, var(--fg) 6%, var(--card-nested));
  }
  .stepper-play.is-playing {
    background: var(--accent-weak);
  }
  .stepper-play.is-playing:hover {
    background: color-mix(in srgb, var(--accent) 20%, transparent);
  }
  /* Icons sit as block svgs so they center (an inline svg leaves baseline
     descender space → the glyph rides high). */
  .stepper-controls :global(svg) {
    display: block;
  }
  .ic-play,
  .ic-pause {
    display: inline-flex;
  }
  /* Optically centre the play triangle: its mass sits left of the glyph box, so
     a geometric centre reads left-heavy in the round-ish button. */
  .ic-play {
    transform: translateX(1px);
  }
  .stepper-play .ic-pause {
    display: none;
  }
  .stepper-play.is-playing .ic-play {
    display: none;
  }
  .stepper-play.is-playing .ic-pause {
    display: inline-flex;
  }

  /* Seek + size sliders wear the shared .sc-range primitive; only their layout
     footprint stays local. The scrub grows to fill the row; the size slider keeps
     its compact 4.5rem width (below, with .stepper-size). */
  .stepper-scrub {
    flex: 1 1 8rem;
    min-width: 6rem;
  }
  .stepper-count {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .stepper-extra {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }
  /* Speed is a labelled instant-action control → the labelled marginalia recipe
     (.sc-pill: bare mono text, ink-wash + accent-ink hover). Sized to the 38px row
     contract and kept at the count's xs mono so the extras read as one set. */
  .stepper-speed {
    justify-content: center;
    min-width: var(--control-h);
    height: var(--control-h);
    padding: 0 var(--space-2);
    font-size: var(--text-xs);
    cursor: pointer;
    font-variant-numeric: tabular-nums;
  }
  .stepper-size {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding-left: var(--space-1);
  }
  .stepper-size[hidden] {
    display: none;
  }
  .stepper-size input[type="range"] {
    width: 4.5rem;
  }

  .stepper-caption {
    margin: 0;
    padding: var(--space-2) var(--space-5) 0;
    font-size: var(--text-xs);
    color: var(--muted);
    line-height: var(--leading-snug);
  }

  /* The 38px control contract widens every button in the row; on the mobile
     pass the four groups (transport, scrub, count, extras) need the tighter
     gap to keep wrapping onto two clean lines instead of crowding a third. */
  @media (max-width: 640px) {
    .stepper-controls {
      gap: var(--space-2);
    }
  }
</style>

<script>
  import {
    importCourseModule,
    lazyMountAll,
    makeCodeBlockController,
    onThemeChange,
    setRangePct,
  } from "../lib/simRuntime";
  import { onPage } from "../lib/pageLifecycle.ts";
  import {
    normalizeFrame,
    clampIndex,
    stepIndex,
    intervalFor,
    nextSpeed,
    tickPlay,
    type Frame,
  } from "../lib/stepper";

  interface StepperDef {
    run: (input: unknown) => Frame[];
    render: (
      stage: HTMLElement,
      frame: Frame,
      api: {
        index: number;
        total: number;
        getSize: () => { w: number; h: number };
        /** Page-lifecycle signal: aborts on the next view-transition swap, so
         * a render that starts its own rAF/timers can tie them to it (same
         * contract as the <Simulation> api). */
        signal: AbortSignal;
      },
    ) => void;
    defaultData?: (size: number) => unknown;
    sizeRange?: { min: number; max: number; default: number };
    label?: (frame: Frame) => string;
  }

  const mount = (fig: HTMLElement, signal: AbortSignal) => {
    const src = fig.dataset.stepperSrc;
    if (!src) return;
    const codeId = fig.dataset.stepperCode || undefined;
    const cssH = Number(fig.dataset.stepperHeight) || 300;

    const q = <T extends HTMLElement = HTMLElement>(s: string) =>
      fig.querySelector<T>(s);
    const stage = q(".stepper-stage");
    const descEl = q(".stepper-desc");
    const countEl = q("[data-count]");
    const scrub = q<HTMLInputElement>("[data-scrub]");
    const speedBtn = q<HTMLButtonElement>('[data-act="speed"]');
    const shuffleBtn = q<HTMLButtonElement>('[data-act="shuffle"]');
    const sizeWrap = q("[data-size-ctrl]");
    const sizeEl = q<HTMLInputElement>("[data-size]");
    const sizeN = q("[data-size-n]");
    const playBtn = q<HTMLButtonElement>('[data-act="play"]');
    if (!stage) return;

    importCourseModule<{ default?: StepperDef } & Partial<StepperDef>>(src)
      .then((mod) => {
        // The lazy import can resolve after the page that mounted this stepper
        // was swapped out — don't boot the module into a detached stage.
        if (signal.aborted) return;
        const def = (mod.default ?? mod) as StepperDef;
        if (typeof def?.run !== "function" || typeof def?.render !== "function")
          throw new Error("stepper module must export run() and render()");
        init(def);
      })
      .catch((err) => {
        console.error(`study-companion: failed to load stepper ${src}`, err);
        // A 404/throwing module must fail visibly, not leave a titled panel
        // over a permanently blank stage. The body stays hidden (no
        // data-ready): its transport listeners are only bound in init(), so
        // revealing it would expose dead controls.
        const p = document.createElement("p");
        p.className = "stepper-fallback";
        p.textContent = "Visualiseringen kunne ikke lastes.";
        stage.replaceChildren(p);
      });

    function init(def: StepperDef) {
      stage!.style.height = cssH + "px";
      fig.dataset.ready = "true";

      const code = codeId ? makeCodeBlockController(codeId) : null;
      // The linked <CodeBlock>'s variable strip is a hardcoded aria-live="polite"
      // region (CodeBlock.astro); paint()'s setVars() replaceChildren()s it every
      // autoplay tick, so we mute it during play the same way as the desc line
      // (setPlaying, below). Resolved by codeId exactly as makeCodeBlockController
      // does, so no need to widen the controller's API.
      const varsLive = codeId
        ? (document
            .querySelector(`.codeblock[data-code-block="${codeId}"]`)
            ?.querySelector<HTMLElement>("[data-codeblock-vars]") ?? null)
        : null;
      const getSize = () => ({
        w: stage!.clientWidth || fig.clientWidth,
        h: cssH,
      });

      let size = def.sizeRange?.default ?? 0;
      let speed = 1;
      let frames: Frame[] = [];
      let idx = 0;
      let playing = false;
      let timer: number | null = null;
      // Stop the play loop when this page is swapped out (otherwise the interval
      // keeps firing render() on a detached stage forever).
      signal.addEventListener("abort", () => {
        if (timer != null) {
          clearInterval(timer);
          timer = null;
        }
      });

      // Capability-gated extras.
      if (def.sizeRange && sizeEl) {
        sizeEl.min = String(def.sizeRange.min);
        sizeEl.max = String(def.sizeRange.max);
        sizeEl.value = String(size);
        setRangePct(sizeEl);
        if (sizeN) sizeN.textContent = String(size);
      } else sizeWrap?.setAttribute("hidden", "");
      if (!def.defaultData) shuffleBtn?.setAttribute("hidden", "");

      function setPlaying(p: boolean) {
        // An empty trace has nothing to loop over (startLoop returns at once):
        // refuse play so the button can't stick in a "pause" state.
        if (p && !frames.length) return;
        // Pressing play at the end replays from the start.
        if (p && idx >= frames.length - 1) idx = 0;
        playing = p;
        // Autoplay would announce the polite desc — and the linked CodeBlock's
        // var strip, which paint() rewrites each tick — every ~520ms; silence
        // both while playing. Manual steps and the final resting frame still
        // announce: startLoop pauses BEFORE its last paint, so polite is
        // already restored when that frame's text and vars land.
        descEl?.setAttribute("aria-live", p ? "off" : "polite");
        varsLive?.setAttribute("aria-live", p ? "off" : "polite");
        if (playBtn) {
          playBtn.classList.toggle("is-playing", p);
          playBtn.setAttribute("aria-pressed", String(p));
          playBtn.setAttribute("aria-label", p ? "Pause" : "Spill av");
        }
        if (timer != null) {
          clearInterval(timer);
          timer = null;
        }
        if (p) {
          paint();
          startLoop();
        } else {
          // Pausing mid-trace must resync the scrubber's valuetext: paint()
          // skips it while playing (same tick-spam gating as the desc line)
          // and pausing itself doesn't repaint, so a focused scrubber would
          // keep announcing the frame from before playback started.
          syncScrubValuetext();
        }
      }
      /** The scrubber's spoken value for the current frame (see paint). */
      function syncScrubValuetext() {
        if (!scrub || !frames.length) return;
        const frame = frames[clampIndex(idx, frames.length)];
        const desc = def.label ? def.label(frame) : normalizeFrame(frame).desc;
        scrub.setAttribute(
          "aria-valuetext",
          desc || `Steg ${idx + 1} av ${frames.length}`,
        );
      }
      function startLoop() {
        if (!frames.length) return;
        timer = window.setInterval(() => {
          const t = tickPlay(idx, frames.length);
          idx = t.index;
          // Pause before the final paint (not after), so that paint runs with
          // the live region polite again and the resting frame is announced.
          if (t.atEnd) setPlaying(false);
          paint();
        }, intervalFor(speed));
      }

      function regen() {
        setPlaying(false);
        const input = def.defaultData ? def.defaultData(size) : [];
        try {
          frames = def.run(input) || [];
        } catch (e) {
          console.error(e);
          frames = [];
        }
        idx = 0;
        if (scrub) scrub.max = String(Math.max(0, frames.length - 1));
        paint();
      }

      function paint() {
        if (!frames.length) {
          if (descEl) descEl.textContent = "Ingen steg.";
          code?.setVars([]);
          return;
        }
        idx = clampIndex(idx, frames.length);
        const frame = frames[idx];
        try {
          def.render(stage!, frame, {
            index: idx,
            total: frames.length,
            getSize,
            signal,
          });
        } catch (e) {
          console.error(e);
        }
        const n = normalizeFrame(frame);
        const desc = def.label ? def.label(frame) : n.desc;
        if (descEl) descEl.textContent = desc;
        if (countEl) countEl.textContent = `${idx + 1} / ${frames.length}`;
        if (scrub) {
          scrub.value = String(idx);
          setRangePct(scrub);
          // Same gating as the desc line: a focused scrubber would otherwise
          // announce every autoplay tick's valuetext. setPlaying(false)
          // resyncs it on pause.
          if (!playing) syncScrubValuetext();
        }
        if (code) {
          code.setActiveLines(n.lines);
          code.setVars(n.vars);
        }
      }

      const go = (next: number) => {
        setPlaying(false);
        idx = next;
        paint();
      };

      // Transport + extras. Bound with the page signal so all of a mounted
      // stepper's listeners drop on the next view-transition swap.
      q('[data-act="back"]')?.addEventListener(
        "click",
        () => go(stepIndex(idx, frames.length, -1)),
        { signal },
      );
      q('[data-act="forward"]')?.addEventListener(
        "click",
        () => go(stepIndex(idx, frames.length, +1)),
        { signal },
      );
      playBtn?.addEventListener("click", () => setPlaying(!playing), {
        signal,
      });
      shuffleBtn?.addEventListener("click", () => regen(), { signal });
      scrub?.addEventListener(
        "input",
        () => go(clampIndex(Number(scrub.value), frames.length)),
        { signal },
      );
      speedBtn?.addEventListener(
        "click",
        () => {
          speed = nextSpeed(speed);
          speedBtn.textContent = `${speed}×`;
          if (playing) setPlaying(true); // restart loop at the new interval
        },
        { signal },
      );
      sizeEl?.addEventListener(
        "input",
        () => {
          size = Number(sizeEl.value);
          setRangePct(sizeEl);
          if (sizeN) sizeN.textContent = String(size);
          regen();
        },
        { signal },
      );

      // Keyboard, scoped to the widget so it can't fight the page's global
      // arrow-key module paging (stopPropagation on the arrows).
      fig.addEventListener(
        "keydown",
        (e) => {
          if (e.metaKey || e.ctrlKey || e.altKey) return;
          const target = e.target as HTMLElement;
          switch (e.key) {
            case "ArrowRight":
              // The size slider keeps its native horizontal arrows (a value
              // change); stepping the trace instead would freeze the slider
              // for keyboard users.
              if (target === sizeEl) return;
              e.preventDefault();
              e.stopPropagation();
              go(stepIndex(idx, frames.length, +1));
              break;
            case "ArrowLeft":
              if (target === sizeEl) return;
              e.preventDefault();
              e.stopPropagation();
              go(stepIndex(idx, frames.length, -1));
              break;
            case " ":
              // Space on any focused button other than play keeps its native
              // activation ("Neste steg" should step, not toggle play). The
              // play button falls through: preventDefault suppresses its
              // native click, so this toggle is the single action.
              if (target instanceof HTMLButtonElement && target !== playBtn)
                return;
              e.preventDefault();
              setPlaying(!playing);
              break;
            case "r":
            case "R":
              go(0);
              break;
            case "s":
            case "S":
              if (def.defaultData) regen();
              break;
          }
        },
        { signal },
      );

      // Repaint the current frame on resize + theme change so the course's
      // SVG/HTML re-lays-out and picks up new theme tokens. Both are torn down
      // on the next swap via the page signal.
      let raf = 0;
      window.addEventListener(
        "resize",
        () => {
          if (raf) return;
          raf = requestAnimationFrame(() => {
            raf = 0;
            paint();
          });
        },
        { signal },
      );
      onThemeChange(() => paint(), signal);

      regen();
    }
  };

  // Mount on each page-load; the page signal tears down the observer, the play
  // interval, and every stepper's resize/theme/transport listeners on swap.
  onPage((signal) => {
    lazyMountAll(
      document.querySelectorAll<HTMLElement>("[data-stepper]"),
      (fig) => mount(fig, signal),
      signal,
    );
  });
</script>
