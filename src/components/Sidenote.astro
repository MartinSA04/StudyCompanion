---
/**
 * A short margin note. On wide viewports it floats into the strip the reading
 * measure leaves open on the right (--maxw − --measure ≈ 225px); on narrower
 * ones — where that strip collapses — it falls back to a quiet inline aside on
 * the reading column. Mono, muted, calm: the "marginalia" voice the design
 * system reserves this room for (asides, cross-refs, a passing remark), not a
 * second callout. Keep it to a sentence or two — the strip is narrow by design.
 *
 * It floats beside the content that FOLLOWS it, so place `<Sidenote>` just
 * before the paragraph it should sit next to. Rendered as an <aside> and kept
 * in source order, so assistive tech reads it right after that anchor.
 */
interface Props {
  /** Optional mono kicker above the note (e.g. "NB", "Merk"). */
  label?: string;
}
const { label } = Astro.props;
---

<aside class="sidenote">
  {label && <span class="sidenote-label">{label}</span>}
  <slot />
</aside>

<style>
  /* Default (inline fallback): a quiet mono aside on the reading column,
     set apart by a hairline above — never a side-stripe. */
  .sidenote {
    max-width: var(--measure);
    margin-block: var(--space-4);
    padding-top: var(--space-2);
    border-top: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    color: var(--muted); /* AA on the page ground (7.1:1 light / 7.0:1 dark) */
  }
  .sidenote-label {
    display: block;
    margin-bottom: var(--space-1);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking);
    color: var(--faint); /* mono kicker on page ground — matches .nav-section */
  }
  .sidenote :global(a) {
    color: var(--accent-ink);
  }
  /* Trim the slotted prose so a one-line note stays one line. */
  .sidenote :global(:is(p, ul, ol)) {
    margin: 0;
  }
  .sidenote :global(p + p) {
    margin-top: var(--space-2);
  }

  /* Wide: float into the margin strip. Gated at 1200px, the point below which
     the content column can no longer hold its full --maxw and the strip is too
     thin for a note. Floated (not absolute) so it participates in flow:
     `clear: right` makes consecutive notes STACK instead of overlapping, and
     the plate-clear rule in base.css drops any following full-width panel or
     display equation BELOW the note rather than letting it slide under. Capped
     prose (≤ --measure) is narrower than the strip, so it flows past the note
     untouched — no text reflow. Place <Sidenote> just before the paragraph it
     should sit beside. Width tracks the strip minus a gutter, so it stays
     correct if --maxw or --measure change. */
  @media (min-width: 1200px) {
    .sidenote {
      float: right;
      clear: right;
      width: calc(var(--maxw) - var(--measure) - var(--gap-6));
      max-width: none;
      margin-block: 0 var(--space-4);
      border-top: 0;
      padding-top: 0;
    }
  }
</style>
