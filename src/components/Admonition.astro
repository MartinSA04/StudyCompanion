---
/**
 * Shared admonition shell: a soft full-tint box with a mono UPPERCASE kicker
 * (icon + label, coloured by tone) over slotted body copy. One editorial vocabulary
 * for every callout-like block — the same kicker treatment `PanelHeader`, `Example`
 * and `Statement` already use. Deliberately NO coloured left-stripe (a spine border
 * reads as a docs template) and NO outline: borderless, with the tone carried by the
 * background tint plus the coloured kicker + icon (the Flexoki aside treatment).
 *
 * Internal primitive (not in mdx-components) wrapped by `<Callout>`,
 * `<LearningGoals>`, `<KeyTakeaways>` and `<ExamFocus>` (ROADMAP 2.7 style).
 */
import Icon from "./Icon.astro";
import { assertOneOf } from "../lib/assertProp.ts";

interface Props {
  tone: "note" | "tip" | "warning" | "goals" | "takeaways" | "exam";
  /** Icon name shown in the kicker. */
  icon: string;
  /** Kicker label (rendered uppercase). */
  title: string;
  /** Accessible label; defaults to the title. */
  ariaLabel?: string;
}
const { tone, icon, title, ariaLabel } = Astro.props;

// Tone → (kicker colour, fill). Each pairs a Flexoki -high text shade with its
// -low fill swatch (defined in tokens.css); takeaways reuses --violet over the
// purple-low fill.
const TONES: Record<Props["tone"], { c: string; bg: string }> = {
  note: { c: "var(--note)", bg: "var(--note-bg)" },
  tip: { c: "var(--tip)", bg: "var(--tip-bg)" },
  warning: { c: "var(--warning)", bg: "var(--warning-bg)" },
  goals: { c: "var(--goals)", bg: "var(--goals-bg)" },
  takeaways: { c: "var(--violet)", bg: "var(--takeaways-bg)" },
  exam: { c: "var(--warning)", bg: "var(--exam-bg)" },
};
// MDX isn't type-checked: an unknown tone would otherwise crash below with an
// opaque "cannot read properties of undefined".
assertOneOf(tone, Object.keys(TONES), "Admonition", "tone");
const t = TONES[tone];
---

<aside
  class="admonition"
  role="note"
  aria-label={ariaLabel ?? title}
  style={`--c:${t.c};--c-bg:${t.bg}`}
>
  <p class="adm-kicker">
    <span class="adm-icon" aria-hidden="true"
      ><Icon name={icon} size={15} /></span
    >
    {title}
  </p>
  <div class="adm-body"><slot /></div>
</aside>

<style>
  .admonition {
    margin-block: var(--space-5);
    padding: var(--space-4);
    border-radius: var(--radius);
    background: var(--c-bg);
  }
  .adm-kicker {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking);
    font-weight: var(--weight-semibold);
    color: var(--c);
  }
  .adm-icon {
    flex: none;
    display: inline-flex;
    align-items: center;
  }
  /* Let the last child sit flush against the padding. */
  .adm-body :global(> :last-child) {
    margin-bottom: 0;
  }
  /* Body copy at full ink: the tinted fill would otherwise show .prose's muted
     gray (#575653 on the orange-low fill is the classic washed-out
     gray-on-colour pairing). The tone lives in the kicker + fill; the text
     stays as readable as the page. */
  .adm-body :global(:is(p, li)) {
    color: var(--fg);
  }
  .adm-body :global(li)::marker {
    color: var(--c);
  }
</style>
