---
/**
 * Shared admonition shell: a single faint-tinted box with a mono UPPERCASE kicker
 * (icon + label, coloured by tone) over slotted body copy. One editorial vocabulary
 * for every callout-like block — the same kicker treatment `PanelHeader`, `Example`
 * and `Statement` already use. Deliberately NO coloured left-stripe: a spine border
 * reads as a docs template; the tone lives in the kicker, icon, border tint and
 * background tint instead.
 *
 * Internal primitive (not in mdx-components) wrapped by `<Callout>`,
 * `<LearningGoals>`, `<KeyTakeaways>` and `<ExamFocus>` (ROADMAP 2.7 style).
 */
import Icon from "./Icon.astro";

interface Props {
  tone: "note" | "tip" | "warning" | "goals" | "takeaways" | "exam";
  /** Icon name shown in the kicker. */
  icon: string;
  /** Kicker label (rendered uppercase). */
  title: string;
  /** Accessible label; defaults to the title. */
  ariaLabel?: string;
}
const { tone, icon, title, ariaLabel } = Astro.props;

// Tone → (accent colour, background tint). Reuses existing tokens; goals/exam pair
// a categorical hue with a purpose-built tint, so the map stays explicit.
const TONES: Record<Props["tone"], { c: string; bg: string }> = {
  note: { c: "var(--note)", bg: "var(--note-bg)" },
  tip: { c: "var(--tip)", bg: "var(--tip-bg)" },
  warning: { c: "var(--warning)", bg: "var(--warning-bg)" },
  goals: { c: "var(--cyan)", bg: "var(--goals-bg)" },
  takeaways: {
    c: "var(--violet)",
    bg: "color-mix(in srgb, var(--violet) 8%, var(--bg-elevated))",
  },
  exam: { c: "var(--warning)", bg: "var(--exam-bg)" },
};
const t = TONES[tone];
---

<aside
  class="admonition"
  role="note"
  aria-label={ariaLabel ?? title}
  style={`--c:${t.c};--c-bg:${t.bg}`}
>
  <p class="adm-kicker">
    <span class="adm-icon" aria-hidden="true"
      ><Icon name={icon} size={15} /></span
    >
    {title}
  </p>
  <div class="adm-body"><slot /></div>
</aside>

<style>
  .admonition {
    margin-block: var(--space-5);
    padding: var(--space-4);
    border: 1px solid color-mix(in srgb, var(--c) 30%, var(--border));
    border-radius: var(--radius);
    background: var(--c-bg);
  }
  .adm-kicker {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking);
    font-weight: var(--weight-semibold);
    color: var(--c);
  }
  .adm-icon {
    flex: none;
    display: inline-flex;
    align-items: center;
  }
  /* Let the last child sit flush against the padding. */
  .adm-body :global(> :last-child) {
    margin-bottom: 0;
  }
</style>
