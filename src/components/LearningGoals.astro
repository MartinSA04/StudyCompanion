---
/**
 * A module's learning objectives ("læringsmål"). A dedicated block so authors
 * write `<LearningGoals>` + a list instead of overloading a note <Callout>, and
 * so goals read distinctly (teal) from notes/tips/warnings. Body is slotted MDX,
 * usually a bullet list. Subject-agnostic — the heading is a prop.
 */
import Admonition from "./Admonition.astro";

interface Props {
  title?: string;
}
const { title = "Læringsmål" } = Astro.props;
---

<Admonition tone="goals" icon="target" title={title}>
  <slot />
</Admonition>
