---
/**
 * Search palette (vanilla island) over the Pagefind index built in
 * `astro:build:done`. A trigger button in the header opens a native <dialog>;
 * `/` or ⌘K/Ctrl+K also open it, Esc closes it. Pagefind is loaded lazily on
 * first open via a runtime import of the emitted /pagefind/pagefind.js (so it
 * is excluded from the Vite bundle). In `astro dev` the index doesn't exist
 * yet, so the palette shows a friendly notice instead.
 */
interface Props {
  label?: string;
}
const { label = "Søk" } = Astro.props;
import Icon from "./Icon.astro";
---

<button type="button" class="search-trigger" aria-label={label}>
  <Icon name="search" size={17} class="search-icon" />
  <span class="search-trigger-text">{label}</span>
  <kbd class="search-kbd" data-search-kbd>⌘K</kbd>
</button>

<script is:inline data-astro-rerun>
  // The open shortcut is ⌘K on Apple platforms and Ctrl K elsewhere. The hint
  // can't be known at build time, so correct it at runtime. This inline script
  // runs synchronously as the parser passes it — the kbd above is already in the
  // DOM and gets fixed before first paint, so non-Mac users never see ⌘K flash.
  // data-astro-rerun re-applies it after each view-transition swap (the topbar,
  // and its kbd, is re-rendered from the server markup on navigation).
  (() => {
    const platform =
      navigator.userAgentData?.platform ?? navigator.platform ?? "";
    if (/mac|iphone|ipad|ipod/i.test(platform)) return; // default markup is correct
    for (const el of document.querySelectorAll("[data-search-kbd]")) {
      el.textContent = "Ctrl K";
    }
  })();
</script>

<dialog class="search-dialog" aria-label={label}>
  <form class="search-box" method="dialog" role="search">
    <Icon name="search" size={20} class="search-icon" />
    <input
      type="search"
      class="search-input"
      placeholder={`${label}…`}
      autocomplete="off"
      autocapitalize="off"
      spellcheck="false"
      aria-label={label}
    />
    <button type="submit" value="close" class="search-esc">Esc</button>
  </form>
  <div class="search-results" aria-live="polite"></div>
</dialog>

<style>
  .search-trigger {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    height: var(--control-h);
    padding-inline: var(--space-3);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg-elevated);
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    transition:
      color var(--dur-fast) var(--ease),
      border-color var(--dur-fast) var(--ease);
  }
  .search-trigger:hover {
    border-color: var(--border-strong);
    color: var(--fg);
  }
  /* Icons render from the <Icon> child (outside this scope) — reach via :global. */
  .search-trigger :global(.search-icon),
  .search-box :global(.search-icon) {
    flex: none;
  }
  .search-kbd {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: var(--radius-xs);
    padding: 0 0.35em;
    background: var(--card);
  }

  .search-dialog {
    width: min(620px, calc(100vw - 2 * var(--space-4)));
    margin-top: 12vh;
    margin-inline: auto;
    padding: 0;
    border-radius: var(--radius-lg);
    background: var(--bg-elevated);
    color: var(--fg);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }
  .search-dialog::backdrop {
    background: var(--scrim);
    backdrop-filter: blur(2px);
  }
  .search-box {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4);
    border-bottom: 1px solid var(--border);
  }
  .search-box :global(.search-icon) {
    color: var(--muted);
  }
  .search-input {
    flex: 1;
    border: 0;
    background: none;
    color: inherit;
    font-size: var(--text-md);
    outline: none;
  }
  /* Suppress the browser's unstyled type=search clear button — it doesn't match
     the palette; clearing is via backspace or Esc. */
  .search-input::-webkit-search-cancel-button {
    -webkit-appearance: none;
    appearance: none;
  }
  .search-esc {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: var(--radius-xs);
    padding: 0.15em 0.5em;
    background: var(--card);
    transition:
      color var(--dur-fast) var(--ease),
      border-color var(--dur-fast) var(--ease);
  }
  .search-esc:hover {
    color: var(--fg);
    border-color: var(--border-strong);
  }
  .search-results {
    max-height: min(60vh, 480px);
    overflow-y: auto;
    padding: var(--space-2);
  }
  .search-results:empty {
    display: none;
  }
  :global(.search-result) {
    display: block;
    padding: var(--space-3);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--fg);
  }
  :global(.search-result:hover),
  :global(.search-result:focus-visible) {
    background: var(--accent-weak);
  }
  :global(.search-result-title) {
    font-weight: var(--weight-semibold);
    margin-bottom: 2px;
  }
  :global(.search-result-excerpt) {
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: var(--leading-snug);
  }
  :global(.search-result-excerpt mark) {
    background: var(--accent-weak);
    color: var(--accent);
    border-radius: var(--radius-xs);
    padding: 0 2px;
  }
  :global(.search-empty) {
    padding: var(--space-4);
    color: var(--muted);
    font-size: var(--text-sm);
    text-align: center;
  }

  @media (max-width: 600px) {
    .search-trigger-text,
    .search-kbd {
      display: none;
    }
    .search-trigger {
      width: var(--control-h);
      justify-content: center;
      padding-inline: 0;
    }
  }
</style>

<script>
  import { onPage } from "../lib/pageLifecycle.ts";
  type PagefindSubResult = { title: string; url: string; excerpt: string };
  type PagefindData = {
    url: string;
    meta: { title?: string };
    excerpt: string;
    sub_results?: PagefindSubResult[];
  };
  type PagefindResult = { data: () => Promise<PagefindData> };
  type Pagefind = {
    options?: (o: Record<string, unknown>) => Promise<void>;
    search: (q: string) => Promise<{ results: PagefindResult[] }>;
  };

  // The pagefind bundle loads once and is cached across navigations (module
  // scope survives view-transition swaps), so search stays instant after nav.
  let pagefind: Pagefind | null = null;
  let loadFailed = false;
  const loadPagefind = async (): Promise<Pagefind | null> => {
    if (pagefind || loadFailed) return pagefind;
    try {
      // Runtime import of the static bundle. The specifier is a variable so
      // Rollup can't statically resolve it at build time (the index is only
      // emitted later, in astro:build:done); @vite-ignore silences the dev
      // analyzer warning.
      const bundle = "/pagefind/pagefind.js";
      const mod = (await import(/* @vite-ignore */ bundle)) as Pagefind;
      await mod.options?.({ excerptLength: 24 });
      pagefind = mod;
    } catch {
      loadFailed = true;
    }
    return pagefind;
  };

  // The topbar (trigger + dialog) is re-rendered on each swap, so (re)wire the
  // DOM per page-load; the page signal drops the ⌘K document listener on swap.
  onPage((signal) => {
    const trigger =
      document.querySelector<HTMLButtonElement>(".search-trigger");
    const dialog = document.querySelector<HTMLDialogElement>(".search-dialog");
    const input = document.querySelector<HTMLInputElement>(".search-input");
    const results = document.querySelector<HTMLDivElement>(".search-results");
    if (!trigger || !dialog || !input || !results) return;

    // Shown in the empty panel so an opened palette isn't a blank void.
    const HINT =
      '<p class="search-empty">Søk i moduler, formler, begreper og eksempler.</p>';

    const open = async () => {
      if (!dialog.open) dialog.showModal();
      input.focus();
      input.select();
      const pf = await loadPagefind();
      if (!pf && !results.childElementCount) {
        results.innerHTML =
          '<p class="search-empty">Søk er tilgjengelig i det bygde nettstedet (ikke i dev-modus).</p>';
      } else if (pf && !input.value.trim()) {
        results.innerHTML = HINT;
      }
    };

    trigger.addEventListener("click", open, { signal });

    document.addEventListener(
      "keydown",
      (e) => {
        const typing =
          document.activeElement instanceof HTMLInputElement ||
          document.activeElement instanceof HTMLTextAreaElement;
        if (
          (e.key === "k" && (e.metaKey || e.ctrlKey)) ||
          (e.key === "/" && !typing)
        ) {
          e.preventDefault();
          void open();
        }
      },
      { signal },
    );

    const render = (items: PagefindSubResult[]) => {
      if (!items.length) {
        results.innerHTML = '<p class="search-empty">Ingen treff.</p>';
        return;
      }
      results.innerHTML = items
        .map(
          (r) =>
            `<a class="search-result" href="${r.url}">` +
            `<div class="search-result-title">${r.title}</div>` +
            `<div class="search-result-excerpt">${r.excerpt}</div></a>`,
        )
        .join("");
      // Close the dialog when a result is chosen.
      results
        .querySelectorAll("a")
        .forEach((a) => a.addEventListener("click", () => dialog.close()));
    };

    let token = 0;
    const runSearch = async (q: string) => {
      const mine = ++token;
      const pf = await loadPagefind();
      if (!pf) return;
      const search = await pf.search(q);
      if (mine !== token) return; // a newer query superseded this one
      const flat: PagefindSubResult[] = [];
      for (const r of search.results.slice(0, 5)) {
        const data = await r.data();
        const subs = data.sub_results?.length
          ? data.sub_results
          : [
              {
                title: data.meta.title ?? "Treff",
                url: data.url,
                excerpt: data.excerpt,
              },
            ];
        flat.push(...subs);
        if (flat.length >= 8) break;
      }
      render(flat.slice(0, 8));
    };

    let debounce: ReturnType<typeof setTimeout>;
    input.addEventListener(
      "input",
      () => {
        clearTimeout(debounce);
        focusIdx = -1;
        const q = input.value.trim();
        if (!q) {
          results.innerHTML = HINT;
          return;
        }
        debounce = setTimeout(() => void runSearch(q), 160);
      },
      { signal },
    );

    // ---- ↑/↓ keyboard navigation through results ----
    let focusIdx = -1;

    input.addEventListener(
      "keydown",
      (e) => {
        const links = [...results.querySelectorAll<HTMLAnchorElement>("a")];
        if (e.key === "Enter" && !e.isComposing) {
          const target = focusIdx >= 0 ? links[focusIdx] : links[0];
          if (target) {
            e.preventDefault();
            target.click();
          }
        } else if (e.key === "ArrowDown") {
          const first = links[0];
          if (first) {
            e.preventDefault();
            first.focus();
            focusIdx = 0;
          }
        }
      },
      { signal },
    );

    results.addEventListener(
      "keydown",
      (e) => {
        const links = [...results.querySelectorAll<HTMLAnchorElement>("a")];
        if (!links.length) return;
        if (e.key === "ArrowDown") {
          e.preventDefault();
          if (focusIdx < links.length - 1) {
            focusIdx++;
            links[focusIdx].focus();
          }
        } else if (e.key === "ArrowUp") {
          e.preventDefault();
          if (focusIdx <= 0) {
            focusIdx = -1;
            input.focus();
          } else {
            focusIdx--;
            links[focusIdx].focus();
          }
        }
      },
      { signal },
    );

    dialog.addEventListener(
      "close",
      () => {
        focusIdx = -1;
      },
      { signal },
    );
  });
</script>
