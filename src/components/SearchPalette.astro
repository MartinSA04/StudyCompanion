---
/**
 * Search palette (vanilla island) over the Pagefind index built in
 * `astro:build:done`. A trigger button in the header opens a native <dialog>;
 * `/` or ⌘K/Ctrl+K also open it, Esc closes it. Pagefind is loaded lazily on
 * first open via a runtime import of the emitted /pagefind/pagefind.js (so it
 * is excluded from the Vite bundle). In `astro dev` the index doesn't exist
 * yet, so the palette shows a friendly notice instead.
 */
interface Props {
  label?: string;
}
const { label = "Søk" } = Astro.props;
import Icon from "./Icon.astro";
---

<button
  type="button"
  class="search-trigger sc-pill sc-press"
  aria-label={label}
>
  <Icon name="search" size={17} class="search-icon" />
  <span class="search-trigger-text">{label}</span>
  <kbd class="search-kbd sc-kbd" data-search-kbd>⌘K</kbd>
</button>

<script is:inline data-astro-rerun>
  // The open shortcut is ⌘K on Apple platforms and Ctrl K elsewhere. The hint
  // can't be known at build time, so correct it at runtime. This inline script
  // runs synchronously as the parser passes it — the kbd above is already in the
  // DOM and gets fixed before first paint, so non-Mac users never see ⌘K flash.
  // data-astro-rerun re-applies it after each view-transition swap (the topbar,
  // and its kbd, is re-rendered from the server markup on navigation).
  (() => {
    const platform =
      navigator.userAgentData?.platform ?? navigator.platform ?? "";
    if (/mac|iphone|ipad|ipod/i.test(platform)) return; // default markup is correct
    for (const el of document.querySelectorAll("[data-search-kbd]")) {
      el.textContent = "Ctrl K";
    }
  })();
</script>

<dialog class="search-dialog" aria-label={label}>
  <form class="search-box" method="dialog" role="search">
    <Icon name="search" size={20} class="search-icon" />
    <input
      type="search"
      class="search-input"
      placeholder={`${label}…`}
      autocomplete="off"
      autocapitalize="off"
      spellcheck="false"
      aria-label={label}
    />
    <button type="submit" value="close" class="search-esc sc-press sc-kbd"
      >Esc</button
    >
  </form>
  <div class="search-results"></div>
  {
    /* NOT the results container: making that tree live would re-announce the
      full innerHTML on every debounced keystroke. render() writes a concise
      count ("N treff" / "Ingen treff") here instead. */
  }
  <p class="search-status sr-only" role="status"></p>
</dialog>

<style>
  /* Marginalia surface + wash hover come from the shared .sc-pill primitive;
     only the control height + inline padding are local. */
  .search-trigger {
    gap: var(--space-2);
    /* min-height (not height) so the control grows when the kbd badge wraps to a
       second line at large text scale (WCAG 1.4.4); block padding is 0 at default
       size, so it still measures exactly --control-h (38px) and the topbar row
       stays aligned. flex-wrap lets the badge drop below the label rather than
       overflow the fixed box. */
    min-height: var(--control-h);
    padding-block: 0;
    padding-inline: var(--space-3);
    flex-wrap: wrap;
  }
  /* Icons render from the <Icon> child (outside this scope) — reach via :global. */
  .search-trigger :global(.search-icon),
  .search-box :global(.search-icon) {
    flex: none;
  }
  /* Frame comes from the shared .sc-kbd; only the tight inline padding is local. */
  .search-kbd {
    padding: 0 0.35em;
  }

  .search-dialog {
    width: min(620px, calc(100vw - 2 * var(--space-4)));
    margin-top: 12vh;
    margin-inline: auto;
    padding: 0;
    border: 0;
    border-radius: var(--radius-lg);
    background: var(--bg-elevated);
    color: var(--fg);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }
  /* Entry motion only — instant close is fine for a palette. Both keyframes
     run over --dur-fast, which zeroes under prefers-reduced-motion, so this
     collapses to a plain pop with no extra handling needed. */
  .search-dialog[open] {
    animation: search-dialog-in var(--dur-fast) var(--ease);
  }
  .search-dialog::backdrop {
    background: var(--scrim);
    backdrop-filter: blur(2px);
    animation: search-backdrop-in var(--dur-fast) var(--ease);
  }
  @keyframes search-dialog-in {
    from {
      opacity: 0;
      transform: translateY(-8px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @keyframes search-backdrop-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  .search-box {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4);
    border-bottom: 1px solid var(--border);
  }
  .search-box :global(.search-icon) {
    color: var(--muted);
  }
  .search-input {
    flex: 1;
    border: 0;
    background: none;
    color: inherit;
    font-size: var(--text-md);
    outline: none;
  }
  /* Suppress the browser's unstyled type=search clear button — it doesn't match
     the palette; clearing is via backspace or Esc. */
  .search-input::-webkit-search-cancel-button {
    -webkit-appearance: none;
    appearance: none;
  }
  /* Keycap frame from the shared .sc-kbd — a keycap is a bordered glyph, not a
     control, so the hairline stays (the sanctioned exception). Being clickable,
     the Esc button answers hover with the marginalia ink wash. */
  .search-esc {
    padding: 0.15em 0.5em;
    transition:
      color var(--dur-fast) var(--ease),
      background-color var(--dur-fast) var(--ease),
      transform var(--dur-fast) var(--ease);
  }
  .search-esc:hover {
    color: var(--accent-ink);
    background: var(--wash);
  }
  .search-results {
    max-height: min(60vh, 480px);
    overflow-y: auto;
    padding: var(--space-2);
  }
  .search-results:empty {
    display: none;
  }
  /* Hits are grouped per owning page; the head is the module's mono kicker
     (number + title), so identically-titled sections ("Hovedpunkter") from
     different modules stay tellable apart. */
  :global(.search-group) {
    margin-bottom: var(--space-2);
  }
  :global(.search-group:last-of-type) {
    margin-bottom: 0;
  }
  /* --muted, not --faint, throughout the dialog: the palette sits on
     --bg-elevated, where --faint is 4.47:1 in light — just under AA (--faint
     is only calibrated against the page --bg). */
  :global(.search-group-head) {
    margin: var(--space-2) var(--space-3) 2px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking);
    color: var(--muted);
  }
  :global(.search-more) {
    padding: var(--space-2) var(--space-3) var(--space-1);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
  }
  :global(.search-result) {
    display: block;
    padding: var(--space-3);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--fg);
  }
  :global(.search-result:hover),
  :global(.search-result:focus-visible) {
    background: var(--accent-weak);
  }
  :global(.search-result-title) {
    font-weight: var(--weight-semibold);
    margin-bottom: 2px;
  }
  :global(.search-result-excerpt) {
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: var(--leading-snug);
  }
  :global(.search-result-excerpt mark) {
    background: var(--accent-weak);
    color: var(--accent-ink);
    border-radius: var(--radius-xs);
    padding: 0 2px;
  }
  :global(.search-empty) {
    padding: var(--space-4);
    color: var(--muted);
    font-size: var(--text-sm);
    text-align: center;
  }
  :global(.search-empty-tip) {
    padding: 0 var(--space-4) var(--space-4);
    margin-top: calc(-1 * var(--space-3));
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-align: center;
  }

  @media (max-width: 640px) {
    .search-trigger-text,
    .search-kbd {
      display: none;
    }
    .search-trigger {
      width: var(--control-h);
      justify-content: center;
      padding-inline: 0;
    }
  }
</style>

<script>
  import { onPage } from "../lib/pageLifecycle.ts";
  type PagefindSubResult = { title: string; url: string; excerpt: string };
  type PagefindData = {
    url: string;
    /** `num` is the module folio number ([slug].astro sets it via data-pagefind-meta). */
    meta: { title?: string; num?: string };
    excerpt: string;
    sub_results?: PagefindSubResult[];
  };
  /** One owning page and its section hits. */
  type ResultGroup = {
    num?: string;
    title: string;
    items: PagefindSubResult[];
  };
  type PagefindResult = { data: () => Promise<PagefindData> };
  type Pagefind = {
    options?: (o: Record<string, unknown>) => Promise<void>;
    search: (q: string) => Promise<{ results: PagefindResult[] }>;
  };

  // The pagefind bundle loads once and is cached across navigations (module
  // scope survives view-transition swaps), so search stays instant after nav.
  let pagefind: Pagefind | null = null;
  // Only dev latches a failure: there the index simply doesn't exist (it's
  // emitted in astro:build:done), so retrying would just repeat the 404. A
  // production failure is treated as transient (flaky network mid-session) and
  // the import is retried on the next open()/search instead of poisoning the
  // whole session.
  let devMissing = false;
  const loadPagefind = async (): Promise<Pagefind | null> => {
    if (pagefind || devMissing) return pagefind;
    try {
      // Runtime import of the static bundle. The specifier is a variable so
      // Rollup can't statically resolve it at build time (the index is only
      // emitted later, in astro:build:done); @vite-ignore silences the dev
      // analyzer warning.
      const bundle = "/pagefind/pagefind.js";
      const mod = (await import(/* @vite-ignore */ bundle)) as Pagefind;
      await mod.options?.({ excerptLength: 24 });
      pagefind = mod;
    } catch {
      if (import.meta.env.DEV) devMissing = true;
    }
    return pagefind;
  };

  // The topbar (trigger + dialog) is re-rendered on each swap, so (re)wire the
  // DOM per page-load; the page signal drops the ⌘K document listener on swap.
  onPage((signal) => {
    const trigger =
      document.querySelector<HTMLButtonElement>(".search-trigger");
    const dialog = document.querySelector<HTMLDialogElement>(".search-dialog");
    const input = document.querySelector<HTMLInputElement>(".search-input");
    const results = document.querySelector<HTMLDivElement>(".search-results");
    const status = document.querySelector<HTMLElement>(".search-status");
    if (!trigger || !dialog || !input || !results || !status) return;

    // Shown in the empty panel so an opened palette isn't a blank void. The tip
    // line is where "/" gets its one piece of on-screen documentation.
    const isApple = /mac|iphone|ipad|ipod/i.test(
      (navigator as { userAgentData?: { platform?: string } }).userAgentData
        ?.platform ??
        navigator.platform ??
        "",
    );
    const HINT =
      '<p class="search-empty">Søk i moduler, formler, begreper og eksempler.</p>' +
      `<p class="search-empty-tip">Tips: «/» eller ${isApple ? "⌘K" : "Ctrl K"} åpner søket fra hvor som helst.</p>`;

    const esc = (s: string) =>
      s.replace(
        /[&<>"']/g,
        (c) =>
          ({
            "&": "&amp;",
            "<": "&lt;",
            ">": "&gt;",
            '"': "&quot;",
            "'": "&#39;",
          })[c]!,
      );

    const open = async () => {
      if (!dialog.open) dialog.showModal();
      input.focus();
      input.select();
      const pf = await loadPagefind();
      if (!pf && !results.childElementCount) {
        // Two different truths: dev has no index at all; production just
        // failed a fetch (and will retry on the next open).
        results.innerHTML = import.meta.env.DEV
          ? '<p class="search-empty">Søk er tilgjengelig i det bygde nettstedet (ikke i dev-modus).</p>'
          : '<p class="search-empty">Søket kunne ikke lastes. Prøv igjen.</p>';
      } else if (pf && !input.value.trim()) {
        results.innerHTML = HINT;
      }
    };

    trigger.addEventListener("click", open, { signal });

    // Dialog-level key handling that native <dialog> gets wrong.
    // • Escape: on a type=search input the first Escape is swallowed by
    //   Chromium's native clear-the-field behavior, so the dialog only closes on
    //   the second press. preventDefault() suppresses that clear and closes on
    //   the first press instead (close event resets focusIdx as before).
    // • Tab: native modal tab-order lets focus escape to document.body for one
    //   stop before wrapping (WCAG 2.4.3/2.1.2). Wrap explicitly across the
    //   currently-visible focusables, recomputed here since results change while
    //   typing.
    dialog.addEventListener(
      "keydown",
      (e) => {
        if (e.key === "Escape") {
          e.preventDefault();
          dialog.close();
          return;
        }
        if (e.key !== "Tab") return;
        // querySelectorAll returns document order regardless of selector order,
        // so first/last are the real DOM extremes: input -> Esc -> result anchors.
        const focusables = [
          ...dialog.querySelectorAll<HTMLElement>(
            ".search-input, .search-esc, .search-results a",
          ),
        ];
        if (!focusables.length) return;
        const first = focusables[0];
        const last = focusables[focusables.length - 1];
        const active = document.activeElement;
        if (e.shiftKey && active === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && active === last) {
          e.preventDefault();
          first.focus();
        }
      },
      { signal },
    );

    document.addEventListener(
      "keydown",
      (e) => {
        const typing =
          document.activeElement instanceof HTMLInputElement ||
          document.activeElement instanceof HTMLTextAreaElement;
        if (
          (e.key === "k" && (e.metaKey || e.ctrlKey)) ||
          (e.key === "/" && !typing)
        ) {
          e.preventDefault();
          void open();
        }
      },
      { signal },
    );

    const render = (groups: ResultGroup[], totalPages: number, q: string) => {
      const hits = groups.reduce((n, g) => n + g.items.length, 0);
      status.textContent = hits ? `${hits} treff` : "Ingen treff";
      if (!groups.length) {
        // A dead end with a next step, not just a verdict.
        results.innerHTML =
          `<p class="search-empty">Ingen treff for «${esc(q)}».<br>` +
          "Prøv et kortere ord eller et annet begrep.</p>";
        return;
      }
      const shownPages = groups.length;
      results.innerHTML =
        groups
          .map(
            (g) =>
              '<section class="search-group">' +
              (g.title
                ? `<h3 class="search-group-head">${
                    g.num ? `${esc(g.num)} · ` : ""
                  }${esc(g.title)}</h3>`
                : "") +
              g.items
                .map(
                  (r) =>
                    `<a class="search-result" href="${esc(r.url)}">` +
                    `<div class="search-result-title">${esc(r.title)}</div>` +
                    `<div class="search-result-excerpt">${r.excerpt}</div></a>`,
                )
                .join("") +
              "</section>",
          )
          .join("") +
        (totalPages > shownPages
          ? `<p class="search-more">Treff på ${totalPages} sider — viser de ${shownPages} første. Skriv mer for å avgrense.</p>`
          : "");
      // Close the dialog when a result is chosen.
      results
        .querySelectorAll("a")
        .forEach((a) => a.addEventListener("click", () => dialog.close()));
    };

    let token = 0;
    const runSearch = async (q: string) => {
      const mine = ++token;
      const pf = await loadPagefind();
      if (!pf) return;
      const search = await pf.search(q);
      if (mine !== token) return; // a newer query superseded this one
      // Keep hits grouped under their owning page (module) so same-titled
      // sections stay distinguishable; cap at 8 section hits over 5 pages.
      const groups: ResultGroup[] = [];
      let shown = 0;
      for (const r of search.results.slice(0, 5)) {
        if (shown >= 8) break;
        const data = await r.data();
        if (mine !== token) return;
        const subs = data.sub_results?.length
          ? data.sub_results
          : [
              {
                title: data.meta.title ?? "Treff",
                url: data.url,
                excerpt: data.excerpt,
              },
            ];
        const items = subs.slice(0, 8 - shown);
        shown += items.length;
        groups.push({
          num: data.meta.num,
          title: data.meta.title ?? "",
          items,
        });
      }
      render(groups, search.results.length, q);
    };

    let debounce: ReturnType<typeof setTimeout>;
    input.addEventListener(
      "input",
      () => {
        clearTimeout(debounce);
        focusIdx = -1;
        const q = input.value.trim();
        if (!q) {
          results.innerHTML = HINT;
          status.textContent = "";
          return;
        }
        debounce = setTimeout(() => void runSearch(q), 160);
      },
      { signal },
    );
    // The debounced search can outlive a swap; cancel it on teardown.
    signal.addEventListener("abort", () => clearTimeout(debounce), {
      once: true,
    });

    // ---- ↑/↓ keyboard navigation through results ----
    let focusIdx = -1;

    input.addEventListener(
      "keydown",
      (e) => {
        const links = [...results.querySelectorAll<HTMLAnchorElement>("a")];
        if (e.key === "Enter" && !e.isComposing) {
          // Always suppress the default: the input lives in a method="dialog"
          // form, so an Enter with no result to activate (empty-query hint, the
          // debounce window, or pagefind still loading) would otherwise submit
          // the form and close the palette.
          e.preventDefault();
          const target = focusIdx >= 0 ? links[focusIdx] : links[0];
          target?.click();
        } else if (e.key === "ArrowDown") {
          const first = links[0];
          if (first) {
            e.preventDefault();
            first.focus();
            focusIdx = 0;
          }
        }
      },
      { signal },
    );

    results.addEventListener(
      "keydown",
      (e) => {
        const links = [...results.querySelectorAll<HTMLAnchorElement>("a")];
        if (!links.length) return;
        if (e.key === "ArrowDown") {
          e.preventDefault();
          if (focusIdx < links.length - 1) {
            focusIdx++;
            links[focusIdx].focus();
          }
        } else if (e.key === "ArrowUp") {
          e.preventDefault();
          if (focusIdx <= 0) {
            focusIdx = -1;
            input.focus();
          } else {
            focusIdx--;
            links[focusIdx].focus();
          }
        }
      },
      { signal },
    );

    dialog.addEventListener(
      "close",
      () => {
        focusIdx = -1;
      },
      { signal },
    );
  });
</script>
