---
import type { Course } from "../schema.ts";
import type { NavItem, ToolFlags } from "../lib/nav.ts";
import { TOOL_SLUGS, partGroups } from "../lib/nav.ts";
import ThemeToggle from "../components/ThemeToggle.astro";
import SearchPalette from "../components/SearchPalette.astro";
import Icon from "../components/Icon.astro";
import { contrastText, accentOnBg, accentInk } from "../lib/color.ts";
import { THEME_COLOR_LIGHT, THEME_COLOR_DARK } from "../lib/themeColor.ts";
import { faviconDataUri } from "../lib/favicon.ts";
import { ogLocale, canonicalPathname, warnMissingSiteOnce } from "../lib/seo.ts";
import { formatDate } from "../lib/dates.ts";
import { progressKey as progressKeyFor } from "../lib/progress.ts";
import { serializeLd } from "../lib/jsonLd.ts";
import { ClientRouter } from "astro:transitions";
import "../styles/fonts.css";
import "../styles/tokens.css";
import "../styles/base.css";
import "../styles/primitives.css";
import "../styles/shell.css";
// Hashed URLs for the above-the-fold faces, used to preload them (the rest load
// from fonts.css). Fraunces is a variable file → preloading 400 covers all
// heading weights; Spectral 400 is the body face.
import displayFont from "../styles/fonts/fraunces-400-latin.woff2";
import bodyFont from "../styles/fonts/spectral-400-latin.woff2";
// The two KaTeX faces every math-bearing page paints on first render (upright
// + italic variables); preloading them avoids the flash-of-fallback-serif a
// module full of formulas would otherwise show while katex.min.css's own
// @font-face rules resolve. Gated on the per-page `hasMath` prop below — a page
// that renders zero KaTeX spans (overview, exam, most 404s) would otherwise pay
// ~48KB of preload for faces it never paints.
import katexMainFont from "katex/dist/fonts/KaTeX_Main-Regular.woff2?url";
import katexMathItalicFont from "katex/dist/fonts/KaTeX_Math-Italic.woff2?url";
// KaTeX's stylesheet as an emitted-URL asset instead of a bundled global
// import: only pages that pass the same `hasMath` gate as the preloads link
// it, keeping its ~29KB out of every prose-only page's always-loaded CSS.
// NOTE (build check): the ?url pipeline must still rewrite the url(fonts/…)
// references inside the emitted CSS to the hashed font assets — verify on a
// built math page before release.
import katexCss from "katex/dist/katex.min.css?url";

interface Props {
  course: Course;
  /** Ordered module nav items (sections only). */
  nav: NavItem[];
  /** Which reference-tool pages exist. */
  tools: ToolFlags;
  /** Active page: "top" (overview) or a section/tool slug. */
  active: string;
  /** Page <title>; defaults to the course title. */
  pageTitle?: string;
  /** "Edit this page" deep-link for the footer (section pages only). */
  editUrl?: string;
  /** Last-updated date for the footer freshness line (section pages only). */
  updated?: Date;
  /**
   * Per-page SEO / social meta, computed in the page where the data lives. The
   * layout renders the tags; every value is optional and degrades gracefully.
   */
  seo?: {
    /** `<meta name="description">` + `og:description`; pages always supply one (4.3). */
    description?: string;
    /** `og:type` — "article" for modules, "website" for overview/tools (4.2). */
    ogType?: "website" | "article";
    /** ISO date → `article:modified_time` (module pages with `updated`). */
    modifiedTime?: string;
    /** Keep out of search (4.6) → `<meta name="robots" content="noindex">`. */
    noindex?: boolean;
  };
  /** schema.org objects → one `<script type="application/ld+json">` each (4.4). */
  jsonLd?: Record<string, unknown>[];
  /** Render the right "on this page" rail column (module pages with a TOC). */
  hasToc?: boolean;
  /**
   * Does this page paint any KaTeX? Gates the two KaTeX-font preloads (see the
   * font imports). Pages compute it from their real inputs (lib/hasMath.ts);
   * defaults to `true` so a page that forgets to pass it keeps the preload
   * rather than risking a flash-of-fallback-serif on real math.
   */
  hasMath?: boolean;
}
const {
  course,
  nav,
  tools,
  active,
  pageTitle,
  editUrl,
  updated,
  seo,
  jsonLd,
  hasToc = false,
  hasMath = true,
} = Astro.props;
const { ui, features } = course;

// The framework's own source — linked from the "Bygget med" footer attribution.
const FRAMEWORK_REPO = "https://github.com/MartinSA04/StudyCompanion";

// ---- Accent contrast guardrails ----
// Grounds these checks sit on, verbatim from tokens.css. Kept as literal hex,
// matching the THEME_COLOR_* constants (lib/themeColor.ts), so this warns
// against the same values the CSS paints even if this file's imports ever get
// tree-shaken from a build. --accent-ink text (checkAccentInk): light lives on
// the page + its one panel step; dark on the panel + nested recess, not raw
// --bg (per the --accent-ink comment in tokens.css). --bg is also the ground
// the raw-accent focus ring + fallback-accent link sit on (checkAccentFallback).
const LIGHT_BG = "#fffcf0"; // --bg (light)
const LIGHT_BG_ELEVATED = "#f2f0e5"; // --bg-elevated (light)
const LIGHT_FG = "#100f0f"; // --fg (light)
const DARK_BG = "#100f0f"; // --bg (dark, Flexoki black)
const DARK_BG_ELEVATED = "#1c1b1a"; // --bg-elevated (dark)
const DARK_CARD_NESTED = "#282726"; // --card-nested (dark)
const DARK_FG = "#cecdc3"; // --fg (dark)

// De-duped per accent+fg pair per build. Astro re-runs a component's whole
// frontmatter on every page's render (unlike a plain imported .ts module,
// which is a real singleton — see `siteWarned` in lib/seo.ts), so a `const`
// here would reset every page; stash the guard on `globalThis` instead, which
// is the one thing that actually survives across those re-runs for the life
// of the `astro build`/`astro dev` process.
const scGlobal = globalThis as unknown as { __scWarnedAccents?: Set<string> };
const warnedAccents = (scGlobal.__scWarnedAccents ??= new Set<string>());

/**
 * Warn (never throw — an unreadable accent shouldn't fail a course's build)
 * when `accent` mixed through the Accent-Ink Rule (--accent-ink: 75% accent /
 * 25% ink) would fail AA as TEXT on the grounds it actually renders on.
 */
function checkAccentInk(
  accent: string,
  fg: string,
  surfaces: [name: string, hex: string][],
  theme: "light" | "dark",
) {
  const key = `ink:${theme}:${accent}:${fg}`;
  if (warnedAccents.has(key)) return;
  const ink = accentInk(accent, fg);
  for (const [name, hex] of surfaces) {
    const r = accentOnBg(ink, hex);
    if (r != null && r < 4.5) {
      warnedAccents.add(key);
      console.warn(
        `[study-companion] ${theme} accent "${accent}" mixed through --accent-ink has ${r.toFixed(2)}:1 on ${name} — accent text may be hard to read. Pick a ${theme === "dark" ? "lighter (set accentDark)" : "darker"} shade.`,
      );
      return;
    }
  }
}

/**
 * Warn (never throw) when the on-accent text tokens.css paints (--accent-contrast
 * = `onAccent`, derived by contrastText) fails AA normal-text (4.5:1) as TEXT ON
 * the accent FILL — the skip-link, SelfCheck badge and filled chips. contrastText
 * already picks the higher-contrast of white / near-black ink per theme (in dark,
 * light accents pair with the #100f0f ink the token default now also uses), so a
 * warning here means the accent itself is a mid-tone that neither ink clears.
 */
function checkAccentContrast(
  accent: string,
  onAccent: string,
  theme: "light" | "dark",
) {
  const key = `on:${theme}:${accent}:${onAccent}`;
  if (warnedAccents.has(key)) return;
  const r = accentOnBg(onAccent, accent);
  if (r != null && r < 4.5) {
    warnedAccents.add(key);
    console.warn(
      `[study-companion] ${theme} accent "${accent}" gives ${r.toFixed(2)}:1 for its on-accent text "${onAccent}" — text on the filled accent (skip-link, badges, chips) may be hard to read. Pick a shade further from mid-tone.`,
    );
  }
}

/**
 * Warn (never throw) when a course omits `accentDark`: dark `--accent` then falls
 * back to the light accent (tokens.css), which for a typical dark-enough brand is
 * too weak against the dark `--bg` for the 3:1 UI floor — and raw `--accent`
 * drives the global `:focus-visible` ring + accent-as-UI marks (icons, borders).
 * Only meaningful on the fallback pairing, so callers gate on `accentDark` unset.
 */
function checkAccentFallback(accent: string) {
  const key = `fallback:${accent}`;
  if (warnedAccents.has(key)) return;
  const r = accentOnBg(accent, DARK_BG);
  if (r != null && r < 3) {
    warnedAccents.add(key);
    console.warn(
      `[study-companion] dark mode falls back to the light accent "${accent}" (no accentDark set), only ${r.toFixed(2)}:1 on the dark --bg — below the 3:1 UI floor for the focus ring and accent marks. Set a lighter accentDark.`,
    );
  }
}

// Module nav grouped into parts (single null-part group when no section sets one).
const moduleGroups = partGroups(nav);

const updatedStr = updated ? formatDate(updated, course.language) : null;

// Per-theme brand accent. The course sets `accent` (light) and optionally
// `accentDark`; the framework uses exactly those (no auto-lightening) and
// derives the legible text colour that sits ON each. tokens.css switches
// `--accent` / `--accent-contrast` to the right pair per theme.
const accentLight = course.accent;
const accentDark = course.accentDark ?? course.accent;
const onAccentLight = contrastText(accentLight);
const onAccentDark = contrastText(accentDark);
const accentVars =
  `--accent-light: ${accentLight}; --accent-dark: ${accentDark}; ` +
  `--accent-contrast-light: ${onAccentLight}; --accent-contrast-dark: ${onAccentDark};`;
checkAccentInk(
  accentLight,
  LIGHT_FG,
  [
    ["--bg", LIGHT_BG],
    ["--bg-elevated", LIGHT_BG_ELEVATED],
  ],
  "light",
);
checkAccentInk(
  accentDark,
  DARK_FG,
  [
    ["--bg-elevated", DARK_BG_ELEVATED],
    ["--card-nested", DARK_CARD_NESTED],
  ],
  "dark",
);
// On-accent text (--accent-contrast) legibility ON the accent fill, both themes.
checkAccentContrast(accentLight, onAccentLight, "light");
checkAccentContrast(accentDark, onAccentDark, "dark");
// Fallback-accent UI floor: only when the course left accentDark unset, so dark
// `--accent` inherits the (often too-dark) light accent for its focus ring/marks.
if (course.accentDark == null) checkAccentFallback(accentLight);

const themeKey = `sc:theme:${course.code}`;
// Single-sourced from lib/progress so the key template and the scripts that
// read it can never disagree on the shape.
const progressKey = progressKeyFor(course.code);
const title = pageTitle
  ? `${pageTitle} · ${course.code}`
  : `${course.code} · ${course.title}`;
const ogTitle = pageTitle ?? course.title;

// ---- SEO / social metadata (4.1–4.4, 4.7) ----
// All derived from course.yaml + the page props. Absolute-URL features need
// `site` in the course's astro.config.mjs; without it they degrade (skipped +
// one DEV warning) rather than emitting unusable relative URLs.
const site = Astro.site;
const canonicalUrl = site
  ? new URL(canonicalPathname(Astro.url.pathname), site).href
  : null;
if (import.meta.env.DEV && !site) warnMissingSiteOnce();

const metaDescription =
  seo?.description ??
  (course.subtitle ? `${course.title} — ${course.subtitle}` : course.title);
const ogType = seo?.ogType ?? "website";
const siteName = `${course.code} ${course.title}`;
const locale = ogLocale(course.language);
// Interim social-card image: the build-time raster app icon (4.9). A square
// logo → a `summary` Twitter card; 4.11 will add a 1200×630 `summary_large_image`.
const ogImage = site ? new URL("/icon-512.png", site).href : null;
const twitterHandle = course.seo?.twitter
  ? course.seo.twitter.startsWith("@")
    ? course.seo.twitter
    : `@${course.seo.twitter}`
  : null;

// Browser-chrome / native-control colours (THEME_COLOR_*, imported from
// lib/themeColor.ts) — the mobile toolbar per theme, and the same source the
// PWA manifest install-splash reads, so the two can never drift.

type IconName = "sigma" | "book" | "layers" | "file";
const toolNav: { slug: string; icon: IconName; label: string; show: boolean }[] = [
  { slug: TOOL_SLUGS.formulas, icon: "sigma", label: ui.formulaSheetLabel, show: tools.formulas },
  { slug: TOOL_SLUGS.glossary, icon: "book", label: ui.glossaryLabel, show: tools.glossary },
  { slug: TOOL_SLUGS.flashcards, icon: "layers", label: ui.flashcardsLabel, show: tools.flashcards },
  { slug: TOOL_SLUGS.exams, icon: "file", label: ui.examsLabel, show: tools.exams },
];
const hasTools = toolNav.some((t) => t.show);
---

<!doctype html>
<html lang={course.language} style={accentVars}>
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    {/* The `>_` mark, tinted to this course's accent so each tab is
        identifiable. Uses the dark-surface accent since the mark's ground is
        near-black; inlined per render, so no per-course favicon file. */}
    <link rel="icon" type="image/svg+xml" href={faviconDataUri(accentDark)} />
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    {seo?.noindex && <meta name="robots" content="noindex" />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    {/* Browser-chrome + native-control theming (4.7). ONE un-mediaed meta,
        owned by the theme scripts: dark rendering only ever comes from script
        setting data-theme (tokens.css has no prefers-color-scheme fallback),
        so a media-keyed dark meta would paint dark chrome on a light page for
        a no-JS dark-OS reader, and could never track the persisted ThemeToggle
        choice. The no-flash init recolours it pre-paint; `sc:themechange`
        keeps it tracking later flips. Ground verbatim from tokens.css;
        `format-detection` stops iOS auto-linking decimals/ranges (e.g. 1.5,
        240) in a physics/maths guide as tap-to-call numbers. */}
    <meta name="theme-color" content={THEME_COLOR_LIGHT} />
    <meta name="color-scheme" content="light dark" />
    <meta name="format-detection" content="telephone=no" />

    {/* Installable PWA + Apple home-screen (4.8–4.10, 4.15). The raster icons
        and pinned-tab mask are emitted per-course at build (astro:build:done);
        the manifest is an injected endpoint. */}
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color={accentDark} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta
      name="apple-mobile-web-app-status-bar-style"
      content="black-translucent"
    />
    <meta name="apple-mobile-web-app-title" content={course.code} />
    <meta name="application-name" content={course.code} />
    <meta name="generator" content="study-companion" />

    {/* Open Graph + Twitter card (4.2) — link unfurls in chats / search. */}
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={locale} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:alt" content={siteName} />}
    {
      ogType === "article" && seo?.modifiedTime && (
        <meta property="article:modified_time" content={seo.modifiedTime} />
      )
    }
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={metaDescription} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    {twitterHandle && <meta name="twitter:site" content={twitterHandle} />}
    {twitterHandle && <meta name="twitter:creator" content={twitterHandle} />}

    {/* schema.org structured data (4.4) — Course / LearningResource /
        BreadcrumbList / DefinedTermSet, built per page kind in the page. */}
    {
      jsonLd?.map((obj) => (
        <script type="application/ld+json" set:html={serializeLd(obj)} />
      ))
    }

    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href={bodyFont}
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href={displayFont}
      crossorigin
    />
    {
      hasMath && (
        <>
          {/* KaTeX CSS rides the same gate as its font preloads: a page that
              paints no math (overview, exam, most 404s) never fetches it. */}
          <link rel="stylesheet" href={katexCss} />
          <link
            rel="preload"
            as="font"
            type="font/woff2"
            href={katexMainFont}
            crossorigin
          />
          <link
            rel="preload"
            as="font"
            type="font/woff2"
            href={katexMathItalicFont}
            crossorigin
          />
        </>
      )
    }
    {
      features.theme && (
        <script
          is:inline
          define:vars={{
            themeKey,
            themeColorLight: THEME_COLOR_LIGHT,
            themeColorDark: THEME_COLOR_DARK,
          }}
        >
          // No-flash: set the theme before first paint, and — crucially — set it
          // on the INCOMING document during a view-transition swap. The fetched
          // static document has no data-theme (it's client-set), so swapping it in
          // paints one light frame before the theme is re-applied. Doing it in
          // `astro:before-swap` (on e.newDocument) means the swap never sees light;
          // `astro:after-swap` alone is a frame too late and flashes bright.
          (function () {
            function isDark() {
              try {
                const saved = localStorage.getItem(themeKey);
                return saved
                  ? saved === "dark"
                  : matchMedia("(prefers-color-scheme: dark)").matches;
              } catch (e) {
                return false;
              }
            }
            // Browser chrome (<meta name="theme-color">) follows the EFFECTIVE
            // theme — the data-theme the scripts applied, which a persisted
            // ThemeToggle choice can hold against the OS preference — so it is
            // painted from the applied attribute, never recomputed from the OS.
            function paintChrome(root) {
              const dark = root.getAttribute("data-theme") === "dark";
              const doc = root.ownerDocument || document;
              const meta = doc.querySelector('meta[name="theme-color"]');
              if (meta)
                meta.setAttribute(
                  "content",
                  dark ? themeColorDark : themeColorLight,
                );
            }
            function applyTheme(root) {
              root = root || document.documentElement;
              if (isDark()) root.setAttribute("data-theme", "dark");
              else root.removeAttribute("data-theme");
              paintChrome(root);
            }
            applyTheme();
            document.addEventListener("astro:before-swap", function (e) {
              applyTheme(e.newDocument.documentElement);
            });
            document.addEventListener("astro:after-swap", function () {
              applyTheme();
            });
            // Track a live OS theme flip (e.g. the system switching at sunset)
            // for a reader who never picked a theme explicitly — an explicit
            // localStorage choice always wins and this listener leaves it alone.
            // Guarded so a view-transition swap re-embedding this same inline
            // script never registers the listeners twice.
            if (!window.__scOsThemeBound) {
              window.__scOsThemeBound = true;
              // An explicit toggle flip (ThemeToggle dispatches after applying
              // data-theme + persisting) re-paints the chrome meta too. Reads
              // the applied attribute, so it also stays right in private mode
              // where the persist step silently fails.
              document.addEventListener("sc:themechange", function () {
                paintChrome(document.documentElement);
              });
              matchMedia("(prefers-color-scheme: dark)").addEventListener(
                "change",
                function () {
                  try {
                    if (localStorage.getItem(themeKey)) return;
                  } catch (e) {
                    /* private mode / storage disabled — fall through, OS still wins */
                  }
                  applyTheme();
                  document.dispatchEvent(
                    new CustomEvent("sc:themechange", {
                      detail:
                        document.documentElement.getAttribute("data-theme") ===
                        "dark"
                          ? "dark"
                          : "light",
                    }),
                  );
                },
              );
            }
          })();
        </script>
      )
    }
    {
      /* Privacy-friendly analytics. Production builds only (never in `astro
         dev`); GoatCounter is cookieless, so no consent banner is needed.
         `is:inline` emits the third-party CDN tag verbatim (no Astro bundling). */
      import.meta.env.PROD && course.analytics?.goatcounter && (
        <>
          <script
            is:inline
            data-goatcounter={course.analytics.goatcounter}
            async
            src="https://gc.zgo.at/count.js"></script>
          {/* count.js self-counts the initial load but never hooks the History
              API, so every view-transition navigation goes uncounted. Bridge
              them off astro:page-load: skip the first firing (it coincides with
              the load count.js already logged) and count each later one. The
              listener registers once — ClientRouter does not re-run an identical
              head inline script across swaps, so this persists as-is. */}
          <script is:inline>
            {`(function () {
              var first = true;
              document.addEventListener("astro:page-load", function () {
                if (first) { first = false; return; }
                if (window.goatcounter && window.goatcounter.count)
                  window.goatcounter.count({
                    path: location.pathname + location.search,
                  });
              });
            })();`}
          </script>
        </>
      )
    }

    {/* Cross-fade page-to-page navigation, so paging through modules reads as one
        continuous surface. Astro disables the animation under prefers-reduced-motion. */}
    <ClientRouter />
  </head>
  <body data-progress-key={progressKey} data-section-total={nav.length}>
    <a class="skip-link" href="#content">{ui.skipToContent}</a>

    <div class="topbar">
      <div class="topbar-inner">
        <button
          class="menu-toggle sc-icon-btn sc-press"
          type="button"
          aria-label="Åpne meny"
          aria-controls="sidebar"
          aria-expanded="false"><Icon name="menu" size={18} /></button>
        <a class="brand" href="/">
          {/* Same `>_` mark as the favicon (geometry mirrors lib/favicon.ts),
              but transparent rather than on the black ground, and using the
              live `--accent` so it tracks the theme. */}
          <svg class="brand-mark" viewBox="0 0 64 64" aria-hidden="true">
            <rect x="4" y="6" width="56" height="52" rx="9" fill="none" stroke="currentColor" stroke-width="5"></rect>
            <path d="M18 21l11 11-11 11" fill="none" stroke="currentColor" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"></path>
            <rect x="34" y="41" width="17" height="6" rx="2" fill="currentColor"></rect>
          </svg>
          <span class="brand-text">
            <span class="brand-title"
              ><span class="brand-code">{course.code}</span>{" "}<span
                class="brand-name">{course.title}</span
              ></span
            >
            <span class="brand-sub">
              {course.subtitle ? `${course.subtitle} · ` : ""}{course.term}
            </span>
          </span>
        </a>
        <div class="spacer"></div>
        {
          features.progress && (
            <div
              class="progresswrap"
              aria-label={ui.progressLabel}
              title="Lagres lokalt i denne nettleseren">
              <span class="lbl-txt">{ui.progressLabel}</span>
              <div
                class="progressbar"
                role="progressbar"
                aria-valuemin="0"
                aria-valuemax="100"
                aria-valuenow="0">
                <div class="progressfill" data-progress-fill></div>
              </div>
              <span class="num" data-progress-text>0/{nav.length}</span>
            </div>
          )
        }
        {features.search && <SearchPalette label={ui.searchLabel} />}
        {features.theme && <ThemeToggle storageKey={themeKey} />}
      </div>
    </div>

    <div class="scrim" data-scrim></div>

    {
      /* Cloned by setupPage() onto each code block. Keeping the copy button in a
         template sources its icons from <Icon> instead of hardcoding SVG in the
         script; box + icon-swap + press come from the shared .sc-copy / .sc-press
         primitives (the same ones the formula sheet's copy control uses). */
    }
    <template id="code-copy-tpl">
      <button
        type="button"
        class="code-copy sc-copy sc-press"
        aria-label="Kopier kode"
        title="Kopier kode"
      >
        <Icon name="copy" class="i-copy" />
        <Icon name="check" class="i-check" />
      </button>
    </template>

    <div class:list={["layout", { "layout--toc": hasToc }]}>
      <aside class="sidebar" id="sidebar" aria-label="Moduler">
        {/* Visible only in the mobile drawer — the desktop rail has no overlay
            to dismiss. Fills the drawer's top padding so it never overlaps a
            nav row. */}
        <button class="sidebar-close sc-icon-btn sc-press" type="button" aria-label="Lukk meny">
          <Icon name="x" size={18} />
        </button>
        <a
          class={`nav-link sc-press sc-lift${active === "top" ? " active" : ""}`}
          href="/"
          aria-current={active === "top" ? "page" : undefined}>
          <span class="nav-num"><Icon name="grid" /></span>
          <span class="nav-title">Oversikt</span>
        </a>

        {
          hasTools && (
            <>
              <div class="nav-section">Verktøy</div>
              {toolNav
                .filter((t) => t.show)
                .map((t) => (
                  <a
                    class={`nav-link sc-press sc-lift${active === t.slug ? " active" : ""}`}
                    href={`/${t.slug}`}
                    aria-current={active === t.slug ? "page" : undefined}>
                    <span class="nav-num">
                      <Icon name={t.icon} />
                    </span>
                    <span class="nav-title">{t.label}</span>
                  </a>
                ))}
            </>
          )
        }

        {
          moduleGroups.map((group) => (
            <>
              <div class="nav-section">{group.part ?? "Moduler"}</div>
              {group.items.map((item) => (
                <a
                  class={`nav-link sc-press sc-lift${active === item.slug ? " active" : ""}`}
                  href={`/${item.slug}`}
                  data-nav-slug={item.slug}
                  data-nav-order={item.order}
                  aria-current={active === item.slug ? "page" : undefined}>
                  <span class="nav-num">{item.num}</span>
                  <span class="nav-title">{item.shortTitle}</span>
                  <span class="nav-check" aria-hidden="true">
                    <Icon name="check" size={14} />
                  </span>
                  {/* Text companion to the aria-hidden check icon, kept in sync
                      with the .done class by paintProgress() so the link's
                      accessible name always states completion too. */}
                  <span class="sr-only" data-done-sr></span>
                </a>
              ))}
            </>
          ))
        }

        {
          course.links.length > 0 && (
            <>
              <div class="nav-section">Lenker</div>
              {course.links.map((l) => (
                <a class="nav-link sc-press sc-lift" href={l.url} target="_blank" rel="noopener noreferrer">
                  <span class="nav-num"><Icon name="external" /></span>
                  <span class="nav-title">{l.label}</span>
                </a>
              ))}
            </>
          )
        }
      </aside>

      {
        /* Before <main> in the DOM so the tab order runs nav → on-this-page →
           content; the grid (shell.css) still paints it as the right column.
           Without this the rail was the LAST stop, after the footer. */
        hasToc && (
          <aside class="toc-rail" aria-label={ui.tocLabel}>
            <slot name="toc" />
          </aside>
        )
      }

      <main class="content" id="content" tabindex="-1">
        <slot />
        <footer class="site-footer">
          {
            (updatedStr || editUrl) && (
              <p class="footer-meta">
                {updatedStr && (
                  <span>
                    {ui.updatedLabel} {updatedStr}
                  </span>
                )}
                {editUrl && (
                  <a
                    class="footer-edit"
                    href={editUrl}
                    target="_blank"
                    rel="noopener noreferrer">
                    {ui.editPageLabel}
                  </a>
                )}
              </p>
            )
          }
          <p>{course.code} · {course.title} · {course.term}</p>
          {
            course.courseUrl && (
              <p>
                <a
                  class="accent-text"
                  href={course.courseUrl}
                  target="_blank"
                  rel="noopener noreferrer">
                  {ui.courseLabel}
                </a>
              </p>
            )
          }
          <p>
            Bygget med
            <a
              class="accent-text"
              href={FRAMEWORK_REPO}
              target="_blank"
              rel="noopener noreferrer">
              study-companion
            </a>
          </p>
        </footer>
      </main>
    </div>

    {/* Page-shell behavior (progress, menu, copy buttons, key nav). A bundled
        module — NOT is:inline — so the ~11KB ships once as a cached asset
        instead of being duplicated verbatim into every emitted page; the
        course-specific inputs ride the <body> data attributes instead of
        define:vars. */}
    <script>
      import { readProgress, writeProgress } from "../lib/progress.ts";

      // ---- Reading progress (per course, localStorage) ----
      // Stored as an array of section slugs, keyed off <body data-progress-key>
      // per call rather than captured — the astro:before-swap paint below
      // targets the INCOMING document. See lib/progress.ts for the migration /
      // pruning / dirty-writeback contract behind readProgress/writeProgress.

      // ---- Mobile menu open/close ----
      // A plain function (not nested in setupPage) so the global Escape
      // handler further down can reuse the same trap/scroll-lock logic;
      // elements are queried fresh each call since a view-transition swap
      // replaces the sidebar/topbar DOM.
      function toggleMenu(open?: boolean) {
        const sidebar = document.getElementById("sidebar");
        if (!sidebar) return;
        const menuBtn = document.querySelector<HTMLElement>(".menu-toggle");
        const scrim = document.querySelector("[data-scrim]");
        const next = open ?? !sidebar.classList.contains("open");
        sidebar.classList.toggle("open", next);
        if (scrim) scrim.classList.toggle("show", next);
        if (menuBtn) menuBtn.setAttribute("aria-expanded", String(next));
        // Trap focus in the open drawer: `inert` everything else reachable by
        // Tab — the skip-link (rendered before the topbar, so it's a sibling
        // rather than a topbar-inner child), the main content, the TOC rail,
        // and the topbar's other controls (the toggle itself lives among
        // those and must stay operable) — and lock the background scroll.
        // The scrim is left alone so a click on it still closes the drawer.
        const skipLink = document.querySelector(".skip-link");
        const content = document.getElementById("content");
        const tocRail = document.querySelector(".toc-rail");
        const topbarInner = document.querySelector(".topbar-inner");
        const outside = [
          skipLink,
          content,
          tocRail,
          ...(topbarInner ? [...topbarInner.children] : []),
        ];
        outside.forEach((el) => {
          if (el && el !== menuBtn) el.toggleAttribute("inert", next);
        });
        document.documentElement.style.overflow = next ? "hidden" : "";
        // Move focus into the drawer on open; return it to the toggle on close.
        if (next) sidebar.querySelector("a")?.focus();
        else if (menuBtn) menuBtn.focus();
      }

      // ---- Deep-link arrival focus ----
      // The browser already scrolled `:target` into view; if it's one of the
      // rows the widgets mark `tabindex="-1"` (Statement / Glossary /
      // FormulaSheet anchors), also move keyboard focus there so a screen
      // reader announces it and Tab continues from that row.
      function focusDeepLinkTarget() {
        const hash = location.hash.slice(1);
        if (!hash) return;
        const target = document.getElementById(hash);
        if (target && target.getAttribute("tabindex") === "-1") {
          target.focus({ preventScroll: true });
        }
      }

      function paintProgress(doc?: Document) {
        doc = doc || document;
        const fill = doc.querySelector<HTMLElement>("[data-progress-fill]");
        const text = doc.querySelector("[data-progress-text]");
        const bar = fill ? fill.closest(".progressbar") : null;
        const navLinks = [...doc.querySelectorAll<HTMLElement>("[data-nav-slug]")];
        const total = Number(doc.body.dataset.sectionTotal ?? 0);
        const set = readProgress(doc);
        let count = 0;
        navLinks.forEach((a) => {
          const on = set.has(a.dataset.navSlug!);
          if (on) count++;
          a.classList.toggle("done", on);
          // Keep the sr-only text companion (see the aria-hidden check icon
          // beside it) in lockstep with the visual .done class.
          const sr = a.querySelector("[data-done-sr]");
          if (sr) sr.textContent = on ? ", fullført" : "";
        });
        const pct = total ? Math.round((count / total) * 100) : 0;
        if (fill) fill.style.transform = `scaleX(${pct / 100})`;
        if (bar) bar.setAttribute("aria-valuenow", String(pct));
        if (text) text.textContent = count + "/" + total;
      }

      // The current page may carry a "mark done" button (set in [slug].astro).
      function paintDoneBtn(doc?: Document) {
        doc = doc || document;
        const doneBtn = doc.querySelector<HTMLElement>("[data-done-slug]");
        if (!doneBtn) return;
        const on = readProgress(doc).has(doneBtn.dataset.doneSlug!);
        doneBtn.classList.toggle("done", on);
        // The check (an SVG) shows via the .done class; only swap the label text.
        const label = doneBtn.querySelector("[data-done-label]");
        if (label) label.textContent = on ? "Fullført" : "Marker fullført";
      }

      // ---- Per-page setup: repaint + (re)bind page-scoped elements. Runs on the
      // first load and after every view-transition swap; a data-flag keeps a
      // listener from binding twice on the same element. ----
      function setupPage() {
        paintProgress();
        paintDoneBtn();
        focusDeepLinkTarget();

        const doneBtn = document.querySelector<HTMLElement>("[data-done-slug]");
        if (doneBtn && !doneBtn.dataset.scBound) {
          doneBtn.dataset.scBound = "1";
          doneBtn.addEventListener("click", () => {
            const slug = doneBtn.dataset.doneSlug!;
            const set = readProgress(document);
            if (set.has(slug)) set.delete(slug);
            else set.add(slug);
            writeProgress(document, set);
            paintDoneBtn();
            paintProgress();
          });
        }

        // ---- Mobile menu ----
        const menuBtn = document.querySelector<HTMLElement>(".menu-toggle");
        const sidebar = document.getElementById("sidebar");
        const scrim = document.querySelector<HTMLElement>("[data-scrim]");
        if (menuBtn && !menuBtn.dataset.scBound) {
          menuBtn.dataset.scBound = "1";
          menuBtn.addEventListener("click", () => toggleMenu());
        }
        if (scrim && !scrim.dataset.scBound) {
          scrim.dataset.scBound = "1";
          scrim.addEventListener("click", () => toggleMenu(false));
        }
        const closeBtn = sidebar?.querySelector<HTMLElement>(".sidebar-close");
        if (closeBtn && !closeBtn.dataset.scBound) {
          closeBtn.dataset.scBound = "1";
          closeBtn.addEventListener("click", () => toggleMenu(false));
        }

        // ---- Copy buttons on code blocks (icon button cloned from template) ----
        const copyTpl = document.getElementById(
          "code-copy-tpl",
        ) as HTMLTemplateElement | null;
        if (copyTpl) {
          document
            .querySelectorAll<HTMLPreElement>(".content pre")
            .forEach((pre) => {
            if (pre.querySelector(".code-copy")) return;
            const btn = copyTpl.content.firstElementChild!.cloneNode(
              true,
            ) as HTMLButtonElement;
            let copyTimer: ReturnType<typeof setTimeout> | undefined;
            btn.addEventListener("click", async () => {
              const code = pre.querySelector("code");
              try {
                await navigator.clipboard.writeText(
                  code ? code.innerText : pre.innerText,
                );
                // The copy→check icon swap is pure CSS on [data-copied]; the
                // label swap is the announcement an AT user gets in its place.
                btn.dataset.copied = "true";
                btn.setAttribute("aria-label", "Kopiert");
                clearTimeout(copyTimer);
                copyTimer = setTimeout(() => {
                  btn.dataset.copied = "false";
                  btn.setAttribute("aria-label", "Kopier kode");
                }, 1500);
              } catch {}
            });
            pre.appendChild(btn);
          });
        }
      }

      // ---- Global listeners: bound once, persist across view-transition swaps.
      // (document survives navigation; each handler queries at event time so it
      // always acts on the current page's elements.) ----

      // Escape closes the mobile drawer.
      document.addEventListener("keydown", (e) => {
        const sidebar = document.getElementById("sidebar");
        if (e.key !== "Escape" || !sidebar || !sidebar.classList.contains("open"))
          return;
        toggleMenu(false);
      });

      // A hash change while already on the page (clicking an in-page anchor,
      // not a full navigation — astro:page-load covers that case) also moves
      // focus to a `tabindex="-1"` deep-link target.
      addEventListener("hashchange", focusDeepLinkTarget);

      // ---- Arrow-key prev/next module ----
      document.addEventListener("keydown", (e) => {
        if (e.metaKey || e.ctrlKey || e.altKey || e.shiftKey) return;
        const active = document.activeElement;
        const typing =
          active instanceof HTMLInputElement ||
          active instanceof HTMLTextAreaElement ||
          active instanceof HTMLSelectElement ||
          active?.getAttribute("contenteditable") === "true";
        if (typing) return;
        if (document.querySelector<HTMLDialogElement>(".search-dialog")?.open)
          return;
        if (e.key === "ArrowLeft") {
          const link = document.querySelector("[data-page-prev]");
          if (link instanceof HTMLAnchorElement) { e.preventDefault(); link.click(); }
        } else if (e.key === "ArrowRight") {
          const link = document.querySelector("[data-page-next]");
          if (link instanceof HTMLAnchorElement) { e.preventDefault(); link.click(); }
        }
      });

      // ---- Print prep ----
      // Paper is white and has no disclosure triangles: force the light theme
      // and expand every <details> so collapsed solutions/derivations/answers
      // print, then restore the on-screen state afterwards. (CSS alone can't
      // reveal closed-<details> content.)
      let printOpened: HTMLDetailsElement[] = [];
      let printWasDark = false;
      addEventListener("beforeprint", () => {
        printWasDark =
          document.documentElement.getAttribute("data-theme") === "dark";
        if (printWasDark) document.documentElement.removeAttribute("data-theme");
        printOpened = [
          ...document.querySelectorAll<HTMLDetailsElement>(
            "details:not([open])",
          ),
        ];
        printOpened.forEach((d) => (d.open = true));
      });
      addEventListener("afterprint", () => {
        printOpened.forEach((d) => (d.open = false));
        printOpened = [];
        if (printWasDark)
          document.documentElement.setAttribute("data-theme", "dark");
      });

      // Run per-page setup on first load and after every view-transition swap
      // (astro:page-load fires on the initial load too).
      document.addEventListener("astro:page-load", setupPage);
      // Paint progress + the done button onto the INCOMING document before the
      // swap, so navigating between modules never flashes the default (unmarked)
      // state for a frame — same reasoning as the theme apply above.
      document.addEventListener("astro:before-swap", (e) => {
        const doc = (e as Event & { newDocument: Document }).newDocument;
        paintProgress(doc);
        paintDoneBtn(doc);
      });
    </script>
  </body>
</html>
