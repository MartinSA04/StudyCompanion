---
import { parse } from "yaml";
import { ClientRouter } from "astro:transitions";
import ThemeToggle from "../../src/components/ThemeToggle.astro";
import { faviconDataUri } from "../../src/lib/favicon.ts";
// Vite resolves `?raw` relative to this source file at bundle time
// (cwd-independent) and puts the YAML in the module graph so `hub:dev`
// hot-reloads it.
import raw from "../courses.yaml?raw";
import {
  daysUntil,
  formatExamCountdown,
  EXAM_PAST_LABEL,
} from "../../src/lib/countdown.ts";
import "../../src/styles/fonts.css";
import "../../src/styles/tokens.css";
import "../../src/styles/base.css";
import "../../src/styles/primitives.css";

/**
 * kurs.martinsundal.no — course hub one-pager (spec:
 * docs/superpowers/specs/2026-07-12-pages-hub-design.md). All visual language
 * comes from the framework's own styles; this page only lays out tiles.
 */
type HubCourse = {
  code: string;
  title: string;
  url: string;
  term: string;
  note?: string;
  /** Hand-mirrored from the course repo's exam.date (see courses.yaml). */
  examDate?: string;
};
const courses = parse(raw) as HubCourse[];

// A tile's live countdown: the same phrase the course header shows, computed
// at build time and re-derived client-side (script below). A past exam yields a
// null pill (hidden) — a completed course shouldn't advertise a stale date.
const countdownFor = (c: HubCourse) => {
  if (!c.examDate) return null;
  const date = new Date(c.examDate);
  if (Number.isNaN(date.getTime())) return null;
  const days = daysUntil(date);
  return {
    iso: date.toISOString(),
    days,
    phrase: days < 0 ? EXAM_PAST_LABEL : formatExamCountdown(days),
  };
};

// Group by term, groups in file order of first appearance. Within a term, tiles
// sort by soonest exam (F11) — the multi-course triage glance "which exam is
// closest?" — with undated courses last, keeping their file order.
const groups: { term: string; courses: HubCourse[] }[] = [];
for (const c of courses) {
  const g = groups.find((g) => g.term === c.term);
  if (g) g.courses.push(c);
  else groups.push({ term: c.term, courses: [c] });
}
for (const g of groups) {
  g.courses.sort((a, b) => {
    if (!a.examDate && !b.examDate) return 0;
    if (!a.examDate) return 1;
    if (!b.examDate) return -1;
    return a.examDate.localeCompare(b.examDate);
  });
}
// "H2026" → "Høst 2026", "V2026" → "Vår 2026" (term shape is CI-tested).
const termLabel = (t: string) =>
  `${t[0] === "H" ? "Høst" : "Vår"} ${t.slice(1)}`;

const description =
  "Interaktive studieguider med flashcards, quiz og formelsamling.";

const themeKey = "sc:theme:hub";
---

<!doctype html>
<html lang="nb">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Studieguider — Martin Sundal</title>
    <meta name="description" content={description} />
    <link rel="icon" href={faviconDataUri("#205ea6")} />
    <script is:inline define:vars={{ themeKey }}>
      // No-flash theme init — trimmed from CourseLayout (single page: no
      // view-transition swaps to re-apply across). An explicit stored choice
      // wins; otherwise the OS preference does, tracked live. The OS path
      // dispatches sc:themechange so ThemeToggle can mirror aria-pressed.
      (function () {
        function isDark() {
          try {
            const saved = localStorage.getItem(themeKey);
            return saved
              ? saved === "dark"
              : matchMedia("(prefers-color-scheme: dark)").matches;
          } catch (e) {
            return false;
          }
        }
        function applyTheme() {
          if (isDark())
            document.documentElement.setAttribute("data-theme", "dark");
          else document.documentElement.removeAttribute("data-theme");
        }
        applyTheme();
        matchMedia("(prefers-color-scheme: dark)").addEventListener(
          "change",
          function () {
            try {
              if (localStorage.getItem(themeKey)) return;
            } catch (e) {
              /* storage disabled — OS still wins */
            }
            applyTheme();
            document.dispatchEvent(
              new CustomEvent("sc:themechange", {
                detail:
                  document.documentElement.getAttribute("data-theme") === "dark"
                    ? "dark"
                    : "light",
              }),
            );
          },
        );
      })();
    </script>
    {
      /* Privacy-friendly analytics — mirrors CourseLayout's wiring: production
         builds only (never `astro dev`), cookieless, `is:inline` so the
         third-party CDN tag is emitted verbatim. */
      import.meta.env.PROD && (
        <script
          is:inline
          data-goatcounter="https://kursmartinsundal.goatcounter.com/count"
          async
          src="https://gc.zgo.at/count.js"
        />
      )
    }
    {
      /* ClientRouter so astro:page-load fires and ThemeToggle's onPage wiring
        runs — the same lifecycle contract the toggle has in CourseLayout. */
    }
    <ClientRouter />
  </head>
  <body>
    <div class="hub">
      <header class="hub-head">
        <h1>Studieguider</h1>
        <ThemeToggle storageKey={themeKey} />
      </header>
      <p class="hub-intro">{description}</p>
      {
        groups.map((g) => (
          <section class="hub-term">
            <h2 class="hub-term-label sc-kicker">{termLabel(g.term)}</h2>
            <ul class="hub-list">
              {g.courses.map((c) => {
                const cd = countdownFor(c);
                return (
                  <li>
                    <a class="hub-tile sc-press sc-tile sc-lift" href={c.url}>
                      <span class="hub-tile-head">
                        <span class="hub-code sc-kicker">{c.code}</span>
                        {cd && (
                          <time
                            class="sc-countdown hub-countdown"
                            datetime={c.examDate}
                            data-exam-countdown={cd.iso}
                            data-past={cd.days < 0}
                            data-countdown-hide-past
                            hidden={cd.days < 0}
                          >
                            {cd.phrase}
                          </time>
                        )}
                      </span>
                      <span class="hub-title">{c.title}</span>
                      {c.note && <span class="hub-note">{c.note}</span>}
                    </a>
                  </li>
                );
              })}
            </ul>
          </section>
        ))
      }
      <script>
        import { onPage } from "../../src/lib/pageLifecycle.ts";
        import { refreshExamCountdowns } from "../../src/lib/examCountdown.ts";
        // Tile countdowns SSR a build-time snapshot; re-derive per load against
        // the viewer's clock (and hide any that have since passed) — the same
        // contract the course header's pill uses.
        onPage(() => refreshExamCountdowns());
      </script>
      <footer class="hub-foot">
        <a href="https://github.com/MartinSA04/StudyCompanion"
          >StudyCompanion på GitHub</a
        > · <a href="https://martinsundal.no">martinsundal.no</a>
      </footer>
    </div>
  </body>
</html>

<style>
  .hub {
    max-width: var(--measure);
    margin-inline: auto;
    padding: var(--space-6) var(--space-4);
  }
  .hub-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-2);
  }
  .hub-intro {
    color: var(--muted);
    margin-bottom: var(--space-6);
  }
  .hub-term {
    margin-bottom: var(--space-6);
  }
  .hub-term-label {
    margin-bottom: var(--space-3);
  }
  .hub-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  /* Float (fill + shadow + radius) plus the hover shadow-lift come from the
     shared .sc-tile primitive; the 1px rise and press dip from .sc-lift /
     .sc-press. These are big cards, so they use the same tile language as the
     overview module tiles. Only layout and type are local. */
  .hub-tile {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
    text-decoration: none;
    color: var(--fg);
  }
  /* Code on the left, the exam countdown pill (when present) opposite it — the
     tile's "which exam is closest" glance without opening the course. */
  .hub-tile-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }
  /* Mono uppercase recipe from .sc-kicker; --accent-ink for AA on the panel
     fill in both themes (same reasoning as the flashcard section kicker). */
  .hub-code {
    color: var(--accent-ink);
  }
  /* The pill is fully the shared .sc-countdown; keep it from stretching the row. */
  .hub-countdown {
    flex: none;
  }
  .hub-title {
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
  }
  /* Small muted mono aside (e.g. "no longer maintained") — same tone as the
     footer, kept quiet so it never competes with the title. */
  .hub-note {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
  }
  .hub-foot {
    margin-top: var(--space-6);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
    text-align: center;
  }
  .hub-foot a {
    color: var(--muted);
  }
  .hub-foot a:hover {
    color: var(--accent-ink);
  }
</style>
