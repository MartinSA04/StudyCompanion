{
  "name": "study-companion",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",

  // Personal baseline (mise + git + gh + Claude Code, and zsh/starship),
  // published from github.com/MartinSA04/devcontainer-base.
  //
  // As of feature v1.2.0, Claude persistence (the CLAUDE_CONFIG_DIR env, the
  // claude-${devcontainerId} volume, and its chown) is baked into the feature
  // itself — so there is nothing to wire up here for it.
  "features": {
    "ghcr.io/martinsa04/devcontainer-base/mise-and-tools:1": {
      "installZsh": true,
      "installClaudeCode": true,
      "claudeCodeVersion": "stable"
    }
  },

  // Keep node_modules in a named volume (keyed by ${devcontainerId}, so it's
  // isolated per project and survives rebuilds) => the container's arch-specific
  // installs never collide with tooling run on the host, and installs are faster.
  "mounts": [
    "source=node-modules-${devcontainerId},target=${containerWorkspaceFolder}/node_modules,type=volume"
  ],

  // A freshly created volume is root-owned — hand node_modules to the remote
  // user, then provision the toolchain from mise.toml and install dependencies.
  // `mise exec` runs pnpm with the mise-managed tools on PATH (postCreate is a
  // non-interactive shell where mise isn't auto-activated).
  //
  // The final step installs the Chromium build + its apt system libs that
  // `pnpm test:visual` (Playwright) needs — the SAME command CI runs
  // (.github/workflows/visual.yml), so local snapshots match the committed
  // Linux baselines. `--with-deps` shells out to `sudo apt-get`; the vscode user
  // has passwordless sudo, so it runs unattended. Browsers land in
  // ~/.cache/ms-playwright (outside the node_modules volume), so this reruns on
  // each rebuild — which is correct, since the apt libs reset with the image too.
  "postCreateCommand": "sudo chown -R $(whoami) node_modules 2>/dev/null; mise trust && mise install && mise exec -- pnpm install && mise exec -- pnpm exec playwright install --with-deps chromium",

  "remoteUser": "vscode",

  // Astro dev server.
  "forwardPorts": [4321],
  "portsAttributes": {
    "4321": { "label": "astro dev", "onAutoForward": "notify" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "astro-build.astro-vscode",
        "esbenp.prettier-vscode",
        "unifiedjs.vscode-mdx"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
      }
    }
  }
}
