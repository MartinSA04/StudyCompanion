{
  "name": "study-companion",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",

  // Personal baseline (mise + git + gh + Claude Code, and zsh/starship),
  // published from github.com/MartinSA04/devcontainer-base (template: mise-claude).
  //
  // As of feature v1.2.0, Claude persistence (the CLAUDE_CONFIG_DIR env, the
  // claude-${devcontainerId} volume, and its chown) is baked into the feature
  // itself — so there is nothing to wire up here for it.
  "features": {
    "ghcr.io/martinsa04/devcontainer-base/mise-and-tools:1": {
      "installZsh": true,
      "installClaudeCode": true,
      "claudeCodeVersion": "stable"
    }
  },

  // Keep node_modules in a named volume (keyed by ${devcontainerId}, so it's
  // isolated per project and survives rebuilds) => the container's arch-specific
  // installs never collide with tooling run on the host, and installs are faster.
  //
  // The id_git mount gives the container your GitHub SSH key (read-only). Only
  // ~/.ssh/id_git is exposed — never your other keys — and post-create.sh writes
  // an ~/.ssh/config that pins github.com to it. Without this, the forwarded SSH
  // agent may offer another key first (e.g. a read-only work deploy key), which
  // wins the handshake and blocks pushes. Requires ~/.ssh/id_git on the host (a
  // key registered on your GitHub account); drop this line and the ssh block in
  // post-create.sh if unused.
  "mounts": [
    "source=node-modules-${devcontainerId},target=${containerWorkspaceFolder}/node_modules,type=volume",
    "source=${localEnv:HOME}/.ssh/id_git,target=/home/vscode/.ssh/id_git,type=bind,readonly"
  ],

  // Provisioning (dep-dir ownership, mise toolchain, pnpm install, the Playwright
  // Chromium build for `pnpm test:visual`, and the GitHub SSH config) lives in
  // .devcontainer/post-create.sh. Note: mise's managed tools are NOT auto-
  // activated in this non-interactive shell, so install steps go through
  // `mise exec --` (e.g. `mise exec -- pnpm install`).
  "postCreateCommand": "bash .devcontainer/post-create.sh",

  "remoteUser": "vscode",

  // Astro dev server.
  "forwardPorts": [4321],
  "portsAttributes": {
    "4321": { "label": "astro dev", "onAutoForward": "notify" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "astro-build.astro-vscode",
        "esbenp.prettier-vscode",
        "unifiedjs.vscode-mdx"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
      }
    }
  }
}
